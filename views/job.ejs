<!doctype html>
<html lang="zh-CN">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>任务进度 - 书签管理器</title>
  <link rel="stylesheet" href="/public/tailwind.generated.css" />
  <link rel="stylesheet" href="/public/app.css" />
  <script src="/public/dialog.js"></script>
  <script>
    (function () {
      var theme = localStorage.getItem('theme');
      if (theme === 'dark') {
        document.documentElement.setAttribute('data-theme', 'dark');
      } else if (theme === 'light') {
        document.documentElement.setAttribute('data-theme', 'light');
      }
    })();
  </script>
</head>

<body class="app-shell job-detail-page" data-testid="job-detail-page" data-job-id="<%= job.id %>" data-processed="<%= job.processed %>"
  data-total="<%= job.total %>" data-plan-id="<%= typeof organizePlanId !== 'undefined' && organizePlanId ? organizePlanId : '' %>">
  <%
    const isLegacyAiTask = job.type === 'ai_classify' || job.type === 'ai_simplify';
    const jobIcon = job.type === 'ai_organize' ? '🤖' : isLegacyAiTask ? '🗂️' : job.type === 'import' ? '📥' : '🔍';
    const jobLabel =
      job.type === 'ai_organize' ? 'AI 整理任务'
      : isLegacyAiTask ? '历史 AI 任务（已下线）'
      : job.type === 'import' ? '导入任务'
      : '书签检查任务';
    const jobSuccessLabel =
      job.type === 'ai_organize' ? '已分配'
      : job.type === 'import' ? '已导入'
      : isLegacyAiTask ? '已处理'
      : '成功';
    const jobBarClass =
      job.type === 'ai_organize' ? 'bg-gradient-to-r from-blue-500 to-blue-700'
      : isLegacyAiTask ? 'bg-gradient-to-r from-amber-500 to-amber-700'
      : job.type === 'import' ? 'bg-gradient-to-r from-emerald-500 to-emerald-700'
      : 'bg-gradient-to-r from-slate-700 to-slate-900';
    const jobStatusLabel =
      job.status === 'running' ? '运行中'
      : job.status === 'pending' ? '等待中'
      : job.status === 'queued' ? '排队中'
      : job.status === 'done' ? '已完成'
      : job.status === 'failed' ? '失败'
      : job.status === 'canceled' || job.status === 'cancelled' ? '已取消'
      : job.status;
    const jobStatusClass =
      job.status === 'running' || job.status === 'pending' || job.status === 'queued' ? 'status-badge--info'
      : job.status === 'done' ? 'status-badge--success'
      : job.status === 'failed' ? 'status-badge--danger'
      : 'status-badge--muted';
    const jobProgressPercent = job.total > 0 ? Math.min(100, Math.floor((job.processed / job.total) * 100)) : 0;
    const jobIconBadgeClass =
      job.type === 'ai_organize' ? 'job-icon-badge--ai'
      : isLegacyAiTask ? 'job-icon-badge--legacy'
      : job.type === 'import' ? 'job-icon-badge--import'
      : 'job-icon-badge--check';

    function getPlanStatusLabel(status) {
      if (status === 'preview') return '待应用';
      if (status === 'applied') return '已应用';
      if (status === 'assigning') return '分配中';
      if (status === 'failed') return '失败';
      if (status === 'error') return '错误';
      if (status === 'canceled' || status === 'cancelled') return '已取消';
      return status || '未知';
    }

    function getPlanStatusClass(status) {
      if (status === 'preview' || status === 'assigning') return 'status-badge--info';
      if (status === 'applied') return 'status-badge--success';
      if (status === 'failed' || status === 'error') return 'status-badge--danger';
      return 'status-badge--muted';
    }
  %>
  <header class="page-topbar glass-header">
    <div class="page-topbar__inner">
      <div class="page-topbar__meta">
        <div class="page-kicker">Jobs center</div>
        <div class="page-heading">📊 任务进度</div>
        <div class="page-subheading">ID：<span class="font-mono"><%= job.id %></span></div>
      </div>
      <div class="page-actions">
        <button id="theme-toggle" class="btn-secondary btn-sm" aria-label="切换主题">🌙</button>
        <a class="btn-secondary btn-sm" href="/jobs">任务列表</a>
        <a class="btn-secondary btn-sm" href="<%= backUrl %>">← 返回</a>
      </div>
    </div>
  </header>

  <div class="page-shell page-content">
    <section class="panel-card job-hero-card">
      <div class="panel-header job-hero-header">
        <div class="job-title-group">
          <span class="job-icon-badge <%= jobIconBadgeClass %>" aria-hidden="true"><%= jobIcon %></span>
          <div class="job-hero-text">
            <div class="panel-title">
              <span><%= jobLabel %></span>
              <span id="job-status" data-testid="job-status" class="status-badge <%= jobStatusClass %>"><%= jobStatusLabel %></span>
            </div>
            <p class="job-hero-subtitle">任务详情保留既有 `/jobs*` 契约、取消动作与 SSE / 轮询语义，只重构信息层级、状态可见性与移动端阅读体验。</p>
          </div>
        </div>
        <div class="panel-actions job-hero-actions">
          <% if (job.status==='running' || job.status==='pending' || job.status==='queued') { %>
            <button id="cancel-job-btn" data-testid="cancel-job-btn" class="btn-danger btn-sm">取消任务</button>
          <% } %>
        </div>
      </div>

      <div class="surface-muted job-message-card">
        <div class="job-message-card__label">任务消息</div>
        <div id="job-message" data-testid="job-message" class="job-message-card__value"><%= job.message || '' %></div>
      </div>

      <div class="job-summary-grid" data-testid="job-summary-grid">
        <article class="job-summary-card">
          <div class="job-summary-card__label">任务 ID</div>
          <div class="job-summary-card__value job-summary-card__value--code"><%= job.id %></div>
          <div class="job-summary-card__meta">详情页、失败分页与任务事件都继续基于同一 job 资源加载。</div>
        </article>
        <article class="job-summary-card">
          <div class="job-summary-card__label">创建时间</div>
          <div class="job-summary-card__value"><%= new Date(job.created_at).toLocaleString('zh-CN') %></div>
          <div class="job-summary-card__meta">任务类型：<span class="font-medium text-slate-700"><%= job.type %></span></div>
        </article>
        <article class="job-summary-card">
          <div class="job-summary-card__label">最近更新时间</div>
          <div class="job-summary-card__value"><span id="job-updated" data-testid="job-updated"><%= new Date(job.updated_at).toLocaleString('zh-CN') %></span></div>
          <div class="job-summary-card__meta">完成后页面会自动回载，以显示最新失败表与整理计划状态。</div>
        </article>
        <article class="job-summary-card">
          <div class="job-summary-card__label">当前进度</div>
          <div class="job-summary-card__value"><span id="job-progress-percent" data-testid="job-progress-percent"><%= jobProgressPercent %>%</span></div>
          <div class="job-summary-card__meta">适用于导入、检查与 AI organize 的统一进度反馈。</div>
        </article>
      </div>

      <div class="surface-muted job-progress-card">
        <div class="job-progress-card__top">
          <div>
            <div class="job-progress-card__label">执行进度</div>
            <div class="job-progress-card__description">SSE 连接异常时会自动回退到轮询，避免任务状态看起来“卡住”。</div>
          </div>
          <% if ((isLegacyAiTask || job.type === 'ai_organize') && job.extra) { try { const extra = JSON.parse(job.extra); if (extra.tokenEstimate) { %>
            <span class="status-badge status-badge--success">预估 Token ~<%= extra.tokenEstimate.estimatedTotalTokens.toLocaleString() %></span>
          <% } } catch(e) {} } %>
        </div>
        <div class="job-progress-track">
          <div id="job-bar" data-testid="job-bar" class="job-progress-fill <%= jobBarClass %> transition-all duration-300" style="width: <%= jobProgressPercent %>%"></div>
        </div>
        <div id="current-item" data-testid="job-current-item" class="job-current-item <%= job.message && job.message.includes('检查') ? '' : 'opacity-0' %>"><%= job.message && job.message.includes('检查') ? job.message : '' %></div>
        <div class="job-metric-pills" data-testid="job-progress-summary">
          <span class="job-metric-pill"><span>进度</span><strong><span id="job-progress" data-testid="job-progress"><%= job.processed %></span>/<span id="job-total" data-testid="job-total"><%= job.total %></span></strong></span>
          <span class="job-metric-pill job-metric-pill--success"><span><%= jobSuccessLabel %></span><strong><span id="job-inserted" data-testid="job-inserted"><%= job.inserted %></span></strong></span>
          <span class="job-metric-pill job-metric-pill--warning"><span>跳过</span><strong><span id="job-skipped" data-testid="job-skipped"><%= job.skipped %></span></strong></span>
          <span class="job-metric-pill job-metric-pill--danger"><span>失败</span><strong><span id="job-failed" data-testid="job-failed"><%= job.failed %></span></strong></span>
        </div>
      </div>
    </section>

    <% if (job.type === 'ai_organize' && organizePlanStatus === 'preview' && organizeDiff) { %>
      <section class="panel-card job-section-card" id="plan-action-block">
        <div class="panel-header">
          <div>
            <div class="panel-title">
              <span aria-hidden="true">🧠</span>
              <span>整理计划预览</span>
            </div>
            <p class="panel-description">支持逐条选择应用或放弃；完成本次计划前，不能开始下一次整理。</p>
          </div>
          <span id="plan-status-badge" class="status-badge <%= getPlanStatusClass('preview') %>"><%= getPlanStatusLabel('preview') %></span>
        </div>
        <% if (organizePlanTemplateName) { %>
          <div class="job-summary-card__meta">将应用于模板：<span class="font-medium text-slate-700"><%= organizePlanTemplateName %></span></div>
        <% } %>
        <div class="job-plan-grid" data-testid="organize-plan-summary">
          <article class="job-summary-card">
            <div class="job-summary-card__label">移动书签</div>
            <div class="job-summary-card__value"><%= organizeDiff.summary.move_count %></div>
            <div class="job-summary-card__meta">按当前预览计划完成归类移动。</div>
          </article>
          <article class="job-summary-card">
            <div class="job-summary-card__label">空分类</div>
            <div class="job-summary-card__value"><%= organizeDiff.summary.empty_count %></div>
            <div class="job-summary-card__meta">应用后可能需要确认保留或删除。</div>
          </article>
          <article class="job-summary-card">
            <div class="job-summary-card__label">待审核</div>
            <div class="job-summary-card__value"><%= organizeDiff.summary.needs_review %></div>
            <div class="job-summary-card__meta">未匹配项默认放弃，可逐条切换。</div>
          </article>
        </div>
        <div class="surface-muted job-plan-note">
          已匹配分类的书签默认应用，未匹配到分类的书签默认放弃；若应用时发生冲突，会进入人工确认步骤。
        </div>
        <div id="plan-actions" class="job-toolbar">
          <button id="discard-plan-btn" class="btn-secondary btn-sm">放弃</button>
          <button id="apply-all-plan-btn" class="btn-secondary btn-sm">全部应用</button>
          <button id="apply-plan-btn" class="btn-primary btn-sm">应用已选</button>
        </div>
        <div id="plan-resolve" class="hidden mt-4 border-t pt-4 space-y-3">
          <div class="text-sm font-medium text-slate-700">冲突解决</div>
          <% if (organizePlanTemplateName) { %>
            <div class="job-summary-card__meta">将应用于模板：<span class="font-medium text-slate-700"><%= organizePlanTemplateName %></span></div>
          <% } %>
          <div id="resolve-conflicts" class="hidden">
            <div class="text-xs text-slate-500 mb-2">以下书签存在冲突，请选择处理方式：</div>
            <div id="resolve-conflicts-list" class="job-resolve-list custom-scrollbar max-h-48 overflow-y-auto"></div>
          </div>
          <div id="resolve-empty" class="hidden">
            <div class="text-xs text-slate-500 mb-2">以下分类将变为空分类：</div>
            <div id="resolve-empty-list" class="job-resolve-list custom-scrollbar max-h-32 overflow-y-auto"></div>
          </div>
          <div class="job-toolbar job-toolbar--compact">
            <button id="resolve-back-btn" class="btn-secondary btn-sm">返回</button>
            <button id="resolve-confirm-btn" class="btn-primary btn-sm">确认并应用</button>
          </div>
        </div>
        <div id="plan-applied" class="hidden mt-4 border-t pt-4">
          <div class="flex flex-col items-center gap-2 py-3">
            <div class="w-10 h-10 rounded-full bg-green-100 flex items-center justify-center text-xl">✓</div>
            <div class="text-sm font-medium text-green-700">整理已应用</div>
            <div id="plan-applied-msg" class="text-xs text-slate-500"></div>
          </div>
        </div>
        <div id="plan-canceled" class="hidden mt-4 border-t pt-4">
          <div class="flex flex-col items-center gap-2 py-3">
            <div class="w-10 h-10 rounded-full bg-slate-100 flex items-center justify-center text-xl">✕</div>
            <div class="text-sm font-medium text-slate-500">已取消</div>
          </div>
        </div>
      </section>
    <% } %>

    <% if (job.failed > 0) { %>
      <section class="panel-card job-section-card job-table-card">
        <div class="panel-header">
          <div>
            <div class="panel-title">失败项（共 <span id="failure-total"><%= typeof failureTotal==='number' ? failureTotal : failures.length %></span> 条）</div>
            <p class="panel-description">失败明细保留既有 AJAX 分页与页大小切换语义，方便快速筛查输入与错误原因。</p>
          </div>
          <label class="form-field job-inline-select">
            <span class="form-label">每页</span>
            <select id="fail-page-size" data-testid="failure-page-size" class="form-control">
              <option value="20" <%=failPageSize===20 ? 'selected' : '' %>>20</option>
              <option value="50" <%=failPageSize===50 ? 'selected' : '' %>>50</option>
              <option value="100" <%=failPageSize===100 ? 'selected' : '' %>>100</option>
            </select>
          </label>
        </div>
        <div class="table-shell" data-testid="failure-table">
          <div class="table-scroll custom-scrollbar">
            <table class="w-full table-fixed">
              <thead>
                <tr>
                  <th class="w-[45%] px-3 py-2 text-left text-xs font-semibold text-slate-600">输入</th>
                  <th class="w-[55%] px-3 py-2 text-left text-xs font-semibold text-slate-600">原因</th>
                </tr>
              </thead>
              <tbody id="failures" data-testid="failure-list" class="divide-y">
                <% if (!failures.length) { %>
                  <tr><td colspan="2" class="px-3 py-6 text-center text-sm text-slate-500">暂无</td></tr>
                <% } %>
                <% failures.forEach(function(f) { %>
                  <tr class="failure-row" data-testid="failure-row">
                    <td class="px-3 py-2 text-sm text-slate-700" data-testid="failure-input">
                      <div class="truncate" title="<%= f.input %>"><%= f.input %></div>
                    </td>
                    <td class="px-3 py-2 text-sm text-rose-700" data-testid="failure-reason">
                      <div class="custom-scrollbar whitespace-pre-wrap break-words max-h-28 overflow-y-auto"><%= f.reason %></div>
                    </td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        </div>
        <div id="fail-pager" data-testid="failure-pager" class="job-pager <%= failTotalPages > 1 ? '' : 'hidden' %>">
          <div class="text-xs text-slate-500">第 <span id="fail-current-page" data-testid="failure-current-page"><%= failPage %></span>/<span id="fail-total-pages" data-testid="failure-total-pages"><%= failTotalPages %></span> 页</div>
          <div class="flex items-center gap-2">
            <button id="fail-prev-btn" data-testid="failure-prev-btn" class="btn-secondary btn-sm" <%=failPage<=1 ? 'disabled' : '' %>>上一页</button>
            <button id="fail-next-btn" data-testid="failure-next-btn" class="btn-secondary btn-sm" <%=failPage>=failTotalPages ? 'disabled' : '' %>>下一页</button>
          </div>
        </div>
        <div class="form-hint">失败项会实时更新；任务结束后刷新页面可查看完整列表。</div>
      </section>
    <% } %>

    <% if (isLegacyAiTask) { %>
      <section class="panel-card job-warning-card">
        <div class="job-warning-card__title">历史遗留 AI 任务</div>
        <p class="job-warning-card__text">当前版本已不再提供旧的 AI 分类建议列表 / AI 精简建议应用界面。该任务仅保留为历史记录，用于查看执行状态。</p>
        <p class="job-warning-card__text">现行 AI 能力以「AI 批量分类」和「AI 整理计划」为准；若需恢复旧流程，请以 backlog 项为准而不是直接依赖此页面。</p>
      </section>
    <% } %>

    <% if (job.type === 'ai_organize' && typeof organizeAssignments !== 'undefined') { %>
      <section class="panel-card job-section-card job-table-card">
        <div class="panel-header">
          <div>
            <div class="panel-title">分类建议（共 <span><%= organizeAssignmentTotal %></span> 条）</div>
            <p class="panel-description">这里保留 preview / applied / assigning / failed 等 organize 详情状态，并继续支持逐页查看。</p>
          </div>
          <% if (organizePlanStatus) { %>
            <span class="status-badge <%= getPlanStatusClass(organizePlanStatus) %>">Plan: <%= getPlanStatusLabel(organizePlanStatus) %></span>
          <% } %>
        </div>

        <div class="table-shell">
          <div class="table-scroll custom-scrollbar max-h-[400px] overflow-y-auto">
            <table class="w-full table-fixed">
              <thead class="sticky top-0">
                <tr>
                  <th class="w-[34%] px-3 py-2 text-left text-xs font-semibold text-slate-600">书签</th>
                  <th class="w-[18%] px-3 py-2 text-left text-xs font-semibold text-slate-600">当前分类</th>
                  <th class="w-[22%] px-3 py-2 text-left text-xs font-semibold text-slate-600">建议分类</th>
                  <th id="assign-action-heading" class="w-[26%] px-3 py-2 text-left text-xs font-semibold text-slate-600"><%= organizePlanStatus === 'preview' ? '处理' : '状态' %></th>
                </tr>
              </thead>
              <tbody id="organize-assignments" class="divide-y">
                <% if (organizeAssignments.length === 0) { %>
                  <tr><td colspan="4" class="px-3 py-6 text-center text-sm text-slate-400">暂无分类建议数据</td></tr>
                <% } else { %>
                  <% organizeAssignments.forEach(function(a) { %>
                    <tr class="<%= organizePlanStatus === 'preview' && a.default_action === 'discard' ? 'bg-slate-50' : a.status === 'assigned' ? '' : 'bg-amber-50' %>" data-bookmark-id="<%= a.bookmark_id %>">
                      <td class="px-3 py-2">
                        <div class="text-sm text-slate-700 truncate"><%= a.title %></div>
                        <% if (a.url) { %>
                          <div class="text-xs text-slate-400 truncate"><%= a.url %></div>
                        <% } %>
                      </td>
                      <td class="px-3 py-2">
                        <span class="text-xs text-slate-500"><%= a.current_category || '未分类' %></span>
                      </td>
                      <td class="px-3 py-2">
                        <% if (a.category_path) { %>
                          <span class="status-badge status-badge--info"><%= a.category_path %></span>
                        <% } else { %>
                          <span class="text-xs text-amber-600">未匹配到分类，默认放弃</span>
                        <% } %>
                      </td>
                      <td class="px-3 py-2">
                        <% if (organizePlanStatus === 'preview') { %>
                          <div class="assign-action-group">
                            <button class="assign-action-btn <%= a.default_action === 'apply' ? 'assign-action-btn--apply-active' : '' %>"
                              data-bookmark-id="<%= a.bookmark_id %>" data-action="apply" data-category-path="<%= a.category_path || '' %>" data-status="<%= a.status %>" <%=a.can_apply ? '' : 'disabled' %>>应用</button>
                            <button class="assign-action-btn <%= a.default_action === 'discard' ? 'assign-action-btn--discard-active' : '' %>"
                              data-bookmark-id="<%= a.bookmark_id %>" data-action="discard" data-category-path="<%= a.category_path || '' %>" data-status="<%= a.status %>">放弃</button>
                          </div>
                        <% } else { %>
                          <% if (a.status === 'assigned') { %>
                            <span class="status-badge status-badge--success">已分配</span>
                          <% } else { %>
                            <span class="status-badge status-badge--muted">待审核</span>
                          <% } %>
                        <% } %>
                      </td>
                    </tr>
                  <% }); %>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
        <div id="assign-pager" class="job-pager <%= organizeAssignmentTotalPages > 1 ? '' : 'hidden' %>">
          <div class="text-xs text-slate-500">第 <span id="assign-current-page"><%= organizeAssignmentPage %></span>/<span id="assign-total-pages"><%= organizeAssignmentTotalPages %></span> 页</div>
          <div class="flex items-center gap-2">
            <button id="assign-prev-btn" class="btn-secondary btn-sm" <%=organizeAssignmentPage<=1 ? 'disabled' : '' %>>上一页</button>
            <button id="assign-next-btn" class="btn-secondary btn-sm" <%=organizeAssignmentPage>=organizeAssignmentTotalPages ? 'disabled' : '' %>>下一页</button>
          </div>
        </div>
      </section>
    <% } %>
  </div>

  <script>
    function updateBar(processed, total) {
      var pct = 0;
      if (total > 0) pct = Math.min(100, Math.floor((processed / total) * 100));
      var bar = document.getElementById('job-bar');
      if (bar) bar.style.width = pct + '%';
      var pctEl = document.getElementById('job-progress-percent');
      if (pctEl) pctEl.textContent = pct + '%';
    }

    function showCurrentItem(message) {
      var el = document.getElementById('current-item');
      if (message && message.includes('检查')) {
        el.textContent = message;
        el.style.opacity = '1';
      } else {
        el.style.opacity = '0';
      }
    }

    function getJobStatusMeta(status) {
      if (status === 'running') return { label: '运行中', tone: 'status-badge--info' };
      if (status === 'pending') return { label: '等待中', tone: 'status-badge--info' };
      if (status === 'queued') return { label: '排队中', tone: 'status-badge--info' };
      if (status === 'done') return { label: '已完成', tone: 'status-badge--success' };
      if (status === 'failed') return { label: '失败', tone: 'status-badge--danger' };
      if (status === 'canceled' || status === 'cancelled') return { label: '已取消', tone: 'status-badge--muted' };
      return { label: status || '未知', tone: 'status-badge--muted' };
    }

    function applyStatusBadge(el, status) {
      if (!el) return;
      var meta = getJobStatusMeta(status);
      el.textContent = meta.label;
      el.className = 'status-badge ' + meta.tone;
    }

    function getPlanStatusMeta(status) {
      if (status === 'preview') return { label: '待应用', tone: 'status-badge--info' };
      if (status === 'assigning') return { label: '分配中', tone: 'status-badge--info' };
      if (status === 'applied') return { label: '已应用', tone: 'status-badge--success' };
      if (status === 'failed') return { label: '失败', tone: 'status-badge--danger' };
      if (status === 'error') return { label: '错误', tone: 'status-badge--danger' };
      if (status === 'canceled' || status === 'cancelled') return { label: '已取消', tone: 'status-badge--muted' };
      return { label: status || '未知', tone: 'status-badge--muted' };
    }

    var jobId = document.body.dataset.jobId;
    var processed = Number(document.body.dataset.processed || '0');
    var total = Number(document.body.dataset.total || '0');
    var lastFailedCount = <%= job.failed %>;
    var initialStatus = '<%= job.status %>';
    var currentJobStatus = initialStatus;

    updateBar(processed, total);

    // 快速任务检测：如果任务执行很快，可能在SSE连接前就完成了
    // 添加一个初始fetch检查作为保障
    async function recheckJobStatus() {
      try {
        var res = await fetch('/api/jobs/' + jobId);
        var data = await res.json();
        if (data && data.job) {
          updateJobUI(data.job);
        }
      } catch (err) {
        console.error('Recheck error:', err);
      }
    }

    // 只有任务还在运行时才建立SSE连接
    var es = null;
    if (initialStatus === 'running' || initialStatus === 'pending' || initialStatus === 'queued') {
      // 立即做一次状态检查，捕获快速完成的任务
      setTimeout(recheckJobStatus, 500);
      setTimeout(recheckJobStatus, 2000);
      
      es = new EventSource('/jobs/' + jobId + '/events');

      es.onopen = function () {
        console.log('SSE connected for job:', jobId);
        // SSE连接后再检查一次，防止竞态条件
        recheckJobStatus();
      };

      es.onerror = function (e) {
        console.error('SSE error:', e);
        // 连接错误时，回退到轮询
        if (es) {
          es.close();
          es = null;
        }
        startPolling();
      };

      es.onmessage = function (evt) {
        try {
          var job = JSON.parse(evt.data);
          updateJobUI(job);
        } catch (err) {
          console.error('SSE parse error:', err);
        }
      };

      es.addEventListener('batch_assignments', function (event) {
        // Reload assignments and show first page
        try {
          var data = JSON.parse(event.data);
          if (data && Array.isArray(data) && data.length > 0) {
            // Jump to first page to show new results
            if (typeof loadAssignments === 'function') {
              loadAssignments(1);
            }
          }
        } catch (err) {
          console.error('batch_assignments parse error:', err);
          // Fallback: reload current page
          if (typeof loadAssignments === 'function') loadAssignments(assignCurrentPage);
        }
      });
    }

    // 轮询作为备用方案
    var pollTimer = null;
    function startPolling() {
      if (pollTimer) return;
      pollTimer = setInterval(async function () {
        try {
          var res = await fetch('/api/jobs/current');
          var data = await res.json();
          if (data && data.job && data.job.id === jobId) {
            updateJobUI(data.job);
            if (data.job.status === 'done' || data.job.status === 'failed' || data.job.status === 'canceled') {
              clearInterval(pollTimer);
              pollTimer = null;
            }
          }
        } catch (err) {
          console.error('Poll error:', err);
        }
      }, 2000);
    }

    var lastInsertedCount = <%= job.inserted %>;
    var jobType = '<%= job.type %>';

    function updateJobUI(job) {
      var statusEl = document.getElementById('job-status');
      currentJobStatus = job.status;
      applyStatusBadge(statusEl, job.status);

      var msgEl = document.getElementById('job-message');
      if (msgEl) msgEl.textContent = job.message || '';

      var totalEl = document.getElementById('job-total');
      if (totalEl) totalEl.textContent = String(job.total);

      var progressEl = document.getElementById('job-progress');
      if (progressEl) progressEl.textContent = String(job.processed);

      var insertedEl = document.getElementById('job-inserted');
      if (insertedEl) insertedEl.textContent = String(job.inserted);

      var skippedEl = document.getElementById('job-skipped');
      if (skippedEl) skippedEl.textContent = String(job.skipped);

      var failedEl = document.getElementById('job-failed');
      if (failedEl) failedEl.textContent = String(job.failed);

      var updatedEl = document.getElementById('job-updated');
      if (updatedEl) updatedEl.textContent = new Date(job.updated_at).toLocaleString('zh-CN');

      updateBar(job.processed, job.total);
      showCurrentItem(job.message);

      // 检测到新的失败项时，刷新失败列表
      if (job.failed > lastFailedCount) {
        lastFailedCount = job.failed;
        loadFailures();
      }

      // AI分类任务：检测到新的分类建议时，刷新建议列表
      if (jobType === 'ai_classify' && job.inserted > lastInsertedCount) {
        lastInsertedCount = job.inserted;
        loadSuggestions();
      }

      // AI整理任务：检测到新的分类建议时，刷新分类建议列表
      if (jobType === 'ai_organize' && (job.inserted > lastInsertedCount || job.processed > (job.inserted + job.skipped))) {
        lastInsertedCount = job.inserted;
        if (typeof loadAssignments === 'function' && planId) {
          // Jump to first page to show new results
          loadAssignments(1);
        }
      }

      if (job.status === 'done' || job.status === 'failed' || job.status === 'canceled') {
        if (es) {
          es.close();
          es = null;
        }
        document.getElementById('current-item').style.opacity = '0';
        // 任务完成后刷新页面以显示完整数据
        if (job.status === 'done') {
          // AI整理任务：先确保预览状态已就绪再刷新
          if (jobType === 'ai_organize' && planId) {
            fetch('/api/ai/organize/' + planId)
              .then(function (res) { return res.json(); })
              .then(function (data) {
                if (data && data.status === 'preview') {
                  location.reload();
                } else {
                  // 如果预览还未就绪，稍后再试
                  setTimeout(function () { location.reload(); }, 2000);
                }
              })
              .catch(function () {
                // 出错时仍然刷新页面
                setTimeout(function () { location.reload(); }, 1000);
              });
          } else {
            setTimeout(function () { location.reload(); }, 1000);
          }
        }
      }
    }

    // 动态加载失败项 - AJAX 分页
    var failPageSize = <%= failPageSize %>;
    var failCurrentPage = <%= typeof failPage === 'number' ? failPage : 1 %>;
    var failTotalPages = <%= typeof failTotalPages === 'number' ? failTotalPages : 1 %>;

    function loadFailures(page) {
      if (typeof page === 'undefined') page = failCurrentPage;
      fetch('/api/jobs/' + jobId + '/failures?page=' + page + '&page_size=' + failPageSize)
        .then(function (res) { return res.json(); })
        .then(function (data) {
          if (!data || !data.failures) return;
          var tbody = document.getElementById('failures');
          if (!tbody) return;

          var html = '';
          if (data.failures.length === 0) {
            html = '<tr><td colspan="2" class="px-3 py-4 text-center text-sm text-slate-500">暂无</td></tr>';
          } else {
            data.failures.forEach(function (f) {
              html += '<tr class="failure-row" data-testid="failure-row">';
              html += '<td class="px-3 py-2 text-sm text-slate-700" data-testid="failure-input"><div class="truncate" title="' + escapeHtml(f.input) + '">' + escapeHtml(f.input) + '</div></td>';
              html += '<td class="px-3 py-2 text-sm text-rose-700" data-testid="failure-reason"><div class="custom-scrollbar whitespace-pre-wrap break-words max-h-28 overflow-y-auto">' + escapeHtml(f.reason) + '</div></td>';
              html += '</tr>';
            });
          }
          tbody.innerHTML = html;

          var failureTotalEl = document.getElementById('failure-total');
          if (failureTotalEl) failureTotalEl.textContent = data.total;

          failCurrentPage = data.page;
          failTotalPages = data.totalPages;
          var pager = document.getElementById('fail-pager');
          if (pager) pager.classList.toggle('hidden', failTotalPages <= 1);
          var cpEl = document.getElementById('fail-current-page');
          var tpEl = document.getElementById('fail-total-pages');
          if (cpEl) cpEl.textContent = failCurrentPage;
          if (tpEl) tpEl.textContent = failTotalPages;
          var prevBtn = document.getElementById('fail-prev-btn');
          var nextBtn = document.getElementById('fail-next-btn');
          if (prevBtn) prevBtn.disabled = failCurrentPage <= 1;
          if (nextBtn) nextBtn.disabled = failCurrentPage >= failTotalPages;
        })
        .catch(function () { });
    }

    // 失败项分页按钮
    (function () {
      var prevBtn = document.getElementById('fail-prev-btn');
      var nextBtn = document.getElementById('fail-next-btn');
      var sizeSelect = document.getElementById('fail-page-size');
      if (prevBtn) prevBtn.addEventListener('click', function () { if (failCurrentPage > 1) loadFailures(failCurrentPage - 1); });
      if (nextBtn) nextBtn.addEventListener('click', function () { if (failCurrentPage < failTotalPages) loadFailures(failCurrentPage + 1); });
      if (sizeSelect) sizeSelect.addEventListener('change', function () { failPageSize = parseInt(this.value, 10) || 20; loadFailures(1); });
    })();

    // 动态加载 organize assignments - AJAX 分页
    var planId = document.body.dataset.planId || '';
    var planStatus = '<%= organizePlanStatus || "" %>';
    var assignCurrentPage = <%= typeof organizeAssignmentPage === 'number' ? organizeAssignmentPage : 1 %>;
    var assignTotalPages = <%= typeof organizeAssignmentTotalPages === 'number' ? organizeAssignmentTotalPages : 1 %>;
    var assignPageSize = <%= typeof organizePageSize === 'number' ? organizePageSize : 20 %>;
    var planSelectionOverrides = {};

    function canApplyPlanAssignment(assignment) {
      return !!assignment && assignment.status === 'assigned' && assignment.category_path && String(assignment.category_path).trim() !== '';
    }

    function getDefaultPlanAction(assignment) {
      return canApplyPlanAssignment(assignment) ? 'apply' : 'discard';
    }

    function getPlanSelectionAction(assignment) {
      return planSelectionOverrides[assignment.bookmark_id] || getDefaultPlanAction(assignment);
    }

    function setPlanSelectionAction(assignment, action) {
      if (!assignment || !assignment.bookmark_id) return;
      var nextAction = action === 'apply' && canApplyPlanAssignment(assignment) ? 'apply' : 'discard';
      var defaultAction = getDefaultPlanAction(assignment);
      if (nextAction === defaultAction) delete planSelectionOverrides[assignment.bookmark_id];
      else planSelectionOverrides[assignment.bookmark_id] = nextAction;
    }

    function collectPlanDecisionOverrides() {
      return Object.keys(planSelectionOverrides).map(function (bookmarkId) {
        return { bookmark_id: Number(bookmarkId), action: planSelectionOverrides[bookmarkId] };
      }).filter(function (item) {
        return Number.isInteger(item.bookmark_id) && item.bookmark_id > 0 && (item.action === 'apply' || item.action === 'discard');
      });
    }

    function setPlanUiStatus(status) {
      planStatus = status || planStatus;
      var badge = document.getElementById('plan-status-badge');
      if (badge) {
        var meta = getPlanStatusMeta(planStatus);
        badge.textContent = meta.label;
        badge.className = 'status-badge ' + meta.tone;
      }
      var heading = document.getElementById('assign-action-heading');
      if (heading) heading.textContent = planStatus === 'preview' ? '处理' : '状态';
      planSelectionOverrides = {};
      loadAssignments(assignCurrentPage);
    }

    function bindAssignmentDecisionButtons() {
      document.querySelectorAll('.assign-action-btn').forEach(function (btn) {
        btn.addEventListener('click', function () {
          var bookmarkId = Number(this.dataset.bookmarkId);
          var action = this.dataset.action === 'apply' ? 'apply' : 'discard';
          var assignment = {
            bookmark_id: bookmarkId,
            category_path: this.dataset.categoryPath || '',
            status: this.dataset.status || '',
          };
          setPlanSelectionAction(assignment, action);
          loadAssignments(assignCurrentPage);
        });
      });
    }

    function loadAssignments(page) {
      if (!planId) return;
      if (typeof page === 'undefined') page = assignCurrentPage;
      fetch('/api/ai/organize/' + planId + '/assignments?page=' + page + '&page_size=' + assignPageSize)
        .then(function (res) { return res.json(); })
        .then(function (data) {
          if (!data || !data.assignments) return;
          var tbody = document.getElementById('organize-assignments');
          if (!tbody) return;

          var html = '';
          if (data.assignments.length === 0) {
            html = '<tr><td colspan="4" class="px-3 py-6 text-center text-sm text-slate-400">暂无分类建议数据</td></tr>';
          } else {
            data.assignments.forEach(function (a) {
              var selectedAction = getPlanSelectionAction(a);
              html += '<tr class="' + (planStatus === 'preview' && selectedAction === 'discard' ? 'bg-slate-50' : (a.status === 'assigned' ? '' : 'bg-amber-50')) + '" data-bookmark-id="' + a.bookmark_id + '">';
              html += '<td class="px-3 py-2"><div class="text-sm text-slate-700 truncate">' + escapeHtml(a.title) + '</div>';
              if (a.url) html += '<div class="text-xs text-slate-400 truncate">' + escapeHtml(a.url) + '</div>';
              html += '</td><td class="px-3 py-2">';
              html += '<span class="text-xs text-slate-500">' + escapeHtml(a.current_category || '未分类') + '</span>';
              html += '</td><td class="px-3 py-2">';
              if (a.category_path) {
                html += '<span class="status-badge status-badge--info">' + escapeHtml(a.category_path) + '</span>';
              } else {
                html += '<span class="text-xs text-amber-600">未匹配到分类，默认放弃</span>';
              }
              html += '</td><td class="px-3 py-2">';
              if (planStatus === 'preview') {
                html += '<div class="assign-action-group">';
                html += '<button class="assign-action-btn' + (selectedAction === 'apply' ? ' assign-action-btn--apply-active' : '') + '"' +
                  ' data-bookmark-id="' + a.bookmark_id + '" data-action="apply" data-category-path="' + escapeHtml(a.category_path || '') + '" data-status="' + escapeHtml(a.status || '') + '"' + (a.can_apply ? '' : ' disabled') + '>应用</button>';
                html += '<button class="assign-action-btn' + (selectedAction === 'discard' ? ' assign-action-btn--discard-active' : '') + '"' +
                  ' data-bookmark-id="' + a.bookmark_id + '" data-action="discard" data-category-path="' + escapeHtml(a.category_path || '') + '" data-status="' + escapeHtml(a.status || '') + '">放弃</button>';
                html += '</div>';
              } else {
                html += a.status === 'assigned' ? '<span class="status-badge status-badge--success">已分配</span>' : '<span class="status-badge status-badge--muted">待审核</span>';
              }
              html += '</td></tr>';
            });
          }
          tbody.innerHTML = html;
          bindAssignmentDecisionButtons();

          assignCurrentPage = data.page;
          assignTotalPages = data.totalPages;
          var pager = document.getElementById('assign-pager');
          if (pager) pager.classList.toggle('hidden', assignTotalPages <= 1);
          var cpEl = document.getElementById('assign-current-page');
          var tpEl = document.getElementById('assign-total-pages');
          if (cpEl) cpEl.textContent = assignCurrentPage;
          if (tpEl) tpEl.textContent = assignTotalPages;
          var prevBtn = document.getElementById('assign-prev-btn');
          var nextBtn = document.getElementById('assign-next-btn');
          if (prevBtn) prevBtn.disabled = assignCurrentPage <= 1;
          if (nextBtn) nextBtn.disabled = assignCurrentPage >= assignTotalPages;
        })
        .catch(function () { });
    }

    // assignments 分页按钮
    (function () {
      var prevBtn = document.getElementById('assign-prev-btn');
      var nextBtn = document.getElementById('assign-next-btn');
      if (prevBtn) prevBtn.addEventListener('click', function () { if (assignCurrentPage > 1) loadAssignments(assignCurrentPage - 1); });
      if (nextBtn) nextBtn.addEventListener('click', function () { if (assignCurrentPage < assignTotalPages) loadAssignments(assignCurrentPage + 1); });
      bindAssignmentDecisionButtons();
    })();

    function escapeHtml(str) {
      if (!str) return '';
      return String(str).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
    }

    // 取消任务
    var cancelBtn = document.getElementById('cancel-job-btn');
    if (cancelBtn) {
      cancelBtn.addEventListener('click', function () {
        cancelBtn.disabled = true;
        cancelBtn.textContent = '取消中...';

        var jobType = '<%= job.type %>';
        var cancelUrl = jobType === 'check' ? '/api/check/cancel' : '/api/jobs/' + jobId + '/cancel';

        fetch(cancelUrl, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
          body: JSON.stringify({ jobId: jobId })
        }).then(function (res) {
          return res.json();
        }).then(function (data) {
          if (data && data.success) {
            location.reload();
          } else {
            cancelBtn.disabled = false;
            cancelBtn.textContent = '取消任务';
            AppDialog.alert('取消失败：' + (data.error || '未知错误'));
          }
        }).catch(function () {
          cancelBtn.disabled = false;
          cancelBtn.textContent = '取消任务';
          AppDialog.alert('取消失败');
        });
      });
    }

    // Plan apply/discard handlers (11.2 & 11.3)
    (function () {
      var applyBtn = document.getElementById('apply-plan-btn');
      var applyAllBtn = document.getElementById('apply-all-plan-btn');
      var discardBtn = document.getElementById('discard-plan-btn');
      var resolveBackBtn = document.getElementById('resolve-back-btn');
      var resolveConfirmBtn = document.getElementById('resolve-confirm-btn');
      if (!applyBtn || !planId) return;

      var planConflicts = [];
      var planEmptyCategories = [];
      var firstApplyCount = 0;

      async function submitPlanApply(mode) {
        applyBtn.disabled = true;
        if (applyAllBtn) applyAllBtn.disabled = true;
        applyBtn.textContent = mode === 'all' ? '应用全部中...' : '应用中...';
        try {
          var payload = { decisions: mode === 'all' ? [] : collectPlanDecisionOverrides() };
          var res = await fetch('/api/ai/organize/' + planId + '/apply', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
          });
          var data = await res.json();
          if (!res.ok || !data.success) {
            await AppDialog.alert(data.error || '应用失败');
            applyBtn.disabled = false;
            applyBtn.textContent = '应用已选';
            if (applyAllBtn) applyAllBtn.disabled = false;
            return;
          }
          firstApplyCount = data.applied_count || 0;
          planConflicts = (data.conflicts || []).map(function (c) { return Object.assign({}, c, { action: 'skip' }); });
          planEmptyCategories = (data.empty_categories || []).map(function (e) { return Object.assign({}, e, { action: 'keep' }); });

          if (planConflicts.length > 0 || planEmptyCategories.length > 0) {
            showResolveUI();
          } else {
            setPlanUiStatus('applied');
            document.getElementById('plan-actions').classList.add('hidden');
            var appliedEl = document.getElementById('plan-applied');
            appliedEl.classList.remove('hidden');
            document.getElementById('plan-applied-msg').textContent = '共移动 ' + firstApplyCount + ' 个书签';
          }
        } catch (e) {
          await AppDialog.alert('应用失败');
          applyBtn.disabled = false;
          applyBtn.textContent = '应用已选';
          if (applyAllBtn) applyAllBtn.disabled = false;
        }
      }

      applyBtn.addEventListener('click', function () {
        submitPlanApply('selected');
      });

      if (applyAllBtn) applyAllBtn.addEventListener('click', function () {
        planSelectionOverrides = {};
        submitPlanApply('all');
      });

      discardBtn.addEventListener('click', async function () {
        var ok = await AppDialog.confirm('确定要放弃此整理计划吗？');
        if (!ok) return;
        discardBtn.disabled = true;
        try {
          await fetch('/api/ai/organize/' + planId + '/cancel', {
            method: 'POST', headers: { 'Content-Type': 'application/json' }
          });
          setPlanUiStatus('canceled');
          document.getElementById('plan-actions').classList.add('hidden');
          document.getElementById('plan-canceled').classList.remove('hidden');
        } catch (e) {
          await AppDialog.alert('取消失败');
          discardBtn.disabled = false;
        }
      });

      function formatConflictStatus(status) {
        if (status === 'preview') return '待应用';
        if (status === 'applied') return '已应用';
        return status || '未知';
      }

      function formatConflictReason(conflict) {
        if (conflict.reason === 'overlapping_plan') {
          var detail = '与更新的整理计划重叠';
          if (conflict.newer_plan_id) detail += '（计划 ' + String(conflict.newer_plan_id).slice(0, 8) + '，' + formatConflictStatus(conflict.newer_plan_status) + '）';
          return detail;
        }
        if (conflict.reason === 'bookmark_changed') {
          return conflict.current_category ? '书签当前分类已变化：' + conflict.current_category : '书签当前分类已变化';
        }
        if (conflict.reason === 'bookmark_updated') {
          return conflict.current_category ? '书签在预览后被编辑，当前分类：' + conflict.current_category : '书签在预览后被编辑';
        }
        return '检测到需要人工确认的冲突';
      }

      function showResolveUI() {
        document.getElementById('plan-actions').classList.add('hidden');
        var resolveEl = document.getElementById('plan-resolve');
        resolveEl.classList.remove('hidden');

        if (planConflicts.length > 0) {
          var cEl = document.getElementById('resolve-conflicts');
          cEl.classList.remove('hidden');
          var cList = document.getElementById('resolve-conflicts-list');
          cList.innerHTML = planConflicts.map(function (c, i) {
            return '<div class="px-3 py-2 flex items-center gap-2">' +
              '<div class="flex-1 min-w-0">' +
                '<div class="text-sm truncate">' + escapeHtml(c.title || c.url || '#' + c.bookmark_id) + '</div>' +
                '<div class="text-xs text-slate-500 mt-1">' + escapeHtml(formatConflictReason(c)) + '</div>' +
              '</div>' +
              '<select data-conflict-idx="' + i + '" class="conflict-select form-control job-inline-select">' +
              '<option value="skip"' + (c.action === 'skip' ? ' selected' : '') + '>跳过</option>' +
              '<option value="override"' + (c.action === 'override' ? ' selected' : '') + '>覆盖</option></select></div>';
          }).join('');
          cList.querySelectorAll('.conflict-select').forEach(function (sel) {
            sel.addEventListener('change', function () { planConflicts[parseInt(this.dataset.conflictIdx)].action = this.value; });
          });
        }

        if (planEmptyCategories.length > 0) {
          var eEl = document.getElementById('resolve-empty');
          eEl.classList.remove('hidden');
          var eList = document.getElementById('resolve-empty-list');
          eList.innerHTML = planEmptyCategories.map(function (e, i) {
            return '<div class="px-3 py-2 flex items-center gap-2">' +
              '<span class="text-sm flex-1">' + escapeHtml(e.name) + '</span>' +
              '<select data-empty-idx="' + i + '" class="empty-select form-control job-inline-select">' +
              '<option value="keep">保留</option><option value="delete">删除</option></select></div>';
          }).join('');
          eList.querySelectorAll('.empty-select').forEach(function (sel) {
            sel.addEventListener('change', function () { planEmptyCategories[parseInt(this.dataset.emptyIdx)].action = this.value; });
          });
        }
      }

      if (resolveBackBtn) resolveBackBtn.addEventListener('click', function () {
        document.getElementById('plan-resolve').classList.add('hidden');
        document.getElementById('plan-actions').classList.remove('hidden');
        applyBtn.disabled = false;
        applyBtn.textContent = '应用已选';
        if (applyAllBtn) applyAllBtn.disabled = false;
      });

      if (resolveConfirmBtn) resolveConfirmBtn.addEventListener('click', async function () {
        resolveConfirmBtn.disabled = true;
        resolveConfirmBtn.textContent = '应用中...';
        await doResolve();
      });

      async function doResolve() {
        var conflicts = planConflicts.map(function (c) { return { bookmark_id: c.bookmark_id, action: c.action }; });
        var emptyCats = planEmptyCategories.map(function (e) { return { id: e.id, action: e.action }; });
        try {
          var res = await fetch('/api/ai/organize/' + planId + '/apply/resolve', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ decisions: collectPlanDecisionOverrides(), conflicts: conflicts, empty_categories: emptyCats })
          });
          var data = await res.json();
          if (res.ok && data.success) {
            var total = (data.applied_count || 0) + firstApplyCount;
            setPlanUiStatus('applied');
            document.getElementById('plan-actions').classList.add('hidden');
            document.getElementById('plan-resolve').classList.add('hidden');
            var appliedEl = document.getElementById('plan-applied');
            appliedEl.classList.remove('hidden');
            document.getElementById('plan-applied-msg').textContent = '共移动 ' + total + ' 个书签';
          } else {
            await AppDialog.alert(data.error || '应用失败');
            if (resolveConfirmBtn) { resolveConfirmBtn.disabled = false; resolveConfirmBtn.textContent = '确认并应用'; }
          }
        } catch (e) {
          await AppDialog.alert('应用失败');
          if (resolveConfirmBtn) { resolveConfirmBtn.disabled = false; resolveConfirmBtn.textContent = '确认并应用'; }
        }
      }
    })();

    // 主题切换
    (function () {
      const btn = document.getElementById('theme-toggle');
      const updateIcon = () => {
        const theme = document.documentElement.getAttribute('data-theme');
        btn.textContent = theme === 'dark' ? '☀️' : '🌙';
      };
      updateIcon();
      btn.addEventListener('click', () => {
        const current = document.documentElement.getAttribute('data-theme');
        const next = current === 'dark' ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', next);
        localStorage.setItem('theme', next);
        updateIcon();
      });
    })();
  </script>
</body>

</html>

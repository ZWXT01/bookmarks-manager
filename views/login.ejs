<!doctype html>
<html lang="zh-CN">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>登录 - 书签管理器</title>
  <link rel="stylesheet" href="/public/tailwind.generated.css" />
  <link rel="stylesheet" href="/public/app.css" />
  <script>
    (function () {
      var theme = localStorage.getItem('theme');
      if (theme === 'dark') {
        document.documentElement.setAttribute('data-theme', 'dark');
      } else if (theme === 'light') {
        document.documentElement.setAttribute('data-theme', 'light');
      }
    })();
  </script>
</head>

<body class="auth-page">
  <main class="page-shell page-shell--narrow">
    <section class="auth-card">
      <div class="auth-eyebrow">🔐 安全登录</div>
      <h1 class="auth-title">登录到书签管理器</h1>
      <p class="auth-subtitle">继续访问你的自托管书签工作台，管理收藏、检查任务与快照归档。</p>

      <% if (error) { %>
        <div class="auth-error mt-6" role="alert">
          <%= error %>
        </div>
      <% } %>

      <form method="post" action="/login" class="section-stack mt-6">
        <label class="form-field">
          <span class="form-label">用户名</span>
          <input type="text" name="username" required autofocus autocomplete="username" class="form-control"
            placeholder="请输入用户名" />
        </label>

        <label class="form-field">
          <span class="form-label">密码</span>
          <input type="password" name="password" required autocomplete="current-password" class="form-control"
            placeholder="请输入密码" />
        </label>

        <label for="remember" class="remember-field">
          <input type="checkbox" name="remember" id="remember" />
          <span>记住我（7天内免登录）</span>
        </label>

        <button type="submit" class="btn-primary btn-lg w-full justify-center">登录</button>
      </form>
    </section>
  </main>
</body>

</html>

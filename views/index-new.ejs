          <div class="max-h-32 overflow-y-auto rounded border">
            <template x-if="manualBackups.length === 0">
              <div class="px-3 py-2 text-xs text-slate-400">暂无手动备份</div>
            </template>
            <template x-for="b in manualBackups" :key="b.name">
              <div class="flex items-center justify-between px-3 py-1.5 border-b last:border-b-0 hover:bg-slate-50">
                <div class="text-xs text-slate-700 truncate flex-1" x-text="b.name"></div>
                <div class="text-xs text-slate-500 mx-2" x-text="formatBytes(b.size)"></div>
                <div class="flex items-center gap-2">
                  <a class="text-blue-600 hover:underline text-xs" :href="'/backups/' + b.name">下载</a>
                  <button @click="deleteBackup(b.name)" class="text-rose-600 hover:underline text-xs">删除</button>
                </div>
              </div>
            </template>
          </div>
        </div>

        <!-- 自动备份区域 -->
        <div class="mt-3">
          <div class="text-sm font-medium text-slate-700 mb-1">自动备份 <span class="text-xs text-slate-400 font-normal" x-text="'(' + autoBackups.length + '个)'"></span></div>
          <div class="max-h-32 overflow-y-auto rounded border">
            <template x-if="autoBackups.length === 0">
              <div class="px-3 py-2 text-xs text-slate-400">暂无自动备份</div>
            </template>
            <template x-for="b in autoBackups" :key="b.name">
              <div class="flex items-center justify-between px-3 py-1.5 border-b last:border-b-0 hover:bg-slate-50">
                <div class="text-xs text-slate-700 truncate flex-1" x-text="b.name"></div>
                <div class="text-xs text-slate-500 mx-2" x-text="formatBytes(b.size)"></div>
                <div class="flex items-center gap-2">
                  <a class="text-blue-600 hover:underline text-xs" :href="'/backups/' + b.name">下载</a>
                  <button @click="deleteBackup(b.name)" class="text-rose-600 hover:underline text-xs">删除</button>
                </div>
              </div>
            </template>
          </div>
        </div>
      </div>
    </div>

    <script src="/public/app-new.js"></script>
  </body>
</html>

<!DOCTYPE html>
<html lang="zh-CN">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>书签管理器</title>
    <link rel="stylesheet" href="/public/tailwind.generated.css">
    <link rel="stylesheet" href="/public/app.css">
    <link rel="icon" href="/public/favicon.svg" type="image/svg+xml">
    <!-- OverlayScrollbars for consistent cross-browser scrollbar behavior -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/overlayscrollbars@2.4.6/styles/overlayscrollbars.min.css"
          crossorigin="anonymous">
    <script src="https://cdn.jsdelivr.net/npm/overlayscrollbars@2.4.6/browser/overlayscrollbars.browser.es6.min.js"
            crossorigin="anonymous"></script>
    <!-- SortableJS with SRI -->
    <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.2/Sortable.min.js"
            crossorigin="anonymous"></script>
    <script src="/public/dialog.js"></script>
    <script src="/public/app.js"></script>
    <style>
        [x-cloak] {
            display: none !important;
        }
    </style>
    <script>
        (function () {
            var theme = localStorage.getItem('theme');
            if (theme === 'dark') {
                document.documentElement.setAttribute('data-theme', 'dark');
            } else if (theme === 'light') {
                document.documentElement.setAttribute('data-theme', 'light');
            }
        })();
    </script>
</head>

<body class="bg-slate-50 text-slate-900">
    <div x-data="bookmarkApp()" x-init="init()">
        <!-- Header -->
        <div class="glass-header border-b sticky top-0 z-40">
            <div class="mx-auto max-w-screen-2xl px-4 py-3">
                <div class="flex items-center justify-between">
                    <div class="flex items-center gap-3">
                        <!-- Hamburger Button (Mobile Only) -->
                        <button @click="showMobileSidebar = !showMobileSidebar" 
                                class="lg:hidden p-2 rounded-lg hover:bg-slate-100 text-slate-600 transition-colors">
                            <span class="text-xl" x-text="showMobileSidebar ? '✕' : '☰'"></span>
                        </button>
                        <div>
                            <h1
                                class="text-xl font-bold bg-gradient-to-r from-blue-600 to-purple-600 bg-clip-text text-transparent">
                                📚 书签管理器</h1>
                            <p class="text-xs text-slate-500 hidden sm:block">轻量 · SQLite · 支持导入/导出与有效性检查</p>
                        </div>
                    </div>
                    <div class="flex items-center gap-2">
                        <!-- Current Job Progress (Compact on Mobile) -->
                        <template
                            x-if="currentJob && (currentJob.status === 'running' || currentJob.status === 'queued')">
                            <div
                                class="flex items-center gap-2 text-xs bg-gradient-to-r from-blue-50 to-purple-50 rounded-lg px-2 py-1.5 border border-blue-200 shadow-sm animate-fade-in cursor-pointer"
                                @click="window.location.href='/jobs'">
                                <span class="animate-pulse hidden md:inline"
                                    x-text="currentJob.type === 'ai_organize' ? '🤖 AI整理' : currentJob.type === 'check' ? '🔍 检查' : currentJob.type === 'import' ? '📥 导入' : '任务'"></span>
                                <span class="md:hidden" x-text="currentJob.type === 'ai_organize' ? '🤖' : currentJob.type === 'check' ? '🔍' : currentJob.type === 'import' ? '📥' : '⚙️'"></span>
                                <span x-text="currentJob.processed + '/' + currentJob.total" class="font-medium"></span>
                                <div class="w-12 sm:w-20 h-1.5 progress-bar">
                                    <div class="progress-bar-fill"
                                        :style="'width:' + (currentJob.total > 0 ? Math.floor(currentJob.processed / currentJob.total * 100) : 0) + '%'">
                                    </div>
                                </div>
                                <button @click.stop="cancelCurrentJob()" aria-label="取消任务"
                                    class="text-rose-500 hover:text-rose-700">✕</button>
                            </div>
                        </template>
                        <button @click="openBackupModal()" class="btn-secondary btn-sm hidden md:inline-flex items-center gap-1" title="备份与还原">💾 <span>备份还原</span></button>
                        <a href="/snapshots" class="btn-secondary btn-sm hidden md:inline-flex items-center gap-1" title="快照管理">📸 <span>快照管理</span></a>
                        <a href="/jobs" class="btn-secondary btn-sm hidden md:inline-flex items-center gap-1" title="任务列表">📋 <span>任务列表</span></a>
                        <button @click="toggleTheme()" class="btn-secondary btn-sm hidden md:inline-flex items-center gap-1" aria-label="切换主题">
                            <span x-text="theme === 'dark' ? '☀️' : '🌙'"></span>
                            <span x-text="theme === 'dark' ? '浅色' : '深色'"></span>
                        </button>
                        <div class="flex md:hidden">
                            <button @click="toggleTheme()" class="p-2 text-lg" x-text="theme === 'dark' ? '☀️' : '🌙'"></button>
                        </div>
                        <a href="/settings" class="btn-secondary btn-sm hidden md:inline-flex items-center gap-1">⚙️ <span>设置</span></a>
                        <form action="/logout" method="POST" class="inline">
                            <button type="submit" class="btn-danger btn-sm hidden md:inline-flex items-center gap-1">🚪 <span>退出</span></button>
                            <button type="submit" class="btn-danger btn-sm md:hidden p-2">🚪</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        <div class="mx-auto max-w-screen-2xl px-4 py-4 flex flex-col lg:flex-row gap-4 relative min-w-0" style="height: calc(100svh - 70px);">
            <!-- Mobile Sidebar Overlay -->
            <div x-show="showMobileSidebar" 
                 x-transition:enter="transition ease-out duration-300"
                 x-transition:enter-start="opacity-0"
                 x-transition:enter-end="opacity-100"
                 x-transition:leave="transition ease-in duration-200"
                 x-transition:leave-start="opacity-100"
                 x-transition:leave-end="opacity-0"
                 @click="showMobileSidebar = false"
                 class="lg:hidden fixed inset-0 bg-slate-900/50 backdrop-blur-sm z-30"></div>

            <div class="flex flex-col lg:flex-row gap-4 flex-1 min-h-0 min-w-0">
                <!-- Sidebar -->
                <aside :class="showMobileSidebar ? 'translate-x-0' : '-translate-x-full lg:translate-x-0'"
                       class="fixed lg:static inset-y-0 left-0 w-72 bg-slate-50 lg:bg-transparent z-40 lg:z-auto transition-transform duration-300 ease-in-out
                              flex flex-col gap-4 p-4 lg:p-0 border-r lg:border-r-0 lg:max-h-[calc(100vh-100px)] overflow-y-auto custom-scrollbar">
                    
                    <!-- UI Redesign: Sidebar contains only Tools, Templates and Quick Actions now -->
                    <!-- Import Section -->
                    <div class="card p-4 flex-shrink-0 animate-fade-in">
                        <h2 class="text-sm font-bold text-slate-700 mb-3 flex items-center gap-2">
                            <span
                                class="w-6 h-6 rounded-md bg-gradient-to-br from-blue-500 to-purple-500 flex items-center justify-center text-white text-xs">📥</span>
                            导入书签
                        </h2>
                        <form id="import-form" @submit.prevent="startImport($el)">
                            <input type="file" name="file" accept=".html,.htm,.json,.txt" required
                                class="w-full text-xs mb-3 file:mr-2 file:py-1.5 file:px-3 file:rounded-md file:border-0 file:text-xs file:font-medium file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100">
                            <label class="flex items-center gap-2 text-xs text-slate-600 mb-2">
                                <input type="checkbox" x-model="importOverrideCategory">
                                忽略原有分类，统一导入到：
                            </label>
                            <input type="hidden" name="overrideCategory" :value="importOverrideCategory ? '1' : ''">
                            <div class="mb-3" x-show="importOverrideCategory">
                                <select name="defaultCategoryId" class="w-full rounded-lg border px-3 py-2 text-xs">
                                    <option value="">未分类</option>
                                    <template x-for="cat in categories" :key="cat.id">
                                        <option :value="cat.id" x-text="cat.name"></option>
                                    </template>
                                </select>
                            </div>
                            <label class="flex items-center gap-2 text-xs text-slate-600 mb-3">
                                <input type="checkbox" name="skipDuplicates" value="1" checked>
                                跳过重复书签
                            </label>
                            <button type="submit" class="btn-primary w-full">开始导入</button>
                        </form>
                    </div>

                    <!-- Tools -->
                    <div class="card p-4 flex-shrink-0">
                        <h2 class="text-sm font-bold text-slate-700 mb-3 flex items-center gap-2">
                            <span
                                class="w-6 h-6 rounded-md bg-gradient-to-br from-emerald-500 to-teal-500 flex items-center justify-center text-white text-xs">🛠️</span>
                            工具
                        </h2>
                        <div class="space-y-2">
                            <button @click="openCheckModal()" class="btn-secondary w-full text-left justify-start">🔍
                                批量检查</button>
                            <button @click="openAIOrganizeModal()"
                                class="btn-secondary w-full text-left justify-start">🤖 AI 整理</button>
                        </div>
                    </div>
                    <!-- Template Management -->
                    <div class="card p-4 flex-shrink-0">
                        <h2 class="text-sm font-bold text-slate-700 mb-2 flex items-center gap-2">
                            <span
                                class="w-6 h-6 rounded-md bg-gradient-to-br from-violet-500 to-purple-500 flex items-center justify-center text-white text-xs">🗂️</span>
                            分类模板
                        </h2>
                        <template x-if="activeTemplate">
                            <div class="flex items-center justify-between gap-2">
                                <span class="text-sm text-slate-600 truncate"
                                      data-testid="active-template-name"
                                      x-text="activeTemplate.name"></span>
                                <button @click="showTemplateSelectModal = true"
                                    data-testid="open-template-select"
                                    class="text-xs text-blue-500 hover:text-blue-700 whitespace-nowrap">切换模板</button>
                            </div>
                        </template>
                        <template x-if="!activeTemplate">
                            <div class="flex items-center justify-between gap-2">
                                <span class="text-xs text-slate-400">请先选择分类模板</span>
                                <button @click="showTemplateSelectModal = true"
                                    data-testid="open-template-select"
                                    class="text-xs text-blue-500 hover:text-blue-700 whitespace-nowrap">选择模板</button>
                            </div>
                        </template>
                        <div class="flex gap-1 mt-2">
                            <button @click="showToast('该功能正在开发中，敬请期待', 'info')"
                                class="flex-1 text-xs px-2 py-1 rounded border border-dashed border-slate-300 text-slate-400 hover:text-slate-600 hover:border-slate-400">AI 设计模板 <span class="text-[10px] bg-amber-100 text-amber-600 px-1 rounded">Beta</span></button>
                            <button @click="showToast('该功能正在开发中，敬请期待', 'info')"
                                class="flex-1 text-xs px-2 py-1 rounded border border-dashed border-slate-300 text-slate-400 hover:text-slate-600 hover:border-slate-400">AI 改造模板 <span class="text-[10px] bg-amber-100 text-amber-600 px-1 rounded">Beta</span></button>
                        </div>
                    </div>
                    <!-- Quick Actions (Phase 2) -->
                    <div class="card p-4 flex-shrink-0 animate-fade-in">
                        <h2 class="text-sm font-bold text-slate-700 mb-3 flex items-center gap-2">
                            <span class="w-6 h-6 rounded-md bg-gradient-to-br from-orange-400 to-amber-500 flex items-center justify-center text-white text-xs">⚡</span>
                            快捷操作
                        </h2>
                        <div class="grid grid-cols-2 gap-2">
                            <button @click="openAddBookmarkModal()" class="flex flex-col items-center justify-center p-3 rounded-xl border border-slate-100 hover:bg-green-50 hover:border-green-200 transition-all group">
                                <span class="text-xl mb-1 group-hover:scale-110 transition-transform">➕</span>
                                <span class="text-[10px] text-slate-500 font-medium">添加书签</span>
                            </button>
                            <button @click="openCategoryManager()" class="flex flex-col items-center justify-center p-3 rounded-xl border border-slate-100 hover:bg-blue-50 hover:border-blue-200 transition-all group">
                                <span class="text-xl mb-1 group-hover:scale-110 transition-transform">📁</span>
                                <span class="text-[10px] text-slate-500 font-medium">管理分类</span>
                            </button>
                            <button @click="openCreateCategoryModal(null)" class="flex flex-col items-center justify-center p-3 rounded-xl border border-slate-100 hover:bg-emerald-50 hover:border-emerald-200 transition-all group">
                                <span class="text-xl mb-1 group-hover:scale-110 transition-transform">📂</span>
                                <span class="text-[10px] text-slate-500 font-medium">添加分类</span>
                            </button>
                            <button @click="openCheckModal()" class="flex flex-col items-center justify-center p-3 rounded-xl border border-slate-100 hover:bg-purple-50 hover:border-purple-200 transition-all group">
                                <span class="text-xl mb-1 group-hover:scale-110 transition-transform">🔍</span>
                                <span class="text-[10px] text-slate-500 font-medium">批量检查</span>
                            </button>
                            <button @click="openExportModal()" class="flex flex-col items-center justify-center p-3 rounded-xl border border-slate-100 hover:bg-amber-50 hover:border-amber-200 transition-all group">
                                <span class="text-xl mb-1 group-hover:scale-110 transition-transform">📤</span>
                                <span class="text-[10px] text-slate-500 font-medium">导出书签</span>
                            </button>
                        </div>
                    </div>

                </aside>

                <!-- Main Content -->
                <main class="flex-1 min-w-0 flex flex-col overflow-y-auto overflow-x-hidden">
                    <!-- UI Redesign: Category Navigation moved from Sidebar to Top of Main Content -->
                    <!-- Category Tabs with Dropdown Container -->
                    <div class="relative z-30 mb-4">
                    <div class="category-tabs-container rounded-lg shadow-sm border">
                        <!-- Left Scroll Button -->
                        <button @click="scrollCategoryTabs('left')"
                                class="category-tabs-scroll-btn mr-2"
                                aria-label="向左滚动"
                                title="向左滚动">
                            ◀
                        </button>

                        <div class="category-tabs"
                             :class="{ 'is-dragging': _categoryTabsDragging }"
                             role="tablist"
                             aria-label="分类导航"
                             x-ref="categoryTabsContainer"
                             @pointerdown="startCategoryTabsDrag($event)"
                             @pointermove="handleCategoryTabsDrag($event)"
                             @pointerup="stopCategoryTabsDrag($event)"
                             @pointercancel="stopCategoryTabsDrag($event)"
                             @lostpointercapture="stopCategoryTabsDrag($event)"
                             @click.capture="handleCategoryTabsClickCapture($event)"
                             @wheel="handleCategoryTabsWheel($event)">
                            <!-- All -->
                            <button @click="loadCategory(null)"
                                    @focus="closeCategoryDropdown()"
                                    type="button"
                                    role="tab"
                                    data-testid="category-nav-all-tab"
                                    :aria-selected="currentCategory === null"
                                    aria-label="全部书签"
                                    class="category-tab"
                                    :class="currentCategory === null ? 'active' : ''">
                                <span class="category-tab-icon">📚</span>
                                <span>全部</span>
                                <span class="text-[10px] opacity-70" x-text="totalCount"></span>
                            </button>

                            <!-- Uncategorized -->
                            <button @click="loadCategory('uncategorized')"
                                    @focus="closeCategoryDropdown()"
                                    type="button"
                                    role="tab"
                                    :aria-selected="currentCategory === 'uncategorized'"
                                    aria-label="未分类书签"
                                    class="category-tab"
                                    :class="currentCategory === 'uncategorized' ? 'active' : ''">
                                <span class="category-tab-icon">📂</span>
                                <span>未分类</span>
                                <span class="text-[10px] opacity-70" x-text="uncategorizedCount"></span>
                            </button>

                            <!-- Parent Categories -->
                            <template x-for="cat in categoryTree" :key="cat.id">
                                <div class="relative group flex items-center gap-1"
                                     role="presentation"
                                     @mouseenter="cat.children && cat.children.length > 0 ? handleCategoryHover(cat.id) : null"
                                     @mouseleave="cat.children && cat.children.length > 0 ? handleCategoryLeave() : null">
                                    <button @click="handleCategoryClick(cat)"
                                            @focus="if (cat.children && cat.children.length > 0) { if (skipNextFocusOpen) { skipNextFocusOpen = false; } else { openCategoryDropdown(cat.id); } } else { closeCategoryDropdown(); }"
                                            @blur="cat.children && cat.children.length > 0 ? handleCategoryBlur($event) : null"
                                            @keydown.arrow-down.prevent="cat.children && cat.children.length > 0 ? focusFirstSubcategory(cat.id) : null"
                                            @keydown.escape.prevent="closeCategoryDropdown(true)"
                                            type="button"
                                            :id="'category-tab-' + cat.id"
                                            role="tab"
                                            :aria-selected="currentCategory == cat.id"
                                            :aria-haspopup="cat.children && cat.children.length > 0 ? 'true' : null"
                                            :aria-expanded="cat.children && cat.children.length > 0 ? (categoryDropdownVisible && activeParentCategory == cat.id) : null"
                                            :aria-controls="cat.children && cat.children.length > 0 ? 'subcategory-panel-' + cat.id : null"
                                            :aria-label="cat.name + '分类'"
                                            data-testid="category-nav-tab"
                                            :data-category-id="cat.id"
                                            class="category-tab"
                                            :class="currentCategory == cat.id ? 'active' : ''">
                                        <span class="category-tab-icon" x-text="cat.icon || '📁'" :style="cat.color ? 'color:' + cat.color : ''"></span>
                                        <span x-text="cat.name"></span>
                                    </button>
                                </div>
                            </template>
                        </div>

                        <!-- Right Scroll Button -->
                        <button @click="scrollCategoryTabs('right')"
                                class="category-tabs-scroll-btn ml-2"
                                aria-label="向右滚动"
                                title="向右滚动">
                            ▶
                        </button>

                        <!-- Manage Button -->
                        <button @click="openCategoryManager()"
                                @focus="closeCategoryDropdown()"
                                class="ml-2 p-2 text-slate-400 hover:text-blue-500 transition-colors flex-shrink-0"
                                data-testid="open-category-manager"
                                aria-label="管理分类"
                                title="管理分类">
                            <span class="text-lg" aria-hidden="true">⚙️</span>
                        </button>
                    </div>

                    <!-- Subcategory Dropdown Panel (Phase 2) - Absolute positioned overlay -->
                    <div x-show="categoryDropdownVisible"
                         x-ref="subcategoryPanel"
                         data-testid="subcategory-panel"
                         :id="'subcategory-panel-' + activeParentCategory"
                         role="region"
                         :aria-label="activeParentCategory ? (categoryTree.find(c => c.id == activeParentCategory)?.name + ' 的子分类') : '子分类'"
                         x-transition:enter="transition ease-out duration-200"
                         x-transition:enter-start="opacity-0 translate-y-1"
                         x-transition:enter-end="opacity-100 translate-y-0"
                         x-transition:leave="transition ease-in duration-150"
                         x-transition:leave-start="opacity-100 translate-y-0"
                         x-transition:leave-end="opacity-0 translate-y-1"
                         @click.away="closeCategoryDropdown()"
                         @keydown.escape.prevent="closeCategoryDropdown(true)"
                         @mouseenter="handleDropdownPanelEnter()"
                         @mouseleave="handleDropdownPanelLeave()"
                         @focusin="handleDropdownPanelEnter()"
                         @focusout="handleDropdownPanelFocusOut($event)"
                         class="absolute top-full left-0 right-0 z-50 category-dropdown-panel-external rounded-b-lg border shadow-lg"
                         style="max-height: 70vh; overflow-y: auto;">
                        <template x-if="activeParentCategory">
                            <div class="col-span-full grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-2">
                                <template x-for="child in (categoryTree.find(c => c.id == activeParentCategory)?.children || [])" :key="child.id">
                                    <button @click="loadCategory(child.id); closeCategoryDropdown()"
                                            type="button"
                                            :aria-label="(child.displayName || child.name) + '子分类'"
                                            data-testid="subcategory-nav-item"
                                            :data-category-id="child.id"
                                            class="subcategory-item focus:outline-none focus:ring-2 focus:ring-blue-500"
                                            :class="currentCategory == child.id ? 'active' : ''">
                                        <span class="subcategory-item-icon" x-text="child.icon || '📄'" :style="child.color ? 'color:' + child.color : ''"></span>
                                        <span class="subcategory-item-text" x-text="child.displayName || child.name"></span>
                                        <span class="subcategory-item-count text-[10px] opacity-50" x-text="child.count"></span>
                                    </button>
                                </template>
                            </div>
                        </template>
                    </div>
                    </div>

                    <!-- Search & Filters -->
                    <div class="rounded-lg border bg-white p-3 shadow-sm mb-4">
                        <div class="flex flex-wrap items-center gap-2">
                            <input type="text" x-model="searchKeyword" @input="debouncedSearch()"
                                @keyup.enter="searchBookmarks()" placeholder="搜索书签..."
                                class="flex-1 min-w-[200px] rounded border px-3 py-2 text-sm">
                            <button @click="searchBookmarks()"
                                class="rounded bg-slate-900 text-white px-4 py-2 text-sm hover:bg-slate-800 flex-shrink-0">搜索</button>
                            <button @click="showAdvancedSearch = !showAdvancedSearch"
                                class="rounded border px-3 py-2 text-sm hover:bg-slate-50 flex-shrink-0">
                                <span x-text="showAdvancedSearch ? '收起 ▲' : '筛选 ▼'"></span>
                            </button>
                            <button @click="toggleViewMode()" class="rounded border px-3 py-2 text-sm hover:bg-slate-50 flex-shrink-0"
                                x-text="viewMode === 'table' ? '🗂️ 卡片' : '📋 表格'"></button>
                        </div>

                        <!-- Advanced Search -->
                        <div x-show="showAdvancedSearch"
                            class="mt-3 pt-3 border-t grid grid-cols-2 md:grid-cols-4 gap-3">
                            <div>
                                <label class="text-xs text-slate-600">状态</label>
                                <select x-model="advancedSearch.status"
                                    class="w-full rounded border px-2 py-1.5 text-sm mt-1">
                                    <option value="all">全部</option>
                                    <option value="not_checked">未检查</option>
                                    <option value="ok">正常</option>
                                    <option value="fail">失败</option>
                                </select>
                            </div>
                            <div>
                                <label class="text-xs text-slate-600">排序</label>
                                <select x-model="advancedSearch.sort"
                                    class="w-full rounded border px-2 py-1.5 text-sm mt-1">
                                    <option value="id">ID</option>
                                    <option value="title">标题</option>
                                    <option value="created_at">创建时间</option>
                                    <option value="check_status">检查状态</option>
                                </select>
                            </div>
                            <div>
                                <label class="text-xs text-slate-600">排序方向</label>
                                <select x-model="advancedSearch.order"
                                    class="w-full rounded border px-2 py-1.5 text-sm mt-1">
                                    <option value="desc">降序</option>
                                    <option value="asc">升序</option>
                                </select>
                            </div>
                            <div class="flex items-end gap-2">
                                <button @click="applyAdvancedSearch()"
                                    class="rounded bg-slate-900 text-white px-4 py-1.5 text-sm hover:bg-slate-800">应用</button>
                                <button @click="resetAdvancedSearch()"
                                    class="rounded border px-4 py-1.5 text-sm hover:bg-slate-50">重置</button>
                            </div>
                        </div>
                    </div>

                    <!-- Batch Actions & Pagination -->
                    <div class="flex flex-wrap items-center justify-between gap-2 mb-4">
                        <div class="flex items-center gap-2 flex-wrap">
                            <span class="text-sm text-slate-500">
                                共 <span x-text="total"></span> 条，已选 <span x-text="selectedBookmarks.length"></span> 条
                            </span>
                            <template x-if="selectedBookmarks.length > 0">
                                <div class="flex gap-1 flex-wrap">

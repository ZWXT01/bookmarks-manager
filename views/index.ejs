<!DOCTYPE html>
<html lang="zh-CN">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>书签管理器</title>
    <link rel="stylesheet" href="/public/tailwind.generated.css">
    <link rel="stylesheet" href="/public/app.css">
    <link rel="icon" href="/public/favicon.svg" type="image/svg+xml">
    <!-- OverlayScrollbars for consistent cross-browser scrollbar behavior -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/overlayscrollbars@2.4.6/styles/overlayscrollbars.min.css"
          crossorigin="anonymous">
    <script src="https://cdn.jsdelivr.net/npm/overlayscrollbars@2.4.6/browser/overlayscrollbars.browser.es6.min.js"
            crossorigin="anonymous"></script>
    <!-- SortableJS with SRI -->
    <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.2/Sortable.min.js"
            crossorigin="anonymous"></script>
    <script src="/public/dialog.js"></script>
    <script src="/public/app.js"></script>
    <style>
        [x-cloak] {
            display: none !important;
        }
    </style>
    <script>
        (function () {
            var theme = localStorage.getItem('theme');
            if (theme === 'dark') {
                document.documentElement.setAttribute('data-theme', 'dark');
            } else if (theme === 'light') {
                document.documentElement.setAttribute('data-theme', 'light');
            }
        })();
    </script>
</head>

<body class="app-shell home-page bg-slate-50 text-slate-900">
    <div x-data="bookmarkApp()" x-init="init()" class="home-app-shell">
        <%- include('partials/home-header') %>

        <div class="page-shell home-shell" data-testid="home-page">
            <div class="home-shell__frame">
                <div x-show="showMobileSidebar"
                     x-transition:enter="transition ease-out duration-300"
                     x-transition:enter-start="opacity-0"
                     x-transition:enter-end="opacity-100"
                     x-transition:leave="transition ease-in duration-200"
                     x-transition:leave-start="opacity-100"
                     x-transition:leave-end="opacity-0"
                     @click="closeMobileSidebar()"
                     class="home-drawer-backdrop lg:hidden fixed inset-0 z-30"></div>

                <%- include('partials/home-sidebar') %>

                <main class="home-main">
                    <section class="home-overview panel-card panel-card--compact" data-testid="home-overview-card">
                        <div class="home-overview__meta">
                            <div class="page-kicker">Workspace overview</div>
                            <div class="home-overview__title-row">
                                <div class="page-heading home-overview__heading">当前工作区：<span x-text="currentCategoryName"></span></div>
                                <template x-if="searchKeyword.trim()">
                                    <span class="status-badge status-badge--warning" x-text="'搜索：' + searchKeyword.trim()"></span>
                                </template>
                            </div>
                            <div class="page-subheading home-overview__description" x-text="searchKeyword.trim() ? '当前结果已按关键词过滤，可继续结合分类导航、高级筛选和批量操作缩小范围。' : '先用分类导航锁定范围，再用搜索、视图切换和快捷操作完成整理。'"></div>
                            <div class="home-overview__chips">
                                <span class="status-badge status-badge--info" x-text="viewMode === 'table' ? '表格视图' : '卡片视图'"></span>
                                <span class="status-badge status-badge--muted" x-text="selectedBookmarks.length > 0 ? '已选 ' + selectedBookmarks.length + ' 条' : '当前未选择书签'"></span>
                                <span class="status-badge status-badge--muted" x-show="activeTemplate" x-text="activeTemplate ? '模板：' + activeTemplate.name : ''"></span>
                            </div>
                        </div>

                        <div class="home-overview__stats">
                            <article class="home-overview__stat">
                                <div class="home-overview__stat-label">当前结果</div>
                                <div class="home-overview__stat-value" x-text="total"></div>
                                <div class="home-overview__stat-meta">与当前分类、搜索和筛选条件保持同步。</div>
                            </article>
                            <article class="home-overview__stat">
                                <div class="home-overview__stat-label">一级分类</div>
                                <div class="home-overview__stat-value" x-text="categoryTree.length"></div>
                                <div class="home-overview__stat-meta">通过横向 tabs 切换；带子分类时可展开二级面板。</div>
                            </article>
                            <article class="home-overview__stat">
                                <div class="home-overview__stat-label">未分类</div>
                                <div class="home-overview__stat-value" x-text="uncategorizedCount"></div>
                                <div class="home-overview__stat-meta">可直接进入“未分类”视图做补录和清理。</div>
                            </article>
                            <article class="home-overview__stat">
                                <div class="home-overview__stat-label">已选书签</div>
                                <div class="home-overview__stat-value" x-text="selectedBookmarks.length"></div>
                                <div class="home-overview__stat-meta">批量移动、检查、AI 分类和删除仍沿用原合同。</div>
                            </article>
                        </div>

                        <div class="home-overview__actions">
                            <button @click="openAddBookmarkModal()" data-testid="home-overview-add-bookmark" class="btn-primary btn-sm" type="button">➕ 添加书签</button>
                            <button @click="showTemplateSelectModal = true" class="btn-secondary btn-sm" type="button">🗂️ 选择模板</button>
                            <button @click="openCategoryManager()" class="btn-secondary btn-sm" type="button">⚙️ 管理分类</button>
                        </div>
                    </section>

                    <%- include('partials/home-category-nav') %>

                    <!-- Search & Filters -->
                    <div :class="openDropdownId ? 'pointer-events-none' : ''" class="relative z-0 rounded-lg border bg-white p-3 shadow-sm mb-4">
                        <div class="flex flex-wrap items-center gap-2">
                            <input type="text" x-model="searchKeyword" @input="debouncedSearch()"
                                @keyup.enter="searchBookmarks()" placeholder="搜索书签..."
                                data-testid="bookmark-search-input"
                                class="flex-1 min-w-[200px] rounded border px-3 py-2 text-sm">
                            <button @click="searchBookmarks()"
                                data-testid="bookmark-search-submit"
                                class="rounded bg-slate-900 text-white px-4 py-2 text-sm hover:bg-slate-800 flex-shrink-0">搜索</button>
                            <button @click="showAdvancedSearch = !showAdvancedSearch"
                                data-testid="advanced-search-toggle"
                                class="rounded border px-3 py-2 text-sm hover:bg-slate-50 flex-shrink-0">
                                <span x-text="showAdvancedSearch ? '收起 ▲' : '筛选 ▼'"></span>
                            </button>
                            <button @click="toggleViewMode()" data-testid="bookmark-view-toggle" class="rounded border px-3 py-2 text-sm hover:bg-slate-50 flex-shrink-0"
                                x-text="viewMode === 'table' ? '🗂️ 卡片' : '📋 表格'"></button>
                        </div>

                        <!-- Advanced Search -->
                        <div x-show="showAdvancedSearch"
                            data-testid="advanced-search-panel"
                            class="mt-3 pt-3 border-t grid grid-cols-2 md:grid-cols-4 gap-3">
                            <div>
                                <label class="text-xs text-slate-600">状态</label>
                                <select x-model="advancedSearch.status"
                                    data-testid="advanced-search-status"
                                    class="w-full rounded border px-2 py-1.5 text-sm mt-1">
                                    <option value="all">全部</option>
                                    <option value="not_checked">未检查</option>
                                    <option value="ok">正常</option>
                                    <option value="fail">失败</option>
                                </select>
                            </div>
                            <div>
                                <label class="text-xs text-slate-600">排序</label>
                                <select x-model="advancedSearch.sort"
                                    data-testid="advanced-search-sort"
                                    class="w-full rounded border px-2 py-1.5 text-sm mt-1">
                                    <option value="id">ID</option>
                                    <option value="title">标题</option>
                                    <option value="created_at">创建时间</option>
                                    <option value="check_status">检查状态</option>
                                </select>
                            </div>
                            <div>
                                <label class="text-xs text-slate-600">排序方向</label>
                                <select x-model="advancedSearch.order"
                                    data-testid="advanced-search-order"
                                    class="w-full rounded border px-2 py-1.5 text-sm mt-1">
                                    <option value="desc">降序</option>
                                    <option value="asc">升序</option>
                                </select>
                            </div>
                            <div class="flex items-end gap-2">
                                <button @click="applyAdvancedSearch()"
                                    data-testid="advanced-search-apply"
                                    class="rounded bg-slate-900 text-white px-4 py-1.5 text-sm hover:bg-slate-800">应用</button>
                                <button @click="resetAdvancedSearch()"
                                    data-testid="advanced-search-reset"
                                    class="rounded border px-4 py-1.5 text-sm hover:bg-slate-50">重置</button>
                            </div>
                        </div>
                    </div>

                    <!-- Batch Actions & Pagination -->
                    <div class="flex flex-wrap items-center justify-between gap-2 mb-4">
                        <div class="flex items-center gap-2 flex-wrap">
                            <span class="text-sm text-slate-500">
                                共 <span x-text="total"></span> 条，已选 <span x-text="selectedBookmarks.length"></span> 条
                            </span>
                            <template x-if="selectedBookmarks.length > 0">
                                <div class="flex gap-1 flex-wrap">
                                    <button @click="openMoveSelectedModal()"
                                        data-testid="move-selected-bookmarks-button"
                                        class="rounded border px-2 py-1 text-xs hover:bg-slate-50 flex-shrink-0">📁
                                        移动</button>
                                    <button @click="openCheckModalForSelected()"
                                        class="rounded border px-2 py-1 text-xs hover:bg-slate-50 flex-shrink-0">🔍 检查</button>
                                    <button @click="promptClassifyBatch([...selectedBookmarks])"
                                        class="rounded border px-2 py-1 text-xs hover:bg-slate-50 flex-shrink-0">🤖 AI 分类</button>
                                    <button @click="batchDelete()"
                                        class="rounded border border-rose-300 px-2 py-1 text-xs text-rose-600 hover:bg-rose-50 flex-shrink-0">🗑️
                                        删除选中</button>
                                </div>
                            </template>
                            <!-- More dropdown -->
                            <div class="relative ml-2 flex-shrink-0" x-data="{ showMoreMenu: false }">
                                <button @click="showMoreMenu = !showMoreMenu"
                                    class="rounded border px-2 py-1 text-xs hover:bg-slate-50 flex-shrink-0">更多 ▼</button>
                                <div x-show="showMoreMenu" @click.away="showMoreMenu = false"
                                    class="absolute left-0 top-full mt-1 z-50 w-28 rounded-lg border bg-white shadow-lg py-1 text-left">
                                    <button @click="deleteCurrentPage(); showMoreMenu = false"
                                        class="block w-full px-3 py-1.5 text-xs text-rose-600 hover:bg-rose-50 text-left">删除本页</button>
                                    <button @click="deleteAllBookmarks(); showMoreMenu = false"
                                        class="block w-full px-3 py-1.5 text-xs text-rose-600 hover:bg-rose-50 text-left">删除全部</button>
                                </div>
                            </div>
                        </div>
                        <div class="flex items-center gap-2 flex-shrink-0">
                            <span class="text-xs text-slate-500 flex-shrink-0">第 <span x-text="page"></span>/<span
                                    x-text="totalPages"></span>
                                页</span>
                            <button @click="prevPage()" :disabled="page <= 1"
                                class="rounded border px-2 py-1 text-xs hover:bg-slate-50 disabled:opacity-50 flex-shrink-0">上一页</button>
                            <button @click="nextPage()" :disabled="page >= totalPages"
                                class="rounded border px-2 py-1 text-xs hover:bg-slate-50 disabled:opacity-50 flex-shrink-0">下一页</button>
                        </div>
                    </div>

                    <!-- Bookmark List Area -->
                    <div class="flex-1 min-h-0 overflow-visible">
                        <!-- Table View -->
                        <div x-show="viewMode === 'table'" class="relative z-10 rounded-lg border bg-white shadow-sm overflow-x-auto overflow-y-visible">
                            <table class="w-full min-w-[720px]">
                                <thead class="bg-slate-50">
                                    <tr>
                                        <th class="w-10 px-3 py-2"><input type="checkbox" @change="toggleAll($event)"
                                                :checked="allSelected">
                                        </th>
                                        <th class="px-3 py-2 text-left text-xs font-semibold text-slate-600">标题</th>
                                        <th class="w-24 px-3 py-2 text-left text-xs font-semibold text-slate-600">分类
                                        </th>
                                        <th class="w-20 px-3 py-2 text-center text-xs font-semibold text-slate-600">状态
                                        </th>
                                        <th class="w-24 px-3 py-2 text-center text-xs font-semibold text-slate-600">操作
                                        </th>
                                    </tr>
                                </thead>
                                <tbody class="divide-y">
                                    <template x-for="bookmark in displayBookmarks" :key="bookmark.id">
                                        <tr class="hover:bg-slate-50"
                                            data-testid="bookmark-row"
                                            :data-bookmark-id="bookmark.id">
                                            <td class="px-3 py-2">
                                                <input type="checkbox" :value="String(bookmark.id)"
                                                    data-testid="bookmark-row-checkbox"
                                                    x-model="selectedBookmarks">
                                            </td>
                                            <td class="px-3 py-2 max-w-xs">
                                                <a :href="bookmark.url" target="_blank"
                                                    data-testid="bookmark-row-title"
                                                    class="text-sm text-blue-600 hover:underline line-clamp-1"
                                                    x-text="bookmark.title"></a>
                                                <div class="text-xs text-slate-400 truncate max-w-xs"
                                                    x-text="bookmark.url">
                                                </div>
                                            </td>
                                            <td class="px-3 py-2"><span class="text-xs text-slate-500"
                                                    data-testid="bookmark-category-label"
                                                    x-text="bookmark.category_name || '未分类'"></span></td>
                                            <td class="px-3 py-2 text-center">
                                                <span class="inline-flex items-center gap-1">
                                                    <span class="w-2 h-2 rounded-full"
                                                        :class="bookmark.check_status === 'ok' ? 'bg-emerald-500' : bookmark.check_status === 'fail' ? 'bg-rose-500' : 'bg-slate-300'"></span>
                                                    <span
                                                        x-show="bookmark.skip_check == 1 || bookmark.skip_check === true"
                                                        class="text-xs text-slate-400" title="忽略检查">🚫</span>
                                                </span>
                                            </td>
                                            <td class="px-3 py-2 text-center relative z-20">
                                                <!-- Dropdown Menu Button -->
                                                <button
                                                    @click.stop="openDropdownId === bookmark.id ? closeAllDropdowns() : openDropdown(bookmark.id)"
                                                    data-testid="bookmark-actions-button"
                                                    class="rounded border px-2 py-1 text-xs hover:bg-slate-100 dark:hover:bg-slate-700 dark:border-slate-600">操作
                                                    ▼</button>
                                                <!-- Dropdown Menu -->
                                                <div x-show="openDropdownId === bookmark.id"
                                                    @click.away="closeAllDropdowns()" x-effect="if (openDropdownId === bookmark.id) { 
                                                        $nextTick(() => { 
                                                            const rect = $el.parentElement.getBoundingClientRect();
                                                            const spaceBelow = window.innerHeight - rect.bottom;
                                                            const spaceAbove = rect.top;
                                                            if (spaceBelow < 250 && spaceAbove > spaceBelow && spaceAbove > 220) {
                                                                $el.style.top = 'auto';
                                                                $el.style.bottom = '100%';
                                                                $el.style.marginBottom = '0.25rem';
                                                                $el.style.marginTop = '0';
                                                            } else {
                                                                $el.style.bottom = 'auto';
                                                                $el.style.top = '100%';
                                                                $el.style.marginTop = '0.25rem';
                                                                $el.style.marginBottom = '0';
                                                            }
                                                        });
                                                    }"
                                                    class="absolute right-0 z-50 w-32 rounded-lg border bg-white dark:bg-slate-800 dark:border-slate-600 shadow-lg py-1 text-left max-h-80 overflow-y-auto">
                                                    <button @click="openEditBookmark(bookmark); closeAllDropdowns()"
                                                        data-testid="bookmark-row-edit-button"
                                                        class="block w-full px-3 py-1.5 text-xs hover:bg-slate-50 text-left">✏️
                                                        编辑</button>
                                                    <button @click="openMoveBookmark(bookmark); closeAllDropdowns()"
                                                        data-testid="bookmark-row-move-button"
                                                        class="block w-full px-3 py-1.5 text-xs hover:bg-slate-50 text-left">📁
                                                        移动</button>
                                                    <button @click="startCheckOne(bookmark.id); closeAllDropdowns()"
                                                        class="block w-full px-3 py-1.5 text-xs hover:bg-slate-50 text-left">🔍
                                                        检查</button>
                                                    <button @click="promptClassifyBatch([bookmark.id]); closeAllDropdowns()"
                                                        class="block w-full px-3 py-1.5 text-xs hover:bg-slate-50 text-left">🤖
                                                        AI 分类</button>
                                                    <hr class="my-1">
                                                    <button
                                                        @click="updateBookmarkStatus(bookmark.id, 'ok'); closeAllDropdowns()"
                                                        class="block w-full px-3 py-1.5 text-xs hover:bg-slate-50 text-left">✅
                                                        标记正常</button>
                                                    <button
                                                        @click="updateBookmarkStatus(bookmark.id, 'fail'); closeAllDropdowns()"
                                                        class="block w-full px-3 py-1.5 text-xs hover:bg-slate-50 text-left">❌
                                                        标记失败</button>
                                                    <button @click="toggleSkipCheck(bookmark); closeAllDropdowns()"
                                                        class="block w-full px-3 py-1.5 text-xs hover:bg-slate-50 text-left"
                                                        x-text="bookmark.skip_check ? '🔄 取消忽略' : '🚫 忽略检查'"></button>
                                                    <hr class="my-1">
                                                    <button @click="deleteBookmark(bookmark.id); closeAllDropdowns()"
                                                        data-testid="bookmark-row-delete-button"
                                                        class="block w-full px-3 py-1.5 text-xs hover:bg-rose-50 text-rose-600 text-left">🗑️
                                                        删除</button>
                                                </div>
                                            </td>
                                        </tr>
                                    </template>
                                </tbody>
                            </table>
                            <div x-show="displayBookmarks.length === 0" class="text-center py-10 text-slate-400">暂无书签
                            </div>
                        </div>

                        <!-- Card View -->
                        <div x-show="viewMode === 'card'" class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4">
                            <template x-for="bookmark in displayBookmarks" :key="bookmark.id">
                                <div class="rounded-lg border bg-white p-4 shadow-sm hover:shadow-md transition-shadow">
                                    <div class="flex items-start gap-2">
                                        <input type="checkbox" :value="String(bookmark.id)" x-model="selectedBookmarks"
                                            class="mt-1">
                                        <div class="flex-1 min-w-0">
                                            <div class="flex items-start justify-between gap-2">
                                                <a :href="bookmark.url" target="_blank"
                                                    class="text-sm font-medium text-blue-600 hover:underline line-clamp-2 flex-1"
                                                    x-text="bookmark.title"></a>
                                                <span class="inline-flex items-center gap-1 flex-shrink-0 mt-1">
                                                    <span class="w-2 h-2 rounded-full"
                                                        :class="bookmark.check_status === 'ok' ? 'bg-emerald-500' : bookmark.check_status === 'fail' ? 'bg-rose-500' : 'bg-slate-300'"></span>
                                                    <span
                                                        x-show="bookmark.skip_check == 1 || bookmark.skip_check === true"
                                                        class="text-xs text-slate-400" title="忽略检查">🚫</span>
                                                </span>
                                            </div>
                                            <div class="text-xs text-slate-400 truncate max-w-xs mt-1"
                                                x-text="bookmark.url">
                                            </div>
                                            <div class="flex items-center justify-between mt-3">
                                                <span class="text-xs bg-slate-100 rounded px-2 py-0.5"
                                                    x-text="bookmark.category_name || '未分类'"></span>
                                                <div class="relative">
                                                    <button
                                                        @click.stop="openDropdownId === ('card-' + bookmark.id) ? closeAllDropdowns() : openDropdown('card-' + bookmark.id)"
                                                        class="rounded border px-2 py-1 text-xs hover:bg-slate-100">操作
                                                        ▼</button>
                                                    <div x-show="openDropdownId === ('card-' + bookmark.id)"
                                                        @click.away="closeAllDropdowns()"
                                                        class="absolute right-0 top-full mt-1 z-50 w-32 rounded-lg border bg-white shadow-lg py-1 text-left">
                                                        <button @click="openEditBookmark(bookmark); closeAllDropdowns()"
                                                            class="block w-full px-3 py-1.5 text-xs hover:bg-slate-50 text-left">✏️
                                                            编辑</button>
                                                        <button @click="openMoveBookmark(bookmark); closeAllDropdowns()"
                                                            class="block w-full px-3 py-1.5 text-xs hover:bg-slate-50 text-left">📁
                                                            移动</button>
                                                        <button @click="startCheckOne(bookmark.id); closeAllDropdowns()"
                                                            class="block w-full px-3 py-1.5 text-xs hover:bg-slate-50 text-left">�
                                                            检查</button>
                                                        <hr class="my-1">
                                                        <button
                                                            @click="updateBookmarkStatus(bookmark.id, 'ok'); closeAllDropdowns()"
                                                            class="block w-full px-3 py-1.5 text-xs hover:bg-slate-50 text-left">✅
                                                            标记正常</button>
                                                        <button
                                                            @click="updateBookmarkStatus(bookmark.id, 'fail'); closeAllDropdowns()"
                                                            class="block w-full px-3 py-1.5 text-xs hover:bg-slate-50 text-left">❌
                                                            标记失败</button>
                                                        <button @click="toggleSkipCheck(bookmark); closeAllDropdowns()"
                                                            class="block w-full px-3 py-1.5 text-xs hover:bg-slate-50 text-left"
                                                            x-text="bookmark.skip_check ? '🔄 取消忽略' : '🚫 忽略检查'"></button>
                                                        <hr class="my-1">
                                                        <button
                                                            @click="deleteBookmark(bookmark.id); closeAllDropdowns()"
                                                            class="block w-full px-3 py-1.5 text-xs hover:bg-rose-50 text-rose-600 text-left">🗑️
                                                            删除</button>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </template>
                        </div>
                    </div>
                </main>
            </div>
        </div>

        <!-- Edit Bookmark Modal -->
        <div x-cloak x-show="showEditModal" data-testid="edit-bookmark-modal" class="fixed inset-0 z-50 flex items-center justify-center bg-black/50"
            @keydown.escape.window="if(showEditModal) closeEditModal()"
            @click.self="closeEditModal()">
            <div class="w-full max-w-md rounded-lg bg-white p-4 shadow-xl">
                <div class="flex items-center justify-between mb-3">
                    <h3 class="text-lg font-semibold">编辑书签</h3>
                    <button @click="closeEditModal()"
                        class="text-slate-400 hover:text-slate-600 text-xl">&times;</button>
                </div>
                <div class="space-y-3">
                    <input type="text" x-model="editBookmark.url" placeholder="URL"
                        data-testid="edit-bookmark-url-input"
                        @keyup.enter="saveEditBookmark()"
                        class="w-full rounded border px-3 py-2 text-sm">
                    <input type="text" x-model="editBookmark.title" placeholder="标题"
                        data-testid="edit-bookmark-title-input"
                        @keyup.enter="saveEditBookmark()"
                        class="w-full rounded border px-3 py-2 text-sm">
                </div>
                <div class="flex justify-end gap-2 mt-4">
                    <button @click="closeEditModal()" data-testid="edit-bookmark-cancel"
                        class="rounded border px-4 py-2 text-sm hover:bg-slate-50">取消</button>
                    <button @click="saveEditBookmark()" data-testid="edit-bookmark-save"
                        class="rounded bg-slate-900 text-white px-4 py-2 text-sm hover:bg-slate-800">保存</button>
                </div>
            </div>
        </div>

        <!-- Move One Bookmark Modal -->
        <div x-cloak x-show="showMoveOneModal"
            data-testid="move-one-modal"
            class="fixed inset-0 z-50 flex items-center justify-center bg-black/50"
            @click.self="closeMoveOneModal()">
            <div class="w-full max-w-md rounded-lg bg-white p-4 shadow-xl">
                <div class="flex items-center justify-between mb-3">
                    <h3 class="text-lg font-semibold">移动书签</h3>
                    <button @click="closeMoveOneModal()"
                        class="text-slate-400 hover:text-slate-600 text-xl">&times;</button>
                </div>
                <select x-model="moveOneTargetCategory"
                    data-testid="move-one-category-select"
                    class="w-full rounded border px-3 py-2 text-sm">
                    <option value="">未分类</option>
                    <template x-for="cat in categories" :key="cat.id">
                        <option :value="cat.id" x-text="cat.name"></option>
                    </template>
                </select>
                <div class="flex justify-end gap-2 mt-4">
                    <button @click="closeMoveOneModal()"
                        class="rounded border px-4 py-2 text-sm hover:bg-slate-50">取消</button>
                    <button @click="confirmMoveOneBookmark()"
                        data-testid="confirm-move-one-bookmark"
                        class="rounded bg-slate-900 text-white px-4 py-2 text-sm hover:bg-slate-800">确认移动</button>
                </div>
            </div>
        </div>

        <!-- Move Selected Modal -->
        <div x-cloak x-show="showMoveSelectedModal"
            data-testid="move-selected-modal"
            class="fixed inset-0 z-50 flex items-center justify-center bg-black/50"
            @click.self="closeMoveSelectedModal()">
            <div class="w-full max-w-md rounded-lg bg-white p-4 shadow-xl">
                <h3 class="text-lg font-semibold mb-3">批量移动书签</h3>
                <p class="text-sm text-slate-500 mb-3">将 <span x-text="selectedBookmarks.length"></span> 个书签移动到：</p>
                <select x-model="moveSelectedTargetCategory"
                    data-testid="move-selected-category-select"
                    class="w-full rounded border px-3 py-2 text-sm">
                    <option value="">未分类</option>
                    <template x-for="cat in categories" :key="cat.id">
                        <option :value="cat.id" x-text="cat.name"></option>
                    </template>
                </select>
                <div class="flex justify-end gap-2 mt-4">
                    <button @click="closeMoveSelectedModal()"
                        class="rounded border px-4 py-2 text-sm hover:bg-slate-50">取消</button>
                    <button @click="confirmMoveSelectedBookmarks()"
                        data-testid="confirm-move-selected-bookmarks"
                        class="rounded bg-slate-900 text-white px-4 py-2 text-sm hover:bg-slate-800">确认移动</button>
                </div>
            </div>
        </div>

        <!-- Category Style Modal -->
        <div x-cloak x-show="showCategoryStyleModal"
            class="fixed inset-0 z-50 flex items-center justify-center bg-black/50"
            @click.self="closeCategoryStyleModal()">
            <div class="w-full max-w-md rounded-lg bg-white p-4 shadow-xl">
                <h3 class="text-lg font-semibold mb-3">分类样式</h3>
                <div class="space-y-3">
                    <div>
                        <label class="text-xs text-slate-600">图标</label>
                        <div class="flex flex-wrap gap-2 mt-1">
                            <template
                                x-for="icon in ['📁', '📂', '📄', '📝', '📚', '🔖', '⭐', '❤️', '🎮', '🎵', '🎬', '📷', '💻', '🌐', '🛠️', '📱']">
                                <button @click="categoryIcon = icon"
                                    class="w-8 h-8 rounded border hover:bg-slate-50 flex items-center justify-center"
                                    :class="categoryIcon === icon ? 'border-blue-500 bg-blue-50' : ''"
                                    x-text="icon"></button>
                            </template>
                        </div>
                    </div>
                    <div>
                        <label class="text-xs text-slate-600">颜色</label>
                        <div class="flex flex-wrap gap-2 mt-1">
                            <template
                                x-for="color in ['', '#ef4444', '#f97316', '#eab308', '#22c55e', '#14b8a6', '#3b82f6', '#8b5cf6', '#ec4899']">
                                <button @click="categoryColor = color" class="w-8 h-8 rounded border hover:opacity-80"
                                    :class="categoryColor === color ? 'ring-2 ring-blue-500' : ''"
                                    :style="color ? 'background-color:' + color : ''"
                                    x-text="color ? '' : '✕'"></button>
                            </template>
                        </div>
                    </div>
                </div>
                <div class="flex justify-end gap-2 mt-4">
                    <button @click="closeCategoryStyleModal()"
                        class="rounded border px-4 py-2 text-sm hover:bg-slate-50">取消</button>
                    <button @click="saveCategoryStyle()"
                        class="rounded bg-slate-900 text-white px-4 py-2 text-sm hover:bg-slate-800">保存</button>
                </div>
            </div>
        </div>

        <!-- Create Category Modal -->
        <div x-cloak x-show="showCreateCategoryModal" data-testid="create-category-modal"
            class="fixed inset-0 z-50 flex items-center justify-center bg-black/50"
            @click.self="closeCreateCategoryModal()">
            <div class="w-full max-w-md rounded-lg bg-white p-4 shadow-xl">
                <h3 class="text-lg font-semibold mb-3" x-text="createCategoryParentId ? '添加子分类' : '添加分类'"></h3>
                <div class="space-y-3">
                    <div>
                        <label class="text-xs text-slate-600">名称</label>
                        <input type="text" x-model="createCategoryName" placeholder="分类名称"
                            data-testid="create-category-name-input"
                            class="w-full rounded border px-3 py-2 text-sm mt-1" @keyup.enter="confirmCreateCategory()">
                    </div>
                    <div>
                        <label class="text-xs text-slate-600">图标</label>
                        <div class="flex flex-wrap gap-2 mt-1">
                            <template
                                x-for="icon in ['📁', '📂', '📄', '📝', '📚', '🔖', '⭐', '❤️', '🎮', '🎵', '🎬', '📷', '💻', '🌐', '🛠️', '📱']">
                                <button @click="createCategoryIcon = createCategoryIcon === icon ? '' : icon"
                                    class="w-8 h-8 rounded border hover:bg-slate-50 flex items-center justify-center"
                                    :class="createCategoryIcon === icon ? 'border-blue-500 bg-blue-50' : ''"
                                    x-text="icon"></button>
                            </template>
                        </div>
                    </div>
                    <div>
                        <label class="text-xs text-slate-600">颜色</label>
                        <div class="flex flex-wrap gap-2 mt-1">
                            <template
                                x-for="color in ['', '#ef4444', '#f97316', '#eab308', '#22c55e', '#14b8a6', '#3b82f6', '#8b5cf6', '#ec4899']">
                                <button @click="createCategoryColor = color" class="w-8 h-8 rounded border hover:opacity-80"
                                    :class="createCategoryColor === color ? 'ring-2 ring-blue-500' : ''"
                                    :style="color ? 'background-color:' + color : ''"
                                    x-text="color ? '' : '✕'"></button>
                            </template>
                        </div>
                    </div>
                </div>
                <div class="flex justify-end gap-2 mt-4">
                    <button @click="closeCreateCategoryModal()" data-testid="create-category-cancel"
                        class="rounded border px-4 py-2 text-sm hover:bg-slate-50">取消</button>
                    <button @click="confirmCreateCategory()"
                        :disabled="!createCategoryName.trim()"
                        data-testid="create-category-confirm"
                        class="rounded bg-slate-900 text-white px-4 py-2 text-sm hover:bg-slate-800 disabled:opacity-40 disabled:cursor-not-allowed">确认</button>
                </div>
            </div>
        </div>

        <!-- Check Modal -->
        <div x-cloak x-show="showCheckModal" data-testid="job-progress-modal"
            class="fixed inset-0 z-50 flex items-center justify-center bg-black/50"
            @click.self="closeCheckModal()">
            <div class="w-full max-w-lg rounded-lg bg-white p-4 shadow-xl">
                <div class="flex items-center justify-between mb-3">
                    <h3 class="text-lg font-semibold">🔍 批量检查</h3>
                    <button @click="closeCheckModal()"
                        class="text-slate-400 hover:text-slate-600 text-xl">&times;</button>
                </div>
                <template x-if="!checkJobId">
                    <div class="space-y-3">
                        <div>
                            <label class="text-xs text-slate-600">检查范围</label>
                            <select x-model="checkOptions.scope" class="w-full rounded border px-3 py-2 text-sm mt-1">
                                <option value="all">全部书签</option>
                                <option value="not_checked">仅未检查</option>
                                <option value="failed">仅失败书签</option>
                                <option value="category">当前分类</option>
                                <option value="selected">选中书签</option>
                            </select>
                        </div>
                        <div class="grid grid-cols-2 gap-3">
                            <div>
                                <label class="text-xs text-slate-600">重试次数</label>
                                <select x-model="checkOptions.retries"
                                    class="w-full rounded border px-3 py-2 text-sm mt-1">
                                    <option value="0">0</option>
                                    <option value="1">1</option>
                                    <option value="2">2</option>
                                    <option value="3">3</option>
                                </select>
                            </div>
                            <div>
                                <label class="text-xs text-slate-600">重试间隔(ms)</label>
                                <input type="number" x-model="checkOptions.retry_delay_ms"
                                    class="w-full rounded border px-3 py-2 text-sm mt-1">
                            </div>
                        </div>
                        <div class="flex justify-end gap-2">
                            <button @click="closeCheckModal()"
                                class="rounded border px-4 py-2 text-sm hover:bg-slate-50">取消</button>
                            <button @click="startCheck()"
                                class="rounded bg-slate-900 text-white px-4 py-2 text-sm hover:bg-slate-800">开始检查</button>
                        </div>
                    </div>
                </template>
                <template x-if="checkJobId && !checkJobDone">
                    <div class="space-y-4">
                        <!-- Circular Progress Ring -->
                        <div class="flex flex-col items-center gap-3">
                            <div class="relative w-24 h-24">
                                <svg class="w-24 h-24 transform -rotate-90">
                                    <circle cx="48" cy="48" r="40" stroke="#e2e8f0" stroke-width="8" fill="none" />
                                    <circle cx="48" cy="48" r="40" stroke="#3b82f6" stroke-width="8" fill="none"
                                        stroke-linecap="round" :stroke-dasharray="251.2"
                                        :stroke-dashoffset="251.2 - (251.2 * checkProgress / 100)" />
                                </svg>
                                <div class="absolute inset-0 flex items-center justify-center">
                                    <span class="text-xl font-bold text-blue-600" x-text="checkProgress + '%'"></span>
                                </div>
                            </div>
                            <div class="text-center">
                                <div class="text-sm font-medium text-slate-700"
                                    x-text="'处理中 ' + checkStats.processed + ' / ' + checkStats.total"></div>
                                <div class="text-xs text-slate-400 mt-1">正在检查书签可用性...</div>
                            </div>
                        </div>
                        <!-- Action Buttons -->
                        <div class="flex justify-center gap-3 pt-2 border-t">
                            <button @click="cancelCheckJob()"
                                class="flex items-center gap-1 rounded-lg border border-rose-200 text-rose-600 px-4 py-2 text-sm hover:bg-rose-50 transition">
                                <span>✕</span> 取消任务
                            </button>
                            <a :href="'/jobs/' + checkJobId"
                                class="flex items-center gap-1 rounded-lg border px-4 py-2 text-sm hover:bg-slate-50 transition">
                                <span>📋</span> 查看详情
                            </a>
                        </div>
                    </div>
                </template>
                <template x-if="checkJobDone">
                    <div class="space-y-4">
                        <!-- 100% Completion Ring -->
                        <div class="flex flex-col items-center gap-3">
                            <div class="relative w-24 h-24">
                                <svg class="w-24 h-24 transform -rotate-90">
                                    <circle cx="48" cy="48" r="40" stroke="#e2e8f0" stroke-width="8" fill="none" />
                                    <circle cx="48" cy="48" r="40" stroke="#10b981" stroke-width="8" fill="none"
                                        stroke-linecap="round" stroke-dasharray="251.2" stroke-dashoffset="0" />
                                </svg>
                                <div class="absolute inset-0 flex items-center justify-center">
                                    <span class="text-xl font-bold text-emerald-600">100%</span>
                                </div>
                            </div>
                            <div class="text-emerald-600 font-medium">✅ 检查完成</div>
                            <div class="text-sm text-slate-500"
                                x-text="'成功: ' + checkStats.inserted + '  失败: ' + checkStats.failed"></div>
                        </div>
                        <!-- Action Buttons -->
                        <div class="flex justify-center gap-3 pt-2 border-t">
                            <a :href="'/jobs/' + checkJobId"
                                class="flex items-center gap-1 rounded-lg border px-4 py-2 text-sm hover:bg-slate-50 transition">
                                <span>📋</span> 查看详情
                            </a>
                            <button @click="closeCheckModal()"
                                class="rounded-lg border px-4 py-2 text-sm hover:bg-slate-50 transition">关闭</button>
                        </div>
                    </div>
                </template>
            </div>
        </div>

        <!-- Template Select Modal -->
        <div x-cloak x-show="showTemplateSelectModal"
            data-testid="template-select-modal"
            class="fixed inset-0 z-50 flex items-start justify-center overflow-y-auto bg-black/50 px-4 py-4"
            @click.self="showTemplateSelectModal = false">
            <div class="w-full max-w-3xl rounded-lg bg-white shadow-xl flex flex-col overflow-hidden"
                style="max-height: calc(100vh - 2rem);"
                data-testid="template-select-panel"
                x-data="{ activeTab: 'custom' }">
                <div class="flex items-center justify-between gap-3 border-b bg-white px-4 py-3 flex-shrink-0">
                    <h3 class="text-lg font-semibold">🗂️ 选择分类模板</h3>
                    <button @click="showTemplateSelectModal = false"
                        data-testid="template-select-close"
                        class="text-slate-400 hover:text-slate-600 text-xl">&times;</button>
                </div>
                <!-- Tab Navigation -->
                <div class="flex border-b px-4 pt-2 flex-shrink-0" role="tablist" aria-label="模板类型">
                    <button @click="activeTab = 'custom'"
                        data-testid="template-tab-custom"
                        class="px-4 py-2 text-sm font-medium transition-colors"
                        role="tab" :aria-selected="activeTab === 'custom'" aria-controls="tabpanel-custom" id="tab-custom"
                        :class="activeTab === 'custom' ? 'border-b-2 border-blue-500 text-blue-600' : 'text-slate-500 hover:text-slate-700'">
                        📁 我的模板
                    </button>
                    <button @click="activeTab = 'preset'"
                        data-testid="template-tab-preset"
                        class="px-4 py-2 text-sm font-medium transition-colors"
                        role="tab" :aria-selected="activeTab === 'preset'" aria-controls="tabpanel-preset" id="tab-preset"
                        :class="activeTab === 'preset' ? 'border-b-2 border-blue-500 text-blue-600' : 'text-slate-500 hover:text-slate-700'">
                        📚 模板库
                    </button>
                </div>
                <div class="flex-1 min-h-0 overflow-y-auto px-4 py-4"
                    data-testid="template-select-body">
                    <!-- Tab 1: My Templates (Custom) -->
                    <div x-show="activeTab === 'custom'" class="space-y-2" role="tabpanel" id="tabpanel-custom" aria-labelledby="tab-custom">
                        <template x-for="tpl in customTemplates" :key="tpl.id">
                            <div class="flex items-center justify-between border rounded-lg px-3 py-2 hover:bg-slate-50"
                                data-testid="custom-template-card"
                                :data-template-id="tpl.id"
                                :class="tpl.is_active === 1 ? 'border-blue-300 bg-blue-50' : ''">
                                <div class="flex-1 min-w-0">
                                    <div class="flex items-center gap-2">
                                        <span class="text-sm font-medium truncate"
                                              data-testid="template-card-name"
                                              x-text="tpl.name"></span>
                                        <template x-if="tpl.is_active === 1">
                                            <span class="text-xs px-1.5 py-0.5 rounded bg-blue-100 text-blue-600">当前</span>
                                        </template>
                                    </div>
                                    <div class="text-xs text-slate-400 mt-0.5" x-text="tpl.top_level_count + ' 个一级分类'"></div>
                                </div>
                                <div class="flex items-center gap-1 ml-2 flex-shrink-0">
                                    <button @click="openTemplateEditor(tpl.id)"
                                        data-testid="edit-template-button"
                                        class="text-xs px-2 py-1 rounded border hover:bg-slate-100">编辑</button>
                                    <template x-if="tpl.is_active === 1">
                                        <div class="relative group cursor-not-allowed">
                                            <button aria-disabled="true" tabindex="-1"
                                                class="text-xs px-2 py-1 rounded border border-rose-200 text-rose-500 opacity-50 pointer-events-none">删除</button>
                                            <div class="absolute bottom-full left-1/2 -translate-x-1/2 mb-1 px-2 py-1 text-xs text-white bg-slate-800 rounded whitespace-nowrap opacity-0 group-hover:opacity-100 pointer-events-none transition-opacity">
                                                无法删除正在使用中的模板
                                            </div>
                                        </div>
                                    </template>
                                    <template x-if="tpl.is_active !== 1">
                                        <button @click="if(await AppDialog.confirm('确定删除此模板？')) deleteTemplate(tpl.id)"
                                            class="text-xs px-2 py-1 rounded border border-rose-200 text-rose-500 hover:bg-rose-50">删除</button>
                                    </template>
                                    <template x-if="tpl.is_active !== 1">
                                        <button @click="if(await AppDialog.confirm('应用模板将替换当前所有分类，所有书签将变为未分类。如果该模板曾使用过，书签分布将自动恢复。\n\n确定应用此模板？')) { applyTemplate(tpl.id); showTemplateSelectModal = false; }"
                                            data-testid="apply-template-button"
                                            class="text-xs px-2 py-1 rounded bg-blue-500 text-white hover:bg-blue-600"
                                            :disabled="templateApplying">应用</button>
                                    </template>
                                </div>
                            </div>
                        </template>
                        <template x-if="customTemplates.length === 0">
                            <div class="text-xs text-slate-400 text-center py-8">暂无自定义模板，可从模板库创建</div>
                        </template>
                    </div>
                    <!-- Tab 2: Template Library (Preset) -->
                    <div x-show="activeTab === 'preset'" class="space-y-2" role="tabpanel" id="tabpanel-preset" aria-labelledby="tab-preset">
                        <template x-for="tpl in presetTemplates" :key="tpl.id">
                            <div class="border rounded-lg overflow-hidden"
                                data-testid="preset-template-card"
                                :data-template-id="tpl.id"
                                :class="tpl.is_active === 1 ? 'border-violet-300 bg-violet-50' : ''">
                                <div class="flex items-center justify-between px-3 py-2 hover:bg-slate-50">
                                    <div class="flex-1 min-w-0">
                                        <div class="flex items-center gap-2">
                                            <span class="text-sm font-medium truncate"
                                                data-testid="preset-template-card-name"
                                                x-text="tpl.name"></span>
                                            <span class="text-xs px-1.5 py-0.5 rounded bg-violet-100 text-violet-600">预置</span>
                                            <template x-if="tpl.is_active === 1">
                                                <span class="text-xs px-1.5 py-0.5 rounded bg-blue-100 text-blue-600">当前使用</span>
                                            </template>
                                        </div>
                                        <div class="text-xs text-slate-400 mt-0.5" x-text="tpl.top_level_count + ' 个一级分类'"></div>
                                        <div class="text-[11px] text-slate-500 mt-1">可直接创建自定义副本，或创建后立即应用到当前分类体系。</div>
                                    </div>
                                    <div class="flex items-center gap-1 ml-2 flex-shrink-0">
                                        <button @click="toggleTemplatePreview(tpl.id)"
                                            data-testid="preview-preset-template-button"
                                            class="text-xs px-2 py-1 rounded border hover:bg-slate-100"
                                            :class="templatePreviewId === tpl.id ? 'bg-slate-100' : ''"
                                            :aria-expanded="templatePreviewId === tpl.id"
                                            :aria-controls="'preview-panel-' + tpl.id">
                                            <span x-text="templatePreviewId === tpl.id ? '👁️ 收起' : '👁️ 预览'"></span>
                                        </button>
                                        <button @click="instantiatePresetTemplate(tpl.id)"
                                            data-testid="copy-preset-template-button"
                                            class="text-xs px-2 py-1 rounded border border-slate-300 text-slate-600 hover:bg-slate-100 disabled:opacity-50 disabled:cursor-not-allowed"
                                            :disabled="templateApplying">创建副本</button>
                                        <button @click="instantiatePresetTemplate(tpl.id, { applyAfterCreate: true })"
                                            data-testid="use-preset-template-button"
                                            class="text-xs px-2 py-1 rounded bg-violet-600 text-white hover:bg-violet-700 disabled:opacity-50 disabled:cursor-not-allowed"
                                            :disabled="templateApplying">创建并应用</button>
                                    </div>
                                </div>
                                <!-- Preview Tree -->
                                <div x-show="templatePreviewId === tpl.id"
                                    :id="'preview-panel-' + tpl.id"
                                    class="border-t bg-slate-50 px-3 py-2">
                                    <div class="text-xs font-medium text-slate-600 mb-2">分类结构预览：</div>
                                    <div class="space-y-1 max-h-60 overflow-y-auto">
                                        <template x-for="node in templatePreviewTree" :key="node.name">
                                            <div>
                                                <div class="text-xs font-medium text-slate-700">
                                                    <span aria-hidden="true">📁 </span>
                                                    <span x-text="node.name"></span>
                                                </div>
                                                <template x-if="node.children && node.children.length > 0">
                                                    <div class="ml-4 mt-0.5 space-y-0.5">
                                                        <template x-for="child in node.children" :key="child.name">
                                                            <div class="text-xs text-slate-600">
                                                                <span aria-hidden="true">└─ </span>
                                                                <span x-text="child.name"></span>
                                                            </div>
                                                        </template>
                                                    </div>
                                                </template>
                                            </div>
                                        </template>
                                    </div>
                                </div>
                            </div>
                        </template>
                        <template x-if="presetTemplates.length === 0">
                            <div class="text-xs text-slate-400 text-center py-8">暂无预置模板</div>
                        </template>
                    </div>
                </div>
                <!-- New Template Button -->
                <div class="border-t bg-white px-4 py-3 flex-shrink-0">
                    <button @click="openNewTemplateEditor()"
                        data-testid="template-select-new-custom"
                        class="w-full rounded border border-dashed border-slate-300 px-3 py-1.5 text-xs text-slate-500 hover:border-slate-400 hover:text-slate-700">+ 新建自定义模板</button>
                </div>
            </div>
        </div>

        <!-- Batch Size Selector Modal -->
        <div x-cloak x-show="showBatchSizeModal"
            class="fixed inset-0 z-50 flex items-center justify-center bg-black/50"
            @click.self="classifyBatchTemplateId = null; showBatchSizeModal = false">
            <div class="w-full max-w-xs rounded-lg bg-white p-4 shadow-xl">
                <div class="flex items-center justify-between mb-3">
                    <h3 class="text-lg font-semibold">🤖 AI 分类</h3>
                    <button @click="classifyBatchTemplateId = null; showBatchSizeModal = false"
                        class="text-slate-400 hover:text-slate-600 text-xl">&times;</button>
                </div>
                <p class="text-sm text-slate-500 mb-3">将对 <span class="font-medium text-slate-700" x-text="classifyBatchIds.length"></span> 个书签进行 AI 分类</p>
                <template x-if="!activeTemplate && !classifyBatchTemplateId">
                    <div class="mb-3 text-xs text-amber-600 bg-amber-50 border border-amber-200 rounded px-3 py-2">请先选择一个分类模板；可直接使用模板库中的预置模板，或使用当前已应用模板。</div>
                </template>
                <div class="mb-4">
                    <label class="text-xs text-slate-600">每批处理数量</label>
                    <select x-model.number="classifyBatchSize" class="w-full rounded border px-3 py-2 text-sm mt-1">
                        <option value="10">10</option>
                        <option value="20">20（推荐）</option>
                        <option value="30">30</option>
                    </select>
                </div>
                <div class="flex justify-end gap-2">
                    <button @click="classifyBatchTemplateId = null; showBatchSizeModal = false"
                        class="rounded border px-4 py-2 text-sm hover:bg-slate-50">取消</button>
                    <button @click="startClassifyBatch(classifyBatchIds, classifyBatchSize)"
                        :disabled="!activeTemplate && !classifyBatchTemplateId"
                        class="rounded bg-slate-900 text-white px-4 py-2 text-sm hover:bg-slate-800"
                        :class="{'opacity-50 cursor-not-allowed': !activeTemplate && !classifyBatchTemplateId}">开始分类</button>
                </div>
            </div>
        </div>

        <!-- Add Bookmark Modal -->
        <div x-cloak x-show="showAddBookmarkModal" data-testid="add-bookmark-modal"
            class="fixed inset-0 z-50 flex items-center justify-center bg-black/50"
            @click.self="closeAddBookmarkModal()"
            @keydown.escape.window="if(showAddBookmarkModal) closeAddBookmarkModal()">
            <div class="w-full max-w-md rounded-lg bg-white p-6 shadow-xl">
                <div class="flex items-center justify-between mb-4">
                    <h3 class="text-lg font-semibold">➕ 添加书签</h3>
                    <button @click="closeAddBookmarkModal()"
                        class="text-slate-400 hover:text-slate-600 text-xl">&times;</button>
                </div>
                <div class="space-y-3">
                    <div>
                        <label class="text-xs text-slate-600 block mb-1">URL *</label>
                        <input type="text" x-model="newBookmark.url" placeholder="https://example.com"
                            data-testid="add-bookmark-url-input"
                            class="w-full rounded border px-3 py-2 text-sm"
                            @keydown.enter="addBookmark()">
                    </div>
                    <div>
                        <label class="text-xs text-slate-600 block mb-1">标题（可选）</label>
                        <input type="text" x-model="newBookmark.title" placeholder="书签标题"
                            data-testid="add-bookmark-title-input"
                            class="w-full rounded border px-3 py-2 text-sm"
                            @keydown.enter="addBookmark()">
                    </div>
                    <div>
                        <label class="text-xs text-slate-600 block mb-1">分类</label>
                        <select x-model="newBookmark.category_id"
                            data-testid="add-bookmark-category-select"
                            class="w-full rounded border px-3 py-2 text-sm">
                            <option value="">未分类</option>
                            <template x-for="cat in categories" :key="cat.id">
                                <option :value="cat.id" x-text="cat.name"></option>
                            </template>
                        </select>
                    </div>
                    <div class="flex justify-end gap-2 pt-2">
                        <button @click="closeAddBookmarkModal()"
                            class="btn-secondary btn-sm">取消</button>
                        <button @click="addBookmark()" data-testid="add-bookmark-submit"
                            class="btn-primary btn-sm">添加</button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Template Edit Modal -->
        <div x-cloak x-show="showTemplateEditModal"
            data-testid="template-edit-modal"
            class="fixed inset-0 z-50 flex items-start justify-center overflow-y-auto bg-black/50 px-4 py-4"
            @click.self="confirmCloseTemplateEditor()"
            @keydown.escape.window="if(showTemplateEditModal) confirmCloseTemplateEditor()">
            <div class="w-full max-w-3xl rounded-lg bg-white shadow-xl flex flex-col overflow-hidden"
                style="max-height: calc(100vh - 2rem);"
                data-testid="template-edit-panel">
                <div class="flex items-center justify-between gap-3 border-b bg-white px-4 py-3 flex-shrink-0">
                    <h3 class="text-lg font-semibold" x-text="templateEditTarget ? '编辑模板' : '新建自定义模板'"></h3>
                    <button @click="confirmCloseTemplateEditor()"
                        data-testid="template-edit-close"
                        class="text-slate-400 hover:text-slate-600 text-xl">&times;</button>
                </div>
                <div class="flex-1 min-h-0 overflow-y-auto px-4 py-4 space-y-4"
                    data-testid="template-edit-body">
                    <template x-if="!templateEditTarget">
                        <div>
                            <label class="text-xs text-slate-600">基于</label>
                            <select x-model="templateEditSourceId"
                                data-testid="template-edit-source-select"
                                @change="loadTemplateForEdit(templateEditSourceId)"
                                class="w-full rounded border px-3 py-2 text-sm mt-1">
                                <option :value="null">空白模板</option>
                                <template x-for="tpl in templates" :key="tpl.id">
                                    <option :value="tpl.id" x-text="tpl.name + (tpl.type === 'preset' ? ' [预置]' : ' [自定义]')"></option>
                                </template>
                            </select>
                        </div>
                    </template>
                    <div>
                        <label class="text-xs text-slate-600">模板名称</label>
                        <input type="text" x-model="templateEditName"
                            data-testid="template-edit-name-input"
                            class="w-full rounded border px-3 py-2 text-sm mt-1" placeholder="输入模板名称">
                    </div>
                    <div class="rounded border overflow-hidden">
                        <div class="flex items-center justify-between gap-3 border-b bg-slate-50 px-3 py-2">
                            <div>
                                <div class="text-xs font-medium text-slate-600">分类树</div>
                                <div class="mt-1 text-xs text-slate-400" x-text="templateEditSummary"></div>
                            </div>
                            <button @click="addTemplateTreeNode()"
                                data-testid="template-edit-add-root"
                                class="text-xs text-blue-500 hover:underline flex-shrink-0">+ 添加一级分类</button>
                        </div>
                        <div class="p-3 space-y-2"
                            data-testid="template-edit-tree">
                            <template x-for="(node, pi) in templateEditTree" :key="pi">
                                <div class="space-y-1">
                                    <div class="flex items-center gap-2">
                                        <input type="text" x-model="templateEditTree[pi].name"
                                            class="flex-1 rounded border px-2 py-1 text-sm">
                                        <button @click="addTemplateTreeNode(pi)"
                                            class="text-xs text-blue-500 hover:underline flex-shrink-0">+ 子分类</button>
                                        <button @click="removeTemplateTreeNode(pi)"
                                            class="text-xs text-rose-500 hover:underline flex-shrink-0">删除</button>
                                    </div>
                                    <template x-if="node.children && node.children.length > 0">
                                        <div class="ml-6 space-y-1">
                                            <template x-for="(child, ci) in node.children" :key="ci">
                                                <div class="flex items-center gap-2">
                                                    <input type="text"
                                                        x-model="templateEditTree[pi].children[ci].name"
                                                        class="flex-1 rounded border px-2 py-1 text-sm">
                                                    <button @click="removeTemplateTreeNode(pi, ci)"
                                                        class="text-xs text-rose-500 hover:underline flex-shrink-0">删除</button>
                                                </div>
                                            </template>
                                        </div>
                                    </template>
                                </div>
                            </template>
                            <template x-if="templateEditTree.length === 0">
                                <div data-testid="template-edit-empty-state"
                                    class="text-xs text-slate-400 text-center py-4">暂无分类，点击上方按钮添加</div>
                            </template>
                        </div>
                    </div>
                </div>
                <div class="flex justify-end gap-2 border-t bg-white px-4 py-3 flex-shrink-0"
                    data-testid="template-edit-footer">
                    <button @click="confirmCloseTemplateEditor()"
                        data-testid="template-edit-cancel"
                        class="rounded border px-4 py-2 text-sm hover:bg-slate-50">取消</button>
                    <button @click="saveTemplateEdit()"
                        data-testid="template-edit-save"
                        class="rounded bg-slate-900 text-white px-4 py-2 text-sm hover:bg-slate-800">保存</button>
                </div>
            </div>
        </div>

        <style>
            @media (max-width: 767px) {
                [data-testid="organize-preview-desktop-table"] {
                    display: none;
                }
            }

            @media (min-width: 768px) {
                [data-testid="organize-preview-mobile-list"] {
                    display: none;
                }
            }
        </style>

        <!-- AI Organize Modal -->
        <div x-cloak x-show="showAIOrganizeModal"
            data-testid="ai-organize-modal"
            class="fixed inset-0 z-50 overflow-y-auto bg-black/50 p-4 sm:flex sm:items-center sm:justify-center"
            @click.self="closeOrganizeModal()">
            <div class="mx-auto flex w-full max-w-2xl flex-col overflow-hidden rounded-lg bg-white shadow-xl"
                style="max-height: calc(100vh - 2rem);"
                data-testid="ai-organize-panel">
                <div class="flex flex-shrink-0 items-center justify-between border-b px-4 py-3">
                    <h3 class="text-lg font-semibold">🤖 AI 整理</h3>
                    <button @click="closeOrganizeModal()"
                        data-testid="ai-organize-close"
                        class="text-slate-400 hover:text-slate-600 text-xl">&times;</button>
                </div>
                <div class="min-h-0 flex-1 overflow-y-auto px-4 py-4" data-testid="ai-organize-body">

                    <!-- Phase: idle - Scope selection -->
                    <template x-if="organizePhase === 'idle'">
                        <div class="space-y-3" data-testid="organize-phase-idle">
                            <p class="text-sm text-slate-500">AI 将基于当前分类模板，批量匹配书签到最合适的分类。</p>
                            <template x-if="!activeTemplate">
                                <div class="text-xs text-amber-600 bg-amber-50 border border-amber-200 rounded px-3 py-2">请先在左侧「分类模板」中选择并应用一个模板，AI 整理依赖模板中的分类结构。</div>
                            </template>
                            <div>
                                <label class="text-xs text-slate-600">整理范围</label>
                                <select x-model="organizeScope" class="w-full rounded border px-3 py-2 text-sm mt-1">
                                    <option value="all">全部书签</option>
                                    <option value="uncategorized">未分类书签</option>
                                    <option value="category">指定分类</option>
                                </select>
                            </div>
                            <template x-if="organizeScope === 'category'">
                                <div>
                                    <label class="text-xs text-slate-600">选择分类</label>
                                    <select x-model="organizeScopeCategoryId" class="w-full rounded border px-3 py-2 text-sm mt-1">
                                        <template x-for="cat in categories" :key="cat.id">
                                            <option :value="cat.id" x-text="cat.name"></option>
                                        </template>
                                    </select>
                                </div>
                            </template>
                            <div class="flex justify-end gap-2">
                                <button @click="closeOrganizeModal()"
                                    data-testid="organize-idle-cancel"
                                    class="rounded border px-4 py-2 text-sm hover:bg-slate-50">取消</button>
                                <button @click="startOrganize()"
                                    data-testid="organize-start"
                                    class="rounded bg-slate-900 text-white px-4 py-2 text-sm hover:bg-slate-800">开始整理</button>
                            </div>
                        </div>
                    </template>

                    <!-- Phase: assigning - Progress -->
                    <template x-if="organizePhase === 'assigning'">
                        <div class="space-y-4" data-testid="organize-phase-assigning">
                            <div class="flex flex-col items-center gap-3">
                                <div class="text-xs text-slate-400" data-testid="organize-phase-title">批量归类中</div>
                                <div class="relative w-24 h-24">
                                    <svg class="w-24 h-24 transform -rotate-90">
                                        <circle cx="48" cy="48" r="40" stroke="#e2e8f0" stroke-width="8" fill="none" />
                                        <circle cx="48" cy="48" r="40" stroke="#8b5cf6" stroke-width="8" fill="none"
                                            stroke-linecap="round" :stroke-dasharray="251.2"
                                            :stroke-dashoffset="251.2 - (organizeProgress.batches_total > 0 ? 251.2 * organizeProgress.batches_done / organizeProgress.batches_total : 0)" />
                                    </svg>
                                    <div class="absolute inset-0 flex items-center justify-center">
                                        <span class="text-xl font-bold text-purple-600"
                                            x-text="organizeProgress.batches_total > 0 ? Math.floor(organizeProgress.batches_done / organizeProgress.batches_total * 100) + '%' : '准备中...'"></span>
                                    </div>
                                </div>
                                <div class="text-center">
                                    <div class="text-sm font-medium text-slate-700"
                                        data-testid="organize-progress-summary"
                                        x-text="'批次 ' + organizeProgress.batches_done + ' / ' + organizeProgress.batches_total"></div>
                                    <div class="text-xs text-slate-400 mt-1">AI 正在批量归类书签...</div>
                                </div>
                            </div>
                            <div class="flex justify-center gap-2 pt-2 border-t">
                                <button @click="cancelOrganize()"
                                    data-testid="organize-assigning-cancel"
                                    class="flex items-center gap-1 rounded-lg border border-rose-200 text-rose-600 px-4 py-2 text-sm hover:bg-rose-50 transition">
                                    <span>✕</span> 取消
                                </button>
                                <a x-show="organizePlan?.job_id" :href="'/jobs/' + organizePlan?.job_id"
                                    data-testid="organize-open-job"
                                    class="flex items-center gap-1 rounded-lg border border-slate-200 text-slate-600 px-4 py-2 text-sm hover:bg-slate-50 transition">
                                    查看任务详情
                                </a>
                            </div>
                        </div>
                    </template>

                    <!-- Phase: failed / error -->
                    <template x-if="organizePhase === 'failed' || organizePhase === 'error'">
                        <div class="space-y-3" :data-testid="organizePhase === 'error' ? 'organize-phase-error' : 'organize-phase-failed'">
                            <div class="flex flex-col items-center gap-2 py-4">
                                <div class="w-12 h-12 rounded-full bg-rose-100 flex items-center justify-center text-2xl"
                                    x-text="organizePhase === 'error' ? '!' : '✕'"></div>
                                <div class="text-sm font-medium text-rose-700"
                                    data-testid="organize-phase-title"
                                    x-text="organizePhase === 'error' ? '归类中断' : '归类失败'"></div>
                                <div class="text-xs text-slate-500 text-center"
                                    data-testid="organize-phase-message"
                                    x-text="organizePlan?.message || (organizePhase === 'error' ? '整理任务已中断，请查看任务详情或在修复问题后重试' : '连续多个批次失败，请检查 AI 配置后重试')"></div>
                            </div>
                            <template x-if="organizePhase === 'failed' && organizeProgress.failed_batch_ids && organizeProgress.failed_batch_ids.length > 0">
                                <div class="text-xs text-slate-400 text-center" data-testid="organize-failed-batches">
                                    失败批次: <span x-text="organizeProgress.failed_batch_ids.join(', ')"></span>
                                </div>
                            </template>
                            <div class="flex justify-center gap-2 pt-2 border-t">
                                <button @click="cancelOrganize()"
                                    :data-testid="organizePhase === 'error' ? 'organize-error-cancel' : 'organize-failed-cancel'"
                                    class="rounded border px-4 py-2 text-sm hover:bg-slate-50">放弃</button>
                                <button @click="retryOrganize()"
                                    :data-testid="organizePhase === 'error' ? 'organize-error-retry' : 'organize-failed-retry'"
                                    class="rounded bg-slate-900 text-white px-4 py-2 text-sm hover:bg-slate-800">重试</button>
                            </div>
                        </div>
                    </template>

                    <!-- Phase: completed (preview/applied) -->
                    <template x-if="organizePhase === 'preview' || organizePhase === 'applied'">
                        <div class="space-y-4" :data-testid="organizePhase === 'applied' ? 'organize-phase-applied' : 'organize-phase-preview'">
                            <template x-if="organizePhase === 'preview' && organizePreviewGuardActive">
                                <div data-testid="organize-preview-guard"
                                    class="rounded-lg border border-amber-200 bg-amber-50 px-4 py-3">
                                    <div class="text-sm font-medium text-amber-800"
                                        x-text="getOrganizePreviewGuardTitle()"></div>
                                    <div class="mt-1 text-xs leading-5 text-amber-700"
                                        x-text="getOrganizePreviewGuardMessage()"></div>
                                </div>
                            </template>
                            <div class="flex flex-col items-center gap-3">
                                <div class="relative w-24 h-24">
                                    <svg class="w-24 h-24 transform -rotate-90">
                                        <circle cx="48" cy="48" r="40" stroke="#e2e8f0" stroke-width="8" fill="none" />
                                        <circle cx="48" cy="48" r="40" stroke="#22c55e" stroke-width="8" fill="none"
                                            stroke-linecap="round" stroke-dasharray="251.2" stroke-dashoffset="0" />
                                    </svg>
                                    <div class="absolute inset-0 flex items-center justify-center">
                                        <span class="text-xl font-bold text-green-600">100%</span>
                                    </div>
                                </div>
                                <div class="text-center">
                                    <div class="text-sm font-medium text-green-700"
                                        data-testid="organize-phase-title"
                                        x-text="organizePhase === 'applied' ? '分类已应用' : '分类完成'"></div>
                                    <div class="text-xs text-slate-500 mt-1"
                                        data-testid="organize-progress-summary"
                                        x-text="'共处理 ' + organizeProgress.batches_done + ' / ' + organizeProgress.batches_total + ' 批次'"></div>
                                    <template x-if="organizeProgress.needs_review_count > 0">
                                        <div class="text-xs text-amber-600 mt-1"
                                            data-testid="organize-needs-review"
                                            x-text="organizeProgress.needs_review_count + ' 个书签待审核'"></div>
                                    </template>
                                </div>
                            </div>
                            <template x-if="organizePhase === 'preview'">
                                <div class="rounded-lg border border-slate-200 overflow-hidden" data-testid="organize-preview-list">
                                    <div class="flex flex-col gap-3 border-b bg-slate-50 px-4 py-3 md:flex-row md:items-center md:justify-between">
                                        <div>
                                            <div class="text-sm font-medium text-slate-700">逐条处理建议</div>
                                            <div class="mt-1 text-xs text-slate-500">
                                                共 <span x-text="organizePlan?.assignments?.length || organizeAssignmentTotal"></span> 条，
                                                应用 <span class="font-medium text-slate-700" x-text="getOrganizeSelectedApplyCount()"></span> 条，
                                                放弃 <span class="font-medium text-slate-700" x-text="getOrganizeSelectedDiscardCount()"></span> 条
                                            </div>
                                        </div>
                                        <div class="flex items-center gap-2">
                                            <button @click="applyAllOrganizePlan()"
                                                data-testid="organize-preview-apply-all"
                                                class="rounded border px-3 py-1.5 text-sm hover:bg-white">全部应用</button>
                                        </div>
                                    </div>
                                    <div class="overflow-auto" style="max-height: min(320px, 45vh);">
                                        <div data-testid="organize-preview-mobile-list" class="space-y-3 p-3">
                                            <template x-if="organizeAssignmentLoading">
                                                <div class="rounded-lg border border-dashed px-3 py-8 text-center text-sm text-slate-400">加载中...</div>
                                            </template>
                                            <template x-if="!organizeAssignmentLoading && organizeAssignments.length === 0">
                                                <div class="rounded-lg border border-dashed px-3 py-8 text-center text-sm text-slate-400">暂无分类建议数据</div>
                                            </template>
                                            <template x-for="assignment in organizeAssignments" :key="'mobile-' + assignment.bookmark_id">
                                                <article class="rounded-lg border p-3 shadow-sm"
                                                    :class="getOrganizeSelectionAction(assignment) === 'discard' ? 'border-slate-200 bg-slate-50' : 'border-emerald-100 bg-white'">
                                                    <div class="text-sm font-medium leading-6 text-slate-700 break-words" x-text="assignment.title"></div>
                                                    <div class="mt-1 text-xs leading-5 text-slate-400 break-all" x-text="assignment.url || '—'"></div>
                                                    <div class="mt-3 grid grid-cols-[72px_1fr] gap-x-3 gap-y-2 text-xs">
                                                        <div class="font-medium text-slate-500">当前分类</div>
                                                        <div class="text-slate-600 break-words" x-text="assignment.current_category || '未分类'"></div>
                                                        <div class="font-medium text-slate-500">建议分类</div>
                                                        <div>
                                                            <template x-if="assignment.category_path">
                                                                <span class="inline-flex rounded bg-blue-100 px-2 py-0.5 text-xs text-blue-700 break-words" x-text="assignment.category_path"></span>
                                                            </template>
                                                            <template x-if="!assignment.category_path">
                                                                <span class="text-amber-600">未匹配到分类，默认放弃</span>
                                                            </template>
                                                        </div>
                                                    </div>
                                                    <div class="mt-3 grid grid-cols-2 gap-2">
                                                        <button @click="setOrganizeSelectionAction(assignment.bookmark_id, 'apply', assignment)"
                                                            :disabled="!canApplyOrganizeAssignment(assignment)"
                                                            :class="getOrganizeSelectionAction(assignment) === 'apply' ? 'border-emerald-600 bg-emerald-600 text-white' : 'border-slate-300 bg-white text-slate-600'"
                                                            class="rounded border px-3 py-2 text-xs disabled:cursor-not-allowed disabled:border-slate-200 disabled:bg-slate-100 disabled:text-slate-400">应用</button>
                                                        <button @click="setOrganizeSelectionAction(assignment.bookmark_id, 'discard', assignment)"
                                                            :class="getOrganizeSelectionAction(assignment) === 'discard' ? 'border-slate-900 bg-slate-900 text-white' : 'border-slate-300 bg-white text-slate-600'"
                                                            class="rounded border px-3 py-2 text-xs">放弃</button>
                                                    </div>
                                                </article>
                                            </template>
                                        </div>
                                        <div data-testid="organize-preview-desktop-table">
                                            <table class="w-full min-w-[720px] table-fixed">
                                                <thead class="sticky top-0 bg-white">
                                                    <tr class="text-left text-xs font-semibold text-slate-600">
                                                        <th class="w-[34%] px-3 py-2">书签</th>
                                                        <th class="w-[18%] px-3 py-2">当前分类</th>
                                                        <th class="w-[22%] px-3 py-2">建议分类</th>
                                                        <th class="w-[26%] px-3 py-2">处理</th>
                                                    </tr>
                                                </thead>
                                                <tbody class="divide-y">
                                                    <template x-if="organizeAssignmentLoading">
                                                        <tr>
                                                            <td colspan="4" class="px-3 py-8 text-center text-sm text-slate-400">加载中...</td>
                                                        </tr>
                                                    </template>
                                                    <template x-if="!organizeAssignmentLoading && organizeAssignments.length === 0">
                                                        <tr>
                                                            <td colspan="4" class="px-3 py-8 text-center text-sm text-slate-400">暂无分类建议数据</td>
                                                        </tr>
                                                    </template>
                                                    <template x-for="assignment in organizeAssignments" :key="'desktop-' + assignment.bookmark_id">
                                                        <tr :class="getOrganizeSelectionAction(assignment) === 'discard' ? 'bg-slate-50' : ''">
                                                            <td class="px-3 py-3 align-top">
                                                                <div class="text-sm text-slate-700 truncate" x-text="assignment.title"></div>
                                                                <div class="mt-1 text-xs text-slate-400 truncate" x-text="assignment.url || '—'"></div>
                                                            </td>
                                                            <td class="px-3 py-3 align-top">
                                                                <span class="text-xs text-slate-500" x-text="assignment.current_category || '未分类'"></span>
                                                            </td>
                                                            <td class="px-3 py-3 align-top">
                                                                <template x-if="assignment.category_path">
                                                                    <span class="inline-flex rounded bg-blue-100 px-2 py-0.5 text-xs text-blue-700" x-text="assignment.category_path"></span>
                                                                </template>
                                                                <template x-if="!assignment.category_path">
                                                                    <span class="text-xs text-amber-600">未匹配到分类，默认放弃</span>
                                                                </template>
                                                            </td>
                                                            <td class="px-3 py-3 align-top">
                                                                <div class="flex items-center gap-2">
                                                                    <button @click="setOrganizeSelectionAction(assignment.bookmark_id, 'apply', assignment)"
                                                                        :disabled="!canApplyOrganizeAssignment(assignment)"
                                                                        :class="getOrganizeSelectionAction(assignment) === 'apply' ? 'border-emerald-600 bg-emerald-600 text-white' : 'border-slate-300 bg-white text-slate-600'"
                                                                        class="rounded border px-3 py-1 text-xs disabled:cursor-not-allowed disabled:border-slate-200 disabled:bg-slate-100 disabled:text-slate-400">应用</button>
                                                                    <button @click="setOrganizeSelectionAction(assignment.bookmark_id, 'discard', assignment)"
                                                                        :class="getOrganizeSelectionAction(assignment) === 'discard' ? 'border-slate-900 bg-slate-900 text-white' : 'border-slate-300 bg-white text-slate-600'"
                                                                        class="rounded border px-3 py-1 text-xs">放弃</button>
                                                                </div>
                                                            </td>
                                                        </tr>
                                                    </template>
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                    <div class="flex items-center justify-between border-t bg-slate-50 px-4 py-3 text-xs text-slate-500"
                                        x-show="organizeAssignmentTotalPages > 1">
                                        <div>第 <span x-text="organizeAssignmentPage"></span> / <span x-text="organizeAssignmentTotalPages"></span> 页</div>
                                        <div class="flex items-center gap-2">
                                            <button @click="loadOrganizeAssignmentsPage(organizeAssignmentPage - 1)"
                                                :disabled="organizeAssignmentPage <= 1"
                                                data-testid="organize-preview-prev-page"
                                                class="rounded border bg-white px-3 py-1 text-sm text-slate-600 disabled:cursor-not-allowed disabled:text-slate-300">上一页</button>
                                            <button @click="loadOrganizeAssignmentsPage(organizeAssignmentPage + 1)"
                                                :disabled="organizeAssignmentPage >= organizeAssignmentTotalPages"
                                                data-testid="organize-preview-next-page"
                                                class="rounded border bg-white px-3 py-1 text-sm text-slate-600 disabled:cursor-not-allowed disabled:text-slate-300">下一页</button>
                                        </div>
                                    </div>
                                </div>
                            </template>
                            <div class="flex justify-center gap-2 pt-2 border-t">
                                <template x-if="organizePhase === 'preview'">
                                    <button @click="cancelOrganize()"
                                        data-testid="organize-preview-discard"
                                        class="rounded border px-4 py-2 text-sm hover:bg-slate-50">放弃建议</button>
                                </template>
                                <template x-if="organizePhase === 'preview'">
                                    <button @click="applyOrganizePlan()"
                                        data-testid="organize-preview-apply"
                                        class="rounded bg-slate-900 text-white px-4 py-2 text-sm hover:bg-slate-800">应用已选</button>
                                </template>
                                <template x-if="organizePhase === 'applied'">
                                    <button @click="closeOrganizeModal()"
                                        data-testid="organize-complete-close"
                                        class="rounded border px-4 py-2 text-sm hover:bg-slate-50">关闭</button>
                                </template>
                                <a x-show="organizePlan?.job_id" :href="'/jobs/' + organizePlan?.job_id"
                                    data-testid="organize-open-job"
                                    class="flex items-center gap-1 rounded-lg border border-slate-200 text-slate-600 px-4 py-2 text-sm hover:bg-slate-50 transition">
                                    查看任务详情
                                </a>
                            </div>
                        </div>
                    </template>
                </div>
            </div>
        </div>
        <div x-cloak x-show="showImportProgressModal" data-testid="import-progress-modal"
            class="fixed inset-0 z-50 flex items-center justify-center bg-black/50">
            <div class="w-full max-w-md rounded-lg bg-white p-4 shadow-xl" data-testid="import-progress-panel">
                <div class="flex items-center justify-between mb-3">
                    <h3 class="text-lg font-semibold">📥 导入进度</h3>
                    <button @click="closeImportProgressModal()" data-testid="import-progress-close"
                        class="text-slate-400 hover:text-slate-600 text-xl">&times;</button>
                </div>
                <div class="space-y-3 text-center">
                    <div class="text-2xl" data-testid="import-progress-value" x-text="importProgress + '%'"></div>
                    <div class="w-full h-2 bg-slate-200 rounded overflow-hidden" data-testid="import-progress-bar">
                        <div class="h-full bg-blue-500 transition-all" data-testid="import-progress-fill" :style="'width:' + importProgress + '%'"></div>
                    </div>
                    <div class="text-sm text-slate-500" data-testid="import-progress-summary"
                        x-text="importStats.processed + '/' + importStats.total + ' (成功:' + importStats.inserted + ' 失败:' + importStats.failed + ')'">
                    </div>
                    <button @click="cancelImportJob()" data-testid="import-progress-cancel"
                        class="rounded border border-rose-300 text-rose-600 px-4 py-2 text-sm hover:bg-rose-50">取消导入</button>
                </div>
            </div>
        </div>

        <!-- Backup Modal -->
        <div x-cloak x-show="showBackupModal" data-testid="backup-modal" class="fixed inset-0 z-50 flex items-center justify-center bg-black/50"
            @click.self="closeBackupModal()">
            <div class="w-full max-w-2xl rounded-lg bg-white p-4 shadow-xl max-h-[90vh] overflow-y-auto"
                data-testid="backup-panel">
                <div class="flex items-center justify-between mb-3">
                    <h3 class="text-lg font-semibold">💾 备份管理</h3>
                    <button @click="closeBackupModal()" data-testid="backup-close"
                        class="text-slate-400 hover:text-slate-600 text-xl">&times;</button>
                </div>
                <div class="flex justify-between items-center mb-4">
                    <button @click="runBackupNow()" data-testid="backup-run-now"
                        class="rounded bg-slate-900 text-white px-4 py-2 text-sm hover:bg-slate-800">立即备份</button>
                    <a href="/settings" class="text-sm text-blue-500 hover:underline">备份设置</a>
                </div>
                <div class="space-y-4">
                    <!-- Manual Backups -->
                    <div>
                        <h4 class="text-sm font-medium text-slate-700 mb-2">手动备份</h4>
                        <template x-if="manualBackups.length === 0">
                            <div class="text-xs text-slate-400">暂无手动备份</div>
                        </template>
                        <div class="space-y-1">
                            <template x-for="b in manualBackups" :key="b.name">
                                <div class="flex items-center justify-between p-2 bg-slate-50 rounded text-sm"
                                    data-testid="manual-backup-row"
                                    :data-backup-name="b.name">
                                    <span data-testid="backup-name" x-text="b.name"></span>
                                    <div class="flex items-center gap-2 text-xs">
                                        <span class="text-slate-400" x-text="formatBytes(b.size)"></span>
                                        <button @click="restoreBackup(b.name)" data-testid="backup-restore-button"
                                            class="text-blue-500 hover:underline">还原</button>
                                        <button @click="deleteBackup(b.name)" data-testid="backup-delete-button"
                                            class="text-rose-500 hover:underline">删除</button>
                                    </div>
                                </div>
                            </template>
                        </div>
                    </div>
                    <!-- Auto Backups -->
                    <div>
                        <h4 class="text-sm font-medium text-slate-700 mb-2">自动备份</h4>
                        <template x-if="autoBackups.length === 0">
                            <div class="text-xs text-slate-400">暂无自动备份</div>
                        </template>
                        <div class="space-y-1">
                            <template x-for="b in autoBackups" :key="b.name">
                                <div class="flex items-center justify-between p-2 bg-slate-50 rounded text-sm"
                                    data-testid="auto-backup-row"
                                    :data-backup-name="b.name">
                                    <span data-testid="backup-name" x-text="b.name"></span>
                                    <div class="flex items-center gap-2 text-xs">
                                        <span class="text-slate-400" x-text="formatBytes(b.size)"></span>
                                        <button @click="restoreBackup(b.name)" data-testid="backup-restore-button"
                                            class="text-blue-500 hover:underline">还原</button>
                                        <button @click="deleteBackup(b.name)" data-testid="backup-delete-button"
                                            class="text-rose-500 hover:underline">删除</button>
                                    </div>
                                </div>
                            </template>
                        </div>
                    </div>
                    <!-- Upload Restore -->
                    <div class="pt-4 border-t">
                        <h4 class="text-sm font-medium text-slate-700 mb-2">上传还原</h4>
                        <form @submit.prevent="uploadAndRestore($event)" data-testid="backup-upload-form">
                            <input type="file" name="file" accept=".db" class="text-xs mb-2"
                                data-testid="backup-upload-input">
                            <button type="submit" data-testid="backup-upload-submit"
                                class="rounded border px-3 py-1.5 text-sm hover:bg-slate-50">上传并还原</button>
                        </form>
                    </div>
                </div>
                <div class="flex justify-end mt-4">
                    <button @click="closeBackupModal()" data-testid="backup-footer-close"
                        class="rounded border px-4 py-2 text-sm hover:bg-slate-50">关闭</button>
                </div>
            </div>
        </div>

        <!-- Export Modal -->
        <div x-cloak x-show="showExportModal" data-testid="export-modal" class="fixed inset-0 z-50 flex items-center justify-center bg-black/50"
            @click.self="closeExportModal()">
            <div class="w-full max-w-md rounded-lg bg-white p-4 shadow-xl" data-testid="export-panel">
                <div class="flex items-center justify-between mb-3">
                    <h3 class="text-lg font-semibold">📤 导出书签</h3>
                    <button @click="closeExportModal()" data-testid="export-close"
                        class="text-slate-400 hover:text-slate-600 text-xl">&times;</button>
                </div>
                <div class="space-y-3">
                    <div>
                        <label class="text-xs text-slate-600">导出范围</label>
                        <select x-model="exportScope" data-testid="export-scope-select" class="w-full rounded border px-3 py-2 text-sm mt-1">
                            <option value="all">全部书签</option>
                            <option value="uncategorized">仅未分类</option>
                            <option value="selected" x-show="selectedCategories.length > 0">选中分类</option>
                        </select>
                    </div>
                    <div>
                        <label class="text-xs text-slate-600">导出格式</label>
                        <select x-model="exportFormat" data-testid="export-format-select" class="w-full rounded border px-3 py-2 text-sm mt-1">
                            <option value="html">浏览器书签 (HTML)</option>
                            <option value="json">JSON</option>
                        </select>
                    </div>
                </div>
                <div class="flex justify-end gap-2 mt-4">
                    <button @click="closeExportModal()" data-testid="export-cancel"
                        class="rounded border px-4 py-2 text-sm hover:bg-slate-50">取消</button>
                    <a :href="getExportUrl()" @click="closeExportModal()" data-testid="export-download"
                        class="rounded bg-slate-900 text-white px-4 py-2 text-sm hover:bg-slate-800 inline-block">下载</a>
                </div>
            </div>
        </div>

        <!-- Category Manager Modal (Phase 2) -->
        <div x-cloak x-show="showCategoryManager"
             x-transition:enter="transition ease-out duration-300"
             x-transition:enter-start="opacity-0 translate-y-4"
             x-transition:enter-end="opacity-100 translate-y-0"
             data-testid="category-manager-modal"
             class="category-manager-modal custom-scrollbar">
            
            <div class="category-manager-header sticky top-0 z-10">
                <div class="flex items-center gap-4 flex-1">
                    <h2 class="text-xl font-bold flex items-center gap-2">
                        <span class="p-1.5 rounded-lg bg-blue-100 text-blue-600">📁</span>
                        分类管理
                    </h2>
                    <div class="relative flex-1 max-w-md">
                        <input type="text"
                               id="category-manager-search"
                               x-model="categoryManagerSearch"
                               @input="$nextTick(() => syncCategoryManagerSortState())"
                               data-testid="category-manager-search"
                               placeholder="搜索分类名称..."
                               aria-label="搜索分类"
                               class="w-full pl-10 pr-4 py-2 rounded-full border border-slate-200 focus:ring-2 focus:ring-blue-500/20 text-sm">
                        <span class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-400" aria-hidden="true">🔍</span>
                    </div>
                </div>
                
                <div class="flex items-center gap-3">
                    <button @click="openCreateCategoryModal(null)" data-testid="category-manager-add-root" class="btn-primary btn-sm flex items-center gap-1">
                        <span>➕</span> 添加一级分类
                    </button>
                    <button @click="closeCategoryManager()"
                        data-testid="close-category-manager"
                        class="p-2 rounded-full hover:bg-slate-100 text-slate-500 transition-colors">
                        <span class="text-xl">✕</span>
                    </button>
                </div>
            </div>

            <div class="category-manager-content bg-slate-50">
                <div class="mb-4 flex flex-wrap items-center justify-between gap-2 text-xs text-slate-500">
                    <p>拖拽卡片可调整一级分类顺序，导航栏会按相同顺序显示。</p>
                    <p x-show="categoryManagerSearch.trim()" class="text-amber-600">搜索时已禁用拖拽排序</p>
                </div>

                <template x-if="filteredCategoryTree.length === 0">
                    <div class="flex flex-col items-center justify-center py-20 text-slate-400">
                        <span class="text-4xl mb-4">🔍</span>
                        <p>未找到相关分类</p>
                    </div>
                </template>

                <div class="category-manager-grid" x-ref="categoryManagerGrid">
                    <template x-for="cat in filteredCategoryTree" :key="cat.id">
                        <div class="card p-4 hover:shadow-md transition-all group overflow-visible flex flex-col category-card"
                             data-testid="category-drag-card" :data-category-id="cat.id">
                            <div class="flex items-center justify-between mb-4">
                                <div class="flex items-center gap-3 min-w-0">
                                    <div class="drag-handle"
                                         :class="categoryManagerSearch.trim() ? 'pointer-events-none opacity-30' : 'cursor-move text-slate-300 hover:text-slate-500'"
                                         :title="categoryManagerSearch.trim() ? '清空搜索后可拖拽排序' : '拖拽排序'">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="12" r="1"/><circle cx="9" cy="5" r="1"/><circle cx="9" cy="19" r="1"/><circle cx="15" cy="12" r="1"/><circle cx="15" cy="5" r="1"/><circle cx="15" cy="19" r="1"/></svg>
                                    </div>
                                    <input type="checkbox"
                                           :value="cat.id"
                                           x-model="selectedCategories"
                                           class="w-4 h-4 rounded border-slate-300 text-blue-600 focus:ring-blue-500"
                                           :aria-label="'选择 ' + cat.name">
                                    <span class="text-2xl" x-text="cat.icon || '📁'" :style="cat.color ? 'color:' + cat.color : ''"></span>
                                    <div class="min-w-0">
                                        <h3 class="font-bold text-slate-800 truncate" x-text="cat.name" :class="cat.isMatch ? 'bg-amber-100' : ''"></h3>
                                        <p class="text-xs text-slate-400" x-text="cat.count + ' 个书签'"></p>
                                    </div>
                                </div>
                                <div class="flex items-center gap-1 opacity-0 group-hover:opacity-100 transition-opacity">
                                    <button @click="openCreateCategoryModal(cat.id)" class="p-1.5 text-slate-400 hover:text-blue-500" title="添加子分类">➕</button>
                                    <button @click="openCategoryStyleModal(cat)" class="p-1.5 text-slate-400 hover:text-blue-500" title="设置样式">🎨</button>
                                    <button @click="deleteCategory(cat.id)"
                                            data-testid="delete-category-button"
                                            :data-category-id="cat.id"
                                            class="p-1.5 text-slate-400 hover:text-rose-500"
                                            title="删除分类">🗑️</button>
                                </div>
                            </div>

                            <!-- Children -->
                            <template x-if="cat.children && cat.children.length > 0">
                                <div class="space-y-2 mt-2 pl-4 border-l-2 border-slate-100">
                                    <template x-for="child in cat.children" :key="child.id">
                                        <div class="flex items-center justify-between py-1 px-2 rounded hover:bg-slate-50 text-sm group/child">
                                            <div class="flex items-center gap-2 min-w-0">
                                                <input type="checkbox"
                                                       :value="child.id"
                                                       x-model="selectedCategories"
                                                       class="w-3.5 h-3.5 rounded border-slate-300 text-blue-600 focus:ring-blue-500"
                                                       :aria-label="'选择 ' + (child.displayName || child.name)">
                                                <span x-text="child.icon || '📄'" :style="child.color ? 'color:' + child.color : ''"></span>
                                                <span class="truncate text-slate-600" x-text="child.displayName || child.name" :class="child.isMatch ? 'bg-amber-100' : ''"></span>
                                                <span class="text-[10px] text-slate-400" x-text="'(' + child.count + ')'"></span>
                                            </div>
                                            <div class="flex items-center gap-1 opacity-0 group-hover/child:opacity-100 transition-opacity">
                                                <button @click="openCategoryStyleModal(child)" class="p-1 text-slate-400 hover:text-blue-500" title="设置样式">🎨</button>
                                                <button @click="deleteCategory(child.id)"
                                                        data-testid="delete-category-button"
                                                        :data-category-id="child.id"
                                                        class="p-1 text-slate-400 hover:text-rose-500"
                                                        title="删除">🗑️</button>
                                            </div>
                                        </div>
                                    </template>
                                </div>
                            </template>
                        </div>
                    </template>
                </div>
            </div>

            <!-- Selection Actions Overlay -->
            <template x-if="selectedCategories.length > 0">
                <div class="fixed bottom-8 left-1/2 -translate-x-1/2 bg-slate-900 text-white px-6 py-4 rounded-full shadow-2xl flex items-center gap-6 z-50 animate-fade-in"
                     data-testid="category-bulk-actions">
                    <span class="text-sm font-medium">已选择 <span x-text="selectedCategories.length" class="text-blue-400"></span> 个分类</span>
                    <div class="h-4 w-[1px] bg-slate-700"></div>
                    <div class="flex items-center gap-4">
                        <button @click="batchDeleteCategories()" class="text-sm text-rose-400 hover:text-rose-300 font-medium">🗑️ 批量删除</button>
                        <button @click="checkSelectedCategories()" class="text-sm text-blue-400 hover:text-blue-300 font-medium">🔍 批量检查</button>
                        <button @click="openExportSelectedCategories()" class="text-sm text-emerald-400 hover:text-emerald-300 font-medium">📤 批量导出</button>
                    </div>
                    <div class="h-4 w-[1px] bg-slate-700"></div>
                    <button @click="selectedCategories = []" class="text-xs text-slate-400 hover:text-white">取消选择</button>
                </div>
            </template>
        </div>
    </div>
    <script src="/public/lib/alpine.min.js"></script>
</body>

</html>

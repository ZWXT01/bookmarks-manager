                            </div>
                        </div>
                        <div class="flex justify-end gap-2">
                            <button @click="closeCheckModal()"
                                class="rounded border px-4 py-2 text-sm hover:bg-slate-50">取消</button>
                            <button @click="startCheck()"
                                class="rounded bg-slate-900 text-white px-4 py-2 text-sm hover:bg-slate-800">开始检查</button>
                        </div>
                    </div>
                </template>
                <template x-if="checkJobId && !checkJobDone">
                    <div class="space-y-4">
                        <!-- Circular Progress Ring -->
                        <div class="flex flex-col items-center gap-3">
                            <div class="relative w-24 h-24">
                                <svg class="w-24 h-24 transform -rotate-90">
                                    <circle cx="48" cy="48" r="40" stroke="#e2e8f0" stroke-width="8" fill="none" />
                                    <circle cx="48" cy="48" r="40" stroke="#3b82f6" stroke-width="8" fill="none"
                                        stroke-linecap="round" :stroke-dasharray="251.2"
                                        :stroke-dashoffset="251.2 - (251.2 * checkProgress / 100)" />
                                </svg>
                                <div class="absolute inset-0 flex items-center justify-center">
                                    <span class="text-xl font-bold text-blue-600" x-text="checkProgress + '%'"></span>
                                </div>
                            </div>
                            <div class="text-center">
                                <div class="text-sm font-medium text-slate-700"
                                    x-text="'处理中 ' + checkStats.processed + ' / ' + checkStats.total"></div>
                                <div class="text-xs text-slate-400 mt-1">正在检查书签可用性...</div>
                            </div>
                        </div>
                        <!-- Action Buttons -->
                        <div class="flex justify-center gap-3 pt-2 border-t">
                            <button @click="cancelCheckJob()"
                                class="flex items-center gap-1 rounded-lg border border-rose-200 text-rose-600 px-4 py-2 text-sm hover:bg-rose-50 transition">
                                <span>✕</span> 取消任务
                            </button>
                            <a :href="'/jobs/' + checkJobId"
                                class="flex items-center gap-1 rounded-lg border px-4 py-2 text-sm hover:bg-slate-50 transition">
                                <span>📋</span> 查看详情
                            </a>
                        </div>
                    </div>
                </template>
                <template x-if="checkJobDone">
                    <div class="space-y-4">
                        <!-- 100% Completion Ring -->
                        <div class="flex flex-col items-center gap-3">
                            <div class="relative w-24 h-24">
                                <svg class="w-24 h-24 transform -rotate-90">
                                    <circle cx="48" cy="48" r="40" stroke="#e2e8f0" stroke-width="8" fill="none" />
                                    <circle cx="48" cy="48" r="40" stroke="#10b981" stroke-width="8" fill="none"
                                        stroke-linecap="round" stroke-dasharray="251.2" stroke-dashoffset="0" />
                                </svg>
                                <div class="absolute inset-0 flex items-center justify-center">
                                    <span class="text-xl font-bold text-emerald-600">100%</span>
                                </div>
                            </div>
                            <div class="text-emerald-600 font-medium">✅ 检查完成</div>
                            <div class="text-sm text-slate-500"
                                x-text="'成功: ' + checkStats.inserted + '  失败: ' + checkStats.failed"></div>
                        </div>
                        <!-- Action Buttons -->
                        <div class="flex justify-center gap-3 pt-2 border-t">
                            <a :href="'/jobs/' + checkJobId"
                                class="flex items-center gap-1 rounded-lg border px-4 py-2 text-sm hover:bg-slate-50 transition">
                                <span>📋</span> 查看详情
                            </a>
                            <button @click="closeCheckModal()"
                                class="rounded-lg border px-4 py-2 text-sm hover:bg-slate-50 transition">关闭</button>
                        </div>
                    </div>
                </template>
            </div>
        </div>

        <!-- Template Select Modal -->
        <div x-cloak x-show="showTemplateSelectModal"
            data-testid="template-select-modal"
            class="fixed inset-0 z-50 flex items-start justify-center overflow-y-auto bg-black/50 px-4 py-4"
            @click.self="showTemplateSelectModal = false">
            <div class="w-full max-w-3xl rounded-lg bg-white shadow-xl flex flex-col overflow-hidden"
                style="max-height: calc(100vh - 2rem);"
                data-testid="template-select-panel"
                x-data="{ activeTab: 'custom' }">
                <div class="flex items-center justify-between gap-3 border-b bg-white px-4 py-3 flex-shrink-0">
                    <h3 class="text-lg font-semibold">🗂️ 选择分类模板</h3>
                    <button @click="showTemplateSelectModal = false"
                        data-testid="template-select-close"
                        class="text-slate-400 hover:text-slate-600 text-xl">&times;</button>
                </div>
                <!-- Tab Navigation -->
                <div class="flex border-b px-4 pt-2 flex-shrink-0" role="tablist" aria-label="模板类型">
                    <button @click="activeTab = 'custom'"
                        data-testid="template-tab-custom"
                        class="px-4 py-2 text-sm font-medium transition-colors"
                        role="tab" :aria-selected="activeTab === 'custom'" aria-controls="tabpanel-custom" id="tab-custom"
                        :class="activeTab === 'custom' ? 'border-b-2 border-blue-500 text-blue-600' : 'text-slate-500 hover:text-slate-700'">
                        📁 我的模板
                    </button>
                    <button @click="activeTab = 'preset'"
                        data-testid="template-tab-preset"
                        class="px-4 py-2 text-sm font-medium transition-colors"
                        role="tab" :aria-selected="activeTab === 'preset'" aria-controls="tabpanel-preset" id="tab-preset"
                        :class="activeTab === 'preset' ? 'border-b-2 border-blue-500 text-blue-600' : 'text-slate-500 hover:text-slate-700'">
                        📚 模板库
                    </button>
                </div>
                <div class="flex-1 min-h-0 overflow-y-auto px-4 py-4"
                    data-testid="template-select-body">
                    <!-- Tab 1: My Templates (Custom) -->
                    <div x-show="activeTab === 'custom'" class="space-y-2" role="tabpanel" id="tabpanel-custom" aria-labelledby="tab-custom">
                        <template x-for="tpl in customTemplates" :key="tpl.id">
                            <div class="flex items-center justify-between border rounded-lg px-3 py-2 hover:bg-slate-50"
                                data-testid="custom-template-card"
                                :data-template-id="tpl.id"
                                :class="tpl.is_active === 1 ? 'border-blue-300 bg-blue-50' : ''">
                                <div class="flex-1 min-w-0">
                                    <div class="flex items-center gap-2">
                                        <span class="text-sm font-medium truncate"
                                              data-testid="template-card-name"
                                              x-text="tpl.name"></span>
                                        <template x-if="tpl.is_active === 1">
                                            <span class="text-xs px-1.5 py-0.5 rounded bg-blue-100 text-blue-600">当前</span>
                                        </template>
                                    </div>
                                    <div class="text-xs text-slate-400 mt-0.5" x-text="tpl.top_level_count + ' 个一级分类'"></div>
                                </div>
                                <div class="flex items-center gap-1 ml-2 flex-shrink-0">
                                    <button @click="openTemplateEditor(tpl.id)"
                                        data-testid="edit-template-button"
                                        class="text-xs px-2 py-1 rounded border hover:bg-slate-100">编辑</button>
                                    <template x-if="tpl.is_active === 1">
                                        <div class="relative group cursor-not-allowed">
                                            <button aria-disabled="true" tabindex="-1"
                                                class="text-xs px-2 py-1 rounded border border-rose-200 text-rose-500 opacity-50 pointer-events-none">删除</button>
                                            <div class="absolute bottom-full left-1/2 -translate-x-1/2 mb-1 px-2 py-1 text-xs text-white bg-slate-800 rounded whitespace-nowrap opacity-0 group-hover:opacity-100 pointer-events-none transition-opacity">
                                                无法删除正在使用中的模板
                                            </div>
                                        </div>
                                    </template>
                                    <template x-if="tpl.is_active !== 1">
                                        <button @click="if(await AppDialog.confirm('确定删除此模板？')) deleteTemplate(tpl.id)"
                                            class="text-xs px-2 py-1 rounded border border-rose-200 text-rose-500 hover:bg-rose-50">删除</button>
                                    </template>
                                    <template x-if="tpl.is_active !== 1">
                                        <button @click="if(await AppDialog.confirm('应用模板将替换当前所有分类，所有书签将变为未分类。如果该模板曾使用过，书签分布将自动恢复。\n\n确定应用此模板？')) { applyTemplate(tpl.id); showTemplateSelectModal = false; }"
                                            data-testid="apply-template-button"
                                            class="text-xs px-2 py-1 rounded bg-blue-500 text-white hover:bg-blue-600"
                                            :disabled="templateApplying">应用</button>
                                    </template>
                                </div>
                            </div>
                        </template>
                        <template x-if="customTemplates.length === 0">
                            <div class="text-xs text-slate-400 text-center py-8">暂无自定义模板，可从模板库创建</div>
                        </template>
                    </div>
                    <!-- Tab 2: Template Library (Preset) -->
                    <div x-show="activeTab === 'preset'" class="space-y-2" role="tabpanel" id="tabpanel-preset" aria-labelledby="tab-preset">
                        <template x-for="tpl in presetTemplates" :key="tpl.id">
                            <div class="border rounded-lg overflow-hidden"
                                data-testid="preset-template-card"
                                :data-template-id="tpl.id"
                                :class="tpl.is_active === 1 ? 'border-violet-300 bg-violet-50' : ''">
                                <div class="flex items-center justify-between px-3 py-2 hover:bg-slate-50">
                                    <div class="flex-1 min-w-0">
                                        <div class="flex items-center gap-2">
                                            <span class="text-sm font-medium truncate"
                                                data-testid="preset-template-card-name"
                                                x-text="tpl.name"></span>
                                            <span class="text-xs px-1.5 py-0.5 rounded bg-violet-100 text-violet-600">预置</span>
                                            <template x-if="tpl.is_active === 1">
                                                <span class="text-xs px-1.5 py-0.5 rounded bg-blue-100 text-blue-600">当前使用</span>
                                            </template>
                                        </div>
                                        <div class="text-xs text-slate-400 mt-0.5" x-text="tpl.top_level_count + ' 个一级分类'"></div>
                                        <div class="text-[11px] text-slate-500 mt-1">可直接创建自定义副本，或创建后立即应用到当前分类体系。</div>
                                    </div>
                                    <div class="flex items-center gap-1 ml-2 flex-shrink-0">
                                        <button @click="toggleTemplatePreview(tpl.id)"
                                            data-testid="preview-preset-template-button"
                                            class="text-xs px-2 py-1 rounded border hover:bg-slate-100"
                                            :class="templatePreviewId === tpl.id ? 'bg-slate-100' : ''"
                                            :aria-expanded="templatePreviewId === tpl.id"
                                            :aria-controls="'preview-panel-' + tpl.id">
                                            <span x-text="templatePreviewId === tpl.id ? '👁️ 收起' : '👁️ 预览'"></span>
                                        </button>
                                        <button @click="instantiatePresetTemplate(tpl.id)"
                                            data-testid="copy-preset-template-button"
                                            class="text-xs px-2 py-1 rounded border border-slate-300 text-slate-600 hover:bg-slate-100 disabled:opacity-50 disabled:cursor-not-allowed"
                                            :disabled="templateApplying">创建副本</button>
                                        <button @click="instantiatePresetTemplate(tpl.id, { applyAfterCreate: true })"
                                            data-testid="use-preset-template-button"
                                            class="text-xs px-2 py-1 rounded bg-violet-600 text-white hover:bg-violet-700 disabled:opacity-50 disabled:cursor-not-allowed"
                                            :disabled="templateApplying">创建并应用</button>
                                    </div>
                                </div>
                                <!-- Preview Tree -->
                                <div x-show="templatePreviewId === tpl.id"
                                    :id="'preview-panel-' + tpl.id"
                                    class="border-t bg-slate-50 px-3 py-2">
                                    <div class="text-xs font-medium text-slate-600 mb-2">分类结构预览：</div>
                                    <div class="space-y-1 max-h-60 overflow-y-auto">
                                        <template x-for="node in templatePreviewTree" :key="node.name">
                                            <div>
                                                <div class="text-xs font-medium text-slate-700">
                                                    <span aria-hidden="true">📁 </span>
                                                    <span x-text="node.name"></span>
                                                </div>
                                                <template x-if="node.children && node.children.length > 0">
                                                    <div class="ml-4 mt-0.5 space-y-0.5">
                                                        <template x-for="child in node.children" :key="child.name">
                                                            <div class="text-xs text-slate-600">
                                                                <span aria-hidden="true">└─ </span>
                                                                <span x-text="child.name"></span>
                                                            </div>
                                                        </template>
                                                    </div>
                                                </template>
                                            </div>
                                        </template>
                                    </div>
                                </div>
                            </div>
                        </template>
                        <template x-if="presetTemplates.length === 0">
                            <div class="text-xs text-slate-400 text-center py-8">暂无预置模板</div>
                        </template>
                    </div>
                </div>
                <!-- New Template Button -->
                <div class="border-t bg-white px-4 py-3 flex-shrink-0">
                    <button @click="openNewTemplateEditor()"
                        data-testid="template-select-new-custom"
                        class="w-full rounded border border-dashed border-slate-300 px-3 py-1.5 text-xs text-slate-500 hover:border-slate-400 hover:text-slate-700">+ 新建自定义模板</button>
                </div>
            </div>
        </div>

        <!-- Batch Size Selector Modal -->
        <div x-cloak x-show="showBatchSizeModal"
            class="fixed inset-0 z-50 flex items-center justify-center bg-black/50"
            @click.self="classifyBatchTemplateId = null; showBatchSizeModal = false">
            <div class="w-full max-w-xs rounded-lg bg-white p-4 shadow-xl">
                <div class="flex items-center justify-between mb-3">
                    <h3 class="text-lg font-semibold">🤖 AI 分类</h3>
                    <button @click="classifyBatchTemplateId = null; showBatchSizeModal = false"
                        class="text-slate-400 hover:text-slate-600 text-xl">&times;</button>
                </div>
                <p class="text-sm text-slate-500 mb-3">将对 <span class="font-medium text-slate-700" x-text="classifyBatchIds.length"></span> 个书签进行 AI 分类</p>
                <template x-if="!activeTemplate && !classifyBatchTemplateId">
                    <div class="mb-3 text-xs text-amber-600 bg-amber-50 border border-amber-200 rounded px-3 py-2">请先选择一个分类模板；可直接使用模板库中的预置模板，或使用当前已应用模板。</div>
                </template>
                <div class="mb-4">
                    <label class="text-xs text-slate-600">每批处理数量</label>
                    <select x-model.number="classifyBatchSize" class="w-full rounded border px-3 py-2 text-sm mt-1">
                        <option value="10">10</option>
                        <option value="20">20（推荐）</option>
                        <option value="30">30</option>
                    </select>
                </div>
                <div class="flex justify-end gap-2">
                    <button @click="classifyBatchTemplateId = null; showBatchSizeModal = false"
                        class="rounded border px-4 py-2 text-sm hover:bg-slate-50">取消</button>
                    <button @click="startClassifyBatch(classifyBatchIds, classifyBatchSize)"
                        :disabled="!activeTemplate && !classifyBatchTemplateId"
                        class="rounded bg-slate-900 text-white px-4 py-2 text-sm hover:bg-slate-800"
                        :class="{'opacity-50 cursor-not-allowed': !activeTemplate && !classifyBatchTemplateId}">开始分类</button>
                </div>
            </div>
        </div>

        <!-- Add Bookmark Modal -->
        <div x-cloak x-show="showAddBookmarkModal"
            class="fixed inset-0 z-50 flex items-center justify-center bg-black/50"
            @click.self="closeAddBookmarkModal()"
            @keydown.escape.window="if(showAddBookmarkModal) closeAddBookmarkModal()">
            <div class="w-full max-w-md rounded-lg bg-white p-6 shadow-xl">
                <div class="flex items-center justify-between mb-4">
                    <h3 class="text-lg font-semibold">➕ 添加书签</h3>
                    <button @click="closeAddBookmarkModal()"
                        class="text-slate-400 hover:text-slate-600 text-xl">&times;</button>
                </div>
                <div class="space-y-3">
                    <div>
                        <label class="text-xs text-slate-600 block mb-1">URL *</label>
                        <input type="text" x-model="newBookmark.url" placeholder="https://example.com"
                            class="w-full rounded border px-3 py-2 text-sm"
                            @keydown.enter="addBookmark()">
                    </div>
                    <div>
                        <label class="text-xs text-slate-600 block mb-1">标题（可选）</label>
                        <input type="text" x-model="newBookmark.title" placeholder="书签标题"
                            class="w-full rounded border px-3 py-2 text-sm"
                            @keydown.enter="addBookmark()">
                    </div>
                    <div>
                        <label class="text-xs text-slate-600 block mb-1">分类</label>
                        <select x-model="newBookmark.category_id"
                            data-testid="add-bookmark-category-select"
                            class="w-full rounded border px-3 py-2 text-sm">
                            <option value="">未分类</option>
                            <template x-for="cat in categories" :key="cat.id">
                                <option :value="cat.id" x-text="cat.name"></option>
                            </template>
                        </select>
                    </div>
                    <div class="flex justify-end gap-2 pt-2">
                        <button @click="closeAddBookmarkModal()"
                            class="btn-secondary btn-sm">取消</button>
                        <button @click="addBookmark()"
                            class="btn-primary btn-sm">添加</button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Template Edit Modal -->
        <div x-cloak x-show="showTemplateEditModal"
            data-testid="template-edit-modal"
            class="fixed inset-0 z-50 flex items-start justify-center overflow-y-auto bg-black/50 px-4 py-4"
            @click.self="confirmCloseTemplateEditor()"
            @keydown.escape.window="if(showTemplateEditModal) confirmCloseTemplateEditor()">
            <div class="w-full max-w-3xl rounded-lg bg-white shadow-xl flex flex-col overflow-hidden"
                style="max-height: calc(100vh - 2rem);"
                data-testid="template-edit-panel">
                <div class="flex items-center justify-between gap-3 border-b bg-white px-4 py-3 flex-shrink-0">
                    <h3 class="text-lg font-semibold" x-text="templateEditTarget ? '编辑模板' : '新建自定义模板'"></h3>
                    <button @click="confirmCloseTemplateEditor()"
                        data-testid="template-edit-close"
                        class="text-slate-400 hover:text-slate-600 text-xl">&times;</button>
                </div>
                <div class="flex-1 min-h-0 overflow-y-auto px-4 py-4 space-y-4"
                    data-testid="template-edit-body">
                    <template x-if="!templateEditTarget">
                        <div>
                            <label class="text-xs text-slate-600">基于</label>
                            <select x-model="templateEditSourceId"
                                data-testid="template-edit-source-select"
                                @change="loadTemplateForEdit(templateEditSourceId)"
                                class="w-full rounded border px-3 py-2 text-sm mt-1">
                                <option :value="null">空白模板</option>
                                <template x-for="tpl in templates" :key="tpl.id">
                                    <option :value="tpl.id" x-text="tpl.name + (tpl.type === 'preset' ? ' [预置]' : ' [自定义]')"></option>
                                </template>
                            </select>
                        </div>
                    </template>
                    <div>
                        <label class="text-xs text-slate-600">模板名称</label>
                        <input type="text" x-model="templateEditName"
                            data-testid="template-edit-name-input"
                            class="w-full rounded border px-3 py-2 text-sm mt-1" placeholder="输入模板名称">
                    </div>
                    <div class="rounded border overflow-hidden">
                        <div class="flex items-center justify-between gap-3 border-b bg-slate-50 px-3 py-2">
                            <div>
                                <div class="text-xs font-medium text-slate-600">分类树</div>
                                <div class="mt-1 text-xs text-slate-400" x-text="templateEditSummary"></div>
                            </div>
                            <button @click="addTemplateTreeNode()"
                                data-testid="template-edit-add-root"
                                class="text-xs text-blue-500 hover:underline flex-shrink-0">+ 添加一级分类</button>
                        </div>
                        <div class="p-3 space-y-2"
                            data-testid="template-edit-tree">
                            <template x-for="(node, pi) in templateEditTree" :key="pi">
                                <div class="space-y-1">
                                    <div class="flex items-center gap-2">
                                        <input type="text" x-model="templateEditTree[pi].name"
                                            class="flex-1 rounded border px-2 py-1 text-sm">
                                        <button @click="addTemplateTreeNode(pi)"
                                            class="text-xs text-blue-500 hover:underline flex-shrink-0">+ 子分类</button>
                                        <button @click="removeTemplateTreeNode(pi)"
                                            class="text-xs text-rose-500 hover:underline flex-shrink-0">删除</button>
                                    </div>
                                    <template x-if="node.children && node.children.length > 0">
                                        <div class="ml-6 space-y-1">
                                            <template x-for="(child, ci) in node.children" :key="ci">
                                                <div class="flex items-center gap-2">
                                                    <input type="text"
                                                        x-model="templateEditTree[pi].children[ci].name"
                                                        class="flex-1 rounded border px-2 py-1 text-sm">
                                                    <button @click="removeTemplateTreeNode(pi, ci)"
                                                        class="text-xs text-rose-500 hover:underline flex-shrink-0">删除</button>
                                                </div>
                                            </template>
                                        </div>
                                    </template>
                                </div>
                            </template>
                            <template x-if="templateEditTree.length === 0">
                                <div data-testid="template-edit-empty-state"
                                    class="text-xs text-slate-400 text-center py-4">暂无分类，点击上方按钮添加</div>
                            </template>
                        </div>
                    </div>
                </div>
                <div class="flex justify-end gap-2 border-t bg-white px-4 py-3 flex-shrink-0"
                    data-testid="template-edit-footer">
                    <button @click="confirmCloseTemplateEditor()"
                        data-testid="template-edit-cancel"
                        class="rounded border px-4 py-2 text-sm hover:bg-slate-50">取消</button>
                    <button @click="saveTemplateEdit()"
                        data-testid="template-edit-save"
                        class="rounded bg-slate-900 text-white px-4 py-2 text-sm hover:bg-slate-800">保存</button>
                </div>
            </div>
        </div>

        <!-- AI Organize Modal -->
        <div x-cloak x-show="showAIOrganizeModal"
            class="fixed inset-0 z-50 flex items-center justify-center bg-black/50"
            @click.self="closeOrganizeModal()">
            <div class="w-full max-w-2xl rounded-lg bg-white p-4 shadow-xl max-h-[90vh] overflow-y-auto">
                <div class="flex items-center justify-between mb-3">
                    <h3 class="text-lg font-semibold">🤖 AI 整理</h3>
                    <button @click="closeOrganizeModal()"
                        class="text-slate-400 hover:text-slate-600 text-xl">&times;</button>
                </div>

                <!-- Phase: idle - Scope selection -->
                <template x-if="organizePhase === 'idle'">
                    <div class="space-y-3">
                        <p class="text-sm text-slate-500">AI 将基于当前分类模板，批量匹配书签到最合适的分类。</p>
                        <template x-if="!activeTemplate">
                            <div class="text-xs text-amber-600 bg-amber-50 border border-amber-200 rounded px-3 py-2">请先在左侧「分类模板」中选择并应用一个模板，AI 整理依赖模板中的分类结构。</div>
                        </template>
                        <div>
                            <label class="text-xs text-slate-600">整理范围</label>
                            <select x-model="organizeScope" class="w-full rounded border px-3 py-2 text-sm mt-1">
                                <option value="all">全部书签</option>
                                <option value="uncategorized">未分类书签</option>
                                <option value="category">指定分类</option>
                            </select>
                        </div>
                        <template x-if="organizeScope === 'category'">
                            <div>
                                <label class="text-xs text-slate-600">选择分类</label>
                                <select x-model="organizeScopeCategoryId" class="w-full rounded border px-3 py-2 text-sm mt-1">
                                    <template x-for="cat in categories" :key="cat.id">
                                        <option :value="cat.id" x-text="cat.name"></option>
                                    </template>
                                </select>
                            </div>
                        </template>
                        <div class="flex justify-end gap-2">
                            <button @click="closeOrganizeModal()"
                                class="rounded border px-4 py-2 text-sm hover:bg-slate-50">取消</button>
                            <button @click="startOrganize()"
                                class="rounded bg-slate-900 text-white px-4 py-2 text-sm hover:bg-slate-800">开始整理</button>
                        </div>
                    </div>
                </template>

                <!-- Phase: assigning - Progress -->
                <template x-if="organizePhase === 'assigning'">
                    <div class="space-y-4">
                        <div class="flex flex-col items-center gap-3">
                            <div class="text-xs text-slate-400">批量归类中</div>
                            <div class="relative w-24 h-24">
                                <svg class="w-24 h-24 transform -rotate-90">
                                    <circle cx="48" cy="48" r="40" stroke="#e2e8f0" stroke-width="8" fill="none" />
                                    <circle cx="48" cy="48" r="40" stroke="#8b5cf6" stroke-width="8" fill="none"
                                        stroke-linecap="round" :stroke-dasharray="251.2"
                                        :stroke-dashoffset="251.2 - (organizeProgress.batches_total > 0 ? 251.2 * organizeProgress.batches_done / organizeProgress.batches_total : 0)" />
                                </svg>
                                <div class="absolute inset-0 flex items-center justify-center">
                                    <span class="text-xl font-bold text-purple-600"
                                        x-text="organizeProgress.batches_total > 0 ? Math.floor(organizeProgress.batches_done / organizeProgress.batches_total * 100) + '%' : '准备中...'"></span>
                                </div>
                            </div>
                            <div class="text-center">
                                <div class="text-sm font-medium text-slate-700"
                                    x-text="'批次 ' + organizeProgress.batches_done + ' / ' + organizeProgress.batches_total"></div>
                                <div class="text-xs text-slate-400 mt-1">AI 正在批量归类书签...</div>
                            </div>
                        </div>
                        <div class="flex justify-center gap-2 pt-2 border-t">
                            <button @click="cancelOrganize()"
                                class="flex items-center gap-1 rounded-lg border border-rose-200 text-rose-600 px-4 py-2 text-sm hover:bg-rose-50 transition">
                                <span>✕</span> 取消
                            </button>
                            <a x-show="organizePlan?.job_id" :href="'/jobs/' + organizePlan?.job_id"
                                class="flex items-center gap-1 rounded-lg border border-slate-200 text-slate-600 px-4 py-2 text-sm hover:bg-slate-50 transition">
                                查看任务详情
                            </a>
                        </div>
                    </div>
                </template>

                <!-- Phase: failed -->
                <template x-if="organizePhase === 'failed'">
                    <div class="space-y-3">
                        <div class="flex flex-col items-center gap-2 py-4">
                            <div class="w-12 h-12 rounded-full bg-rose-100 flex items-center justify-center text-2xl">✕</div>
                            <div class="text-sm font-medium text-rose-700">归类失败</div>
                            <div class="text-xs text-slate-500 text-center" x-text="organizePlan?.message || '连续多个批次失败，请检查 AI 配置后重试'"></div>
                        </div>
                        <template x-if="organizeProgress.failed_batch_ids && organizeProgress.failed_batch_ids.length > 0">
                            <div class="text-xs text-slate-400 text-center">
                                失败批次: <span x-text="organizeProgress.failed_batch_ids.join(', ')"></span>
                            </div>
                        </template>
                        <div class="flex justify-center gap-2 pt-2 border-t">
                            <button @click="cancelOrganize()"
                                class="rounded border px-4 py-2 text-sm hover:bg-slate-50">放弃</button>
                            <button @click="retryOrganize()"
                                class="rounded bg-slate-900 text-white px-4 py-2 text-sm hover:bg-slate-800">重试</button>
                        </div>
                    </div>
                </template>

                <!-- Phase: completed (preview/applied) -->
                <template x-if="organizePhase === 'preview' || organizePhase === 'applied'">
                    <div class="space-y-4">
                        <div class="flex flex-col items-center gap-3">
                            <div class="relative w-24 h-24">
                                <svg class="w-24 h-24 transform -rotate-90">
                                    <circle cx="48" cy="48" r="40" stroke="#e2e8f0" stroke-width="8" fill="none" />
                                    <circle cx="48" cy="48" r="40" stroke="#22c55e" stroke-width="8" fill="none"
                                        stroke-linecap="round" stroke-dasharray="251.2" stroke-dashoffset="0" />
                                </svg>
                                <div class="absolute inset-0 flex items-center justify-center">
                                    <span class="text-xl font-bold text-green-600">100%</span>
                                </div>
                            </div>
                            <div class="text-center">
                                <div class="text-sm font-medium text-green-700" x-text="organizePhase === 'applied' ? '分类已应用' : '分类完成'"></div>
                                <div class="text-xs text-slate-500 mt-1"
                                    x-text="'共处理 ' + organizeProgress.batches_done + ' / ' + organizeProgress.batches_total + ' 批次'"></div>
                                <template x-if="organizeProgress.needs_review_count > 0">
                                    <div class="text-xs text-amber-600 mt-1" x-text="organizeProgress.needs_review_count + ' 个书签待审核'"></div>
                                </template>
                            </div>
                        </div>
                        <div class="flex justify-center gap-2 pt-2 border-t">
                            <button @click="closeOrganizeModal()"
                                class="rounded border px-4 py-2 text-sm hover:bg-slate-50">关闭</button>
                            <a x-show="organizePlan?.job_id" :href="'/jobs/' + organizePlan?.job_id"
                                class="flex items-center gap-1 rounded-lg border border-slate-200 text-slate-600 px-4 py-2 text-sm hover:bg-slate-50 transition">
                                查看任务详情
                            </a>
                        </div>
                    </div>
                </template>

            </div>
        </div>
        <div x-cloak x-show="showImportProgressModal"
            class="fixed inset-0 z-50 flex items-center justify-center bg-black/50">
            <div class="w-full max-w-md rounded-lg bg-white p-4 shadow-xl">
                <div class="flex items-center justify-between mb-3">
                    <h3 class="text-lg font-semibold">📥 导入进度</h3>
                    <button @click="closeImportProgressModal()"
                        class="text-slate-400 hover:text-slate-600 text-xl">&times;</button>
                </div>
                <div class="space-y-3 text-center">
                    <div class="text-2xl" x-text="importProgress + '%'"></div>
                    <div class="w-full h-2 bg-slate-200 rounded overflow-hidden">
                        <div class="h-full bg-blue-500 transition-all" :style="'width:' + importProgress + '%'"></div>
                    </div>
                    <div class="text-sm text-slate-500"
                        x-text="importStats.processed + '/' + importStats.total + ' (成功:' + importStats.inserted + ' 失败:' + importStats.failed + ')'">
                    </div>
                    <button @click="cancelImportJob()"
                        class="rounded border border-rose-300 text-rose-600 px-4 py-2 text-sm hover:bg-rose-50">取消导入</button>
                </div>
            </div>
        </div>

        <!-- Backup Modal -->
        <div x-cloak x-show="showBackupModal" class="fixed inset-0 z-50 flex items-center justify-center bg-black/50"
            @click.self="closeBackupModal()">
            <div class="w-full max-w-2xl rounded-lg bg-white p-4 shadow-xl max-h-[90vh] overflow-y-auto">
                <div class="flex items-center justify-between mb-3">
                    <h3 class="text-lg font-semibold">💾 备份管理</h3>
                    <button @click="closeBackupModal()"
                        class="text-slate-400 hover:text-slate-600 text-xl">&times;</button>
                </div>
                <div class="flex justify-between items-center mb-4">
                    <button @click="runBackupNow()"
                        class="rounded bg-slate-900 text-white px-4 py-2 text-sm hover:bg-slate-800">立即备份</button>
                    <a href="/settings" class="text-sm text-blue-500 hover:underline">备份设置</a>
                </div>
                <div class="space-y-4">
                    <!-- Manual Backups -->
                    <div>
                        <h4 class="text-sm font-medium text-slate-700 mb-2">手动备份</h4>
                        <template x-if="manualBackups.length === 0">
                            <div class="text-xs text-slate-400">暂无手动备份</div>
                        </template>
                        <div class="space-y-1">
                            <template x-for="b in manualBackups" :key="b.name">
                                <div class="flex items-center justify-between p-2 bg-slate-50 rounded text-sm">
                                    <span x-text="b.name"></span>
                                    <div class="flex items-center gap-2 text-xs">
                                        <span class="text-slate-400" x-text="formatBytes(b.size)"></span>
                                        <button @click="restoreBackup(b.name)"
                                            class="text-blue-500 hover:underline">还原</button>
                                        <button @click="deleteBackup(b.name)"
                                            class="text-rose-500 hover:underline">删除</button>
                                    </div>
                                </div>
                            </template>
                        </div>
                    </div>
                    <!-- Auto Backups -->
                    <div>
                        <h4 class="text-sm font-medium text-slate-700 mb-2">自动备份</h4>
                        <template x-if="autoBackups.length === 0">
                            <div class="text-xs text-slate-400">暂无自动备份</div>
                        </template>
                        <div class="space-y-1">
                            <template x-for="b in autoBackups" :key="b.name">
                                <div class="flex items-center justify-between p-2 bg-slate-50 rounded text-sm">
                                    <span x-text="b.name"></span>
                                    <div class="flex items-center gap-2 text-xs">
                                        <span class="text-slate-400" x-text="formatBytes(b.size)"></span>
                                        <button @click="restoreBackup(b.name)"
                                            class="text-blue-500 hover:underline">还原</button>
                                        <button @click="deleteBackup(b.name)"
                                            class="text-rose-500 hover:underline">删除</button>
                                    </div>
                                </div>
                            </template>
                        </div>
                    </div>
                    <!-- Upload Restore -->
                    <div class="pt-4 border-t">
                        <h4 class="text-sm font-medium text-slate-700 mb-2">上传还原</h4>
                        <form @submit.prevent="uploadAndRestore($event)">
                            <input type="file" name="file" accept=".db" class="text-xs mb-2">
                            <button type="submit"
                                class="rounded border px-3 py-1.5 text-sm hover:bg-slate-50">上传并还原</button>
                        </form>
                    </div>
                </div>
                <div class="flex justify-end mt-4">
                    <button @click="closeBackupModal()"
                        class="rounded border px-4 py-2 text-sm hover:bg-slate-50">关闭</button>
                </div>
            </div>
        </div>

        <!-- Export Modal -->
        <div x-cloak x-show="showExportModal" class="fixed inset-0 z-50 flex items-center justify-center bg-black/50"
            @click.self="closeExportModal()">
            <div class="w-full max-w-md rounded-lg bg-white p-4 shadow-xl">
                <div class="flex items-center justify-between mb-3">
                    <h3 class="text-lg font-semibold">📤 导出书签</h3>
                    <button @click="closeExportModal()"
                        class="text-slate-400 hover:text-slate-600 text-xl">&times;</button>
                </div>
                <div class="space-y-3">
                    <div>
                        <label class="text-xs text-slate-600">导出范围</label>
                        <select x-model="exportScope" class="w-full rounded border px-3 py-2 text-sm mt-1">
                            <option value="all">全部书签</option>
                            <option value="uncategorized">仅未分类</option>
                            <option value="selected" x-show="selectedCategories.length > 0">选中分类</option>
                        </select>
                    </div>
                    <div>
                        <label class="text-xs text-slate-600">导出格式</label>
                        <select x-model="exportFormat" class="w-full rounded border px-3 py-2 text-sm mt-1">
                            <option value="html">浏览器书签 (HTML)</option>
                            <option value="json">JSON</option>
                        </select>
                    </div>
                </div>
                <div class="flex justify-end gap-2 mt-4">
                    <button @click="closeExportModal()"
                        class="rounded border px-4 py-2 text-sm hover:bg-slate-50">取消</button>
                    <a :href="getExportUrl()" @click="closeExportModal()"
                        class="rounded bg-slate-900 text-white px-4 py-2 text-sm hover:bg-slate-800 inline-block">下载</a>
                </div>
            </div>
        </div>

        <!-- Category Manager Modal (Phase 2) -->
        <div x-cloak x-show="showCategoryManager"
             x-transition:enter="transition ease-out duration-300"
             x-transition:enter-start="opacity-0 translate-y-4"
             x-transition:enter-end="opacity-100 translate-y-0"
             data-testid="category-manager-modal"
             class="category-manager-modal custom-scrollbar">
            
            <div class="category-manager-header sticky top-0 z-10">
                <div class="flex items-center gap-4 flex-1">
                    <h2 class="text-xl font-bold flex items-center gap-2">
                        <span class="p-1.5 rounded-lg bg-blue-100 text-blue-600">📁</span>
                        分类管理
                    </h2>
                    <div class="relative flex-1 max-w-md">
                        <input type="text"
                               id="category-manager-search"
                               x-model="categoryManagerSearch"
                               @input="$nextTick(() => syncCategoryManagerSortState())"
                               placeholder="搜索分类名称..."
                               aria-label="搜索分类"
                               class="w-full pl-10 pr-4 py-2 rounded-full border border-slate-200 focus:ring-2 focus:ring-blue-500/20 text-sm">
                        <span class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-400" aria-hidden="true">🔍</span>
                    </div>
                </div>
                
                <div class="flex items-center gap-3">
                    <button @click="openCreateCategoryModal(null)" class="btn-primary btn-sm flex items-center gap-1">
                        <span>➕</span> 添加一级分类
                    </button>
                    <button @click="closeCategoryManager()"
                        data-testid="close-category-manager"
                        class="p-2 rounded-full hover:bg-slate-100 text-slate-500 transition-colors">
                        <span class="text-xl">✕</span>
                    </button>
                </div>
            </div>

            <div class="category-manager-content bg-slate-50">
                <div class="mb-4 flex flex-wrap items-center justify-between gap-2 text-xs text-slate-500">
                    <p>拖拽卡片可调整一级分类顺序，导航栏会按相同顺序显示。</p>
                    <p x-show="categoryManagerSearch.trim()" class="text-amber-600">搜索时已禁用拖拽排序</p>
                </div>

                <template x-if="filteredCategoryTree.length === 0">
                    <div class="flex flex-col items-center justify-center py-20 text-slate-400">
                        <span class="text-4xl mb-4">🔍</span>
                        <p>未找到相关分类</p>
                    </div>
                </template>

                <div class="category-manager-grid" x-ref="categoryManagerGrid">
                    <template x-for="cat in filteredCategoryTree" :key="cat.id">
                        <div class="card p-4 hover:shadow-md transition-all group overflow-visible flex flex-col category-card"
                             data-testid="category-drag-card" :data-category-id="cat.id">
                            <div class="flex items-center justify-between mb-4">
                                <div class="flex items-center gap-3 min-w-0">
                                    <div class="drag-handle"
                                         :class="categoryManagerSearch.trim() ? 'pointer-events-none opacity-30' : 'cursor-move text-slate-300 hover:text-slate-500'"
                                         :title="categoryManagerSearch.trim() ? '清空搜索后可拖拽排序' : '拖拽排序'">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="12" r="1"/><circle cx="9" cy="5" r="1"/><circle cx="9" cy="19" r="1"/><circle cx="15" cy="12" r="1"/><circle cx="15" cy="5" r="1"/><circle cx="15" cy="19" r="1"/></svg>
                                    </div>
                                    <input type="checkbox"
                                           :value="cat.id"
                                           x-model="selectedCategories"
                                           class="w-4 h-4 rounded border-slate-300 text-blue-600 focus:ring-blue-500"
                                           :aria-label="'选择 ' + cat.name">
                                    <span class="text-2xl" x-text="cat.icon || '📁'" :style="cat.color ? 'color:' + cat.color : ''"></span>
                                    <div class="min-w-0">
                                        <h3 class="font-bold text-slate-800 truncate" x-text="cat.name" :class="cat.isMatch ? 'bg-amber-100' : ''"></h3>
                                        <p class="text-xs text-slate-400" x-text="cat.count + ' 个书签'"></p>
                                    </div>
                                </div>
                                <div class="flex items-center gap-1 opacity-0 group-hover:opacity-100 transition-opacity">
                                    <button @click="openCreateCategoryModal(cat.id)" class="p-1.5 text-slate-400 hover:text-blue-500" title="添加子分类">➕</button>
                                    <button @click="openCategoryStyleModal(cat)" class="p-1.5 text-slate-400 hover:text-blue-500" title="设置样式">🎨</button>
                                    <button @click="deleteCategory(cat.id)"
                                            data-testid="delete-category-button"
                                            :data-category-id="cat.id"
                                            class="p-1.5 text-slate-400 hover:text-rose-500"
                                            title="删除分类">🗑️</button>
                                </div>
                            </div>

                            <!-- Children -->
                            <template x-if="cat.children && cat.children.length > 0">
                                <div class="space-y-2 mt-2 pl-4 border-l-2 border-slate-100">
                                    <template x-for="child in cat.children" :key="child.id">
                                        <div class="flex items-center justify-between py-1 px-2 rounded hover:bg-slate-50 text-sm group/child">
                                            <div class="flex items-center gap-2 min-w-0">
                                                <input type="checkbox"
                                                       :value="child.id"
                                                       x-model="selectedCategories"
                                                       class="w-3.5 h-3.5 rounded border-slate-300 text-blue-600 focus:ring-blue-500"
                                                       :aria-label="'选择 ' + (child.displayName || child.name)">
                                                <span x-text="child.icon || '📄'" :style="child.color ? 'color:' + child.color : ''"></span>
                                                <span class="truncate text-slate-600" x-text="child.displayName || child.name" :class="child.isMatch ? 'bg-amber-100' : ''"></span>
                                                <span class="text-[10px] text-slate-400" x-text="'(' + child.count + ')'"></span>
                                            </div>
                                            <div class="flex items-center gap-1 opacity-0 group-hover/child:opacity-100 transition-opacity">
                                                <button @click="openCategoryStyleModal(child)" class="p-1 text-slate-400 hover:text-blue-500" title="设置样式">🎨</button>
                                                <button @click="deleteCategory(child.id)"
                                                        data-testid="delete-category-button"
                                                        :data-category-id="child.id"
                                                        class="p-1 text-slate-400 hover:text-rose-500"
                                                        title="删除">🗑️</button>
                                            </div>
                                        </div>
                                    </template>
                                </div>
                            </template>
                        </div>
                    </template>
                </div>
            </div>

            <!-- Selection Actions Overlay -->
            <template x-if="selectedCategories.length > 0">
                <div class="fixed bottom-8 left-1/2 -translate-x-1/2 bg-slate-900 text-white px-6 py-4 rounded-full shadow-2xl flex items-center gap-6 z-50 animate-fade-in"
                     data-testid="category-bulk-actions">
                    <span class="text-sm font-medium">已选择 <span x-text="selectedCategories.length" class="text-blue-400"></span> 个分类</span>
                    <div class="h-4 w-[1px] bg-slate-700"></div>
                    <div class="flex items-center gap-4">
                        <button @click="batchDeleteCategories()" class="text-sm text-rose-400 hover:text-rose-300 font-medium">🗑️ 批量删除</button>
                        <button @click="checkSelectedCategories()" class="text-sm text-blue-400 hover:text-blue-300 font-medium">🔍 批量检查</button>
                        <button @click="openExportSelectedCategories()" class="text-sm text-emerald-400 hover:text-emerald-300 font-medium">📤 批量导出</button>
                    </div>
                    <div class="h-4 w-[1px] bg-slate-700"></div>
                    <button @click="selectedCategories = []" class="text-xs text-slate-400 hover:text-white">取消选择</button>
                </div>
            </template>
        </div>
    </div>
    <script src="/public/lib/alpine.min.js"></script>
</body>

</html>

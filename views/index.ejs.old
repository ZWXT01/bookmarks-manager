<!DOCTYPE html>
<html lang="zh-CN">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>书签管理器</title>
    <script src="/public/lib/tailwind.js"></script>
    <link rel="stylesheet" href="/public/app.css">
    <script src="/public/dialog.js"></script>
    <script src="/public/app.js"></script>
    <style>
        [x-cloak] {
            display: none !important;
        }
    </style>
    <script>
        (function () {
            var theme = localStorage.getItem('theme');
            if (theme === 'dark') {
                document.documentElement.setAttribute('data-theme', 'dark');
            } else if (theme === 'light') {
                document.documentElement.setAttribute('data-theme', 'light');
            }
        })();
    </script>
</head>

<body class="bg-slate-50 text-slate-900">
    <div x-data="bookmarkApp()" x-init="init()">
        <!-- Header -->
        <div class="glass-header border-b sticky top-0 z-40">
            <div class="mx-auto max-w-screen-2xl px-4 py-3">
                <div class="flex items-center justify-between">
                    <div>
                        <h1
                            class="text-xl font-bold bg-gradient-to-r from-blue-600 to-purple-600 bg-clip-text text-transparent">
                            📚 书签管理器</h1>
                        <p class="text-xs text-slate-500">轻量 · SQLite · 支持导入/导出与有效性检查</p>
                    </div>
                    <div class="flex items-center gap-2">
                        <!-- Current Job Progress -->
                        <template
                            x-if="currentJob && (currentJob.status === 'running' || currentJob.status === 'queued')">
                            <div
                                class="flex items-center gap-2 text-xs bg-gradient-to-r from-blue-50 to-purple-50 rounded-lg px-3 py-2 border border-blue-200 shadow-sm animate-fade-in">
                                <span class="animate-pulse"
                                    x-text="currentJob.type === 'ai_organize' ? '🤖 AI整理' : currentJob.type === 'check' ? '🔍 检查' : currentJob.type === 'import' ? '📥 导入' : '任务'"></span>
                                <span x-text="currentJob.processed + '/' + currentJob.total" class="font-medium"></span>
                                <div class="w-20 h-2 progress-bar">
                                    <div class="progress-bar-fill"
                                        :style="'width:' + (currentJob.total > 0 ? Math.floor(currentJob.processed / currentJob.total * 100) : 0) + '%'">
                                    </div>
                                </div>
                                <span x-text="currentJob.status === 'running' ? '运行中' : '等待中'"
                                    class="text-slate-600"></span>
                                <a :href="'/jobs/' + currentJob.id"
                                    class="text-blue-600 hover:text-blue-700 font-medium">详情</a>
                                <button @click="cancelCurrentJob()" aria-label="取消任务"
                                    class="text-rose-500 hover:text-rose-700 hover:scale-110 transition-transform">✕</button>
                            </div>
                        </template>
                        <button @click="toggleTheme()" class="btn-secondary btn-sm" aria-label="切换主题"
                            x-text="theme === 'dark' ? '☀️' : '🌙'"></button>
                        <button @click="openBackupModal()" class="btn-secondary btn-sm">💾 备份</button>
                        <button @click="openExportModal()" class="btn-secondary btn-sm">📤 导出</button>
                        <a href="/snapshots" class="btn-secondary btn-sm inline-flex items-center">📸 快照</a>
                        <a href="/jobs" class="btn-secondary btn-sm inline-flex items-center">📋 任务</a>
                        <a href="/settings" class="btn-secondary btn-sm inline-flex items-center">⚙️ 设置</a>
                        <form action="/logout" method="POST" class="inline">
                            <button type="submit" class="btn-danger btn-sm">🚪 退出</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        <div class="mx-auto max-w-screen-2xl px-4 py-4 h-[calc(100vh-70px)] flex flex-col lg:flex-row gap-4">
            <div class="flex flex-col lg:flex-row gap-4 flex-1 min-h-0">
                <!-- Sidebar -->
                <aside class="lg:w-72 flex-shrink-0 flex flex-col gap-4 lg:max-h-[calc(100vh-100px)]">
                    <!-- Import -->
                    <div class="card p-4 flex-shrink-0 animate-fade-in">
                        <h2 class="text-sm font-bold text-slate-700 mb-3 flex items-center gap-2">
                            <span
                                class="w-6 h-6 rounded-md bg-gradient-to-br from-blue-500 to-purple-500 flex items-center justify-center text-white text-xs">📥</span>
                            导入书签
                        </h2>
                        <form id="import-form" @submit.prevent="startImport($el)">
                            <input type="file" name="file" accept=".html,.htm,.json,.txt" required
                                class="w-full text-xs mb-3 file:mr-2 file:py-1.5 file:px-3 file:rounded-md file:border-0 file:text-xs file:font-medium file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100">
                            <label class="flex items-center gap-2 text-xs text-slate-600 mb-2">
                                <input type="checkbox" x-model="importOverrideCategory">
                                忽略原有分类，统一导入到：
                            </label>
                            <input type="hidden" name="overrideCategory" :value="importOverrideCategory ? '1' : ''">
                            <div class="mb-3" x-show="importOverrideCategory">
                                <select name="defaultCategoryId" class="w-full rounded-lg border px-3 py-2 text-xs">
                                    <option value="">未分类</option>
                                    <template x-for="cat in categories" :key="cat.id">
                                        <option :value="cat.id" x-text="cat.name"></option>
                                    </template>
                                </select>
                            </div>
                            <label class="flex items-center gap-2 text-xs text-slate-600 mb-3">
                                <input type="checkbox" name="skipDuplicates" value="1" checked>
                                跳过重复书签
                            </label>
                            <button type="submit" class="btn-primary w-full">开始导入</button>
                        </form>
                    </div>

                    <!-- Tools -->
                    <div class="card p-4 flex-shrink-0">
                        <h2 class="text-sm font-bold text-slate-700 mb-3 flex items-center gap-2">
                            <span
                                class="w-6 h-6 rounded-md bg-gradient-to-br from-emerald-500 to-teal-500 flex items-center justify-center text-white text-xs">🛠️</span>
                            工具
                        </h2>
                        <div class="space-y-2">
                            <button @click="openCheckModal()" class="btn-secondary w-full text-left justify-start">🔍
                                批量检查</button>
                            <button @click="openAIOrganizeModal()"
                                class="btn-secondary w-full text-left justify-start">🤖 AI 整理</button>
                        </div>
                    </div>
                    <!-- Template Management -->
                    <div class="card p-4 flex-shrink-0">
                        <h2 class="text-sm font-bold text-slate-700 mb-2 flex items-center gap-2">
                            <span
                                class="w-6 h-6 rounded-md bg-gradient-to-br from-violet-500 to-purple-500 flex items-center justify-center text-white text-xs">🗂️</span>
                            分类模板
                        </h2>
                        <template x-if="activeTemplate">
                            <div class="flex items-center justify-between gap-2">
                                <span class="text-sm text-slate-600 truncate" x-text="activeTemplate.name"></span>
                                <button @click="showTemplateSelectModal = true"
                                    class="text-xs text-blue-500 hover:text-blue-700 whitespace-nowrap">切换模板</button>
                            </div>
                        </template>
                        <template x-if="!activeTemplate">
                            <div class="flex items-center justify-between gap-2">
                                <span class="text-xs text-slate-400">请先选择分类模板</span>
                                <button @click="showTemplateSelectModal = true"
                                    class="text-xs text-blue-500 hover:text-blue-700 whitespace-nowrap">选择模板</button>
                            </div>
                        </template>
                        <div class="flex gap-1 mt-2">
                            <button @click="showToast('该功能正在开发中，敬请期待', 'info')"
                                class="flex-1 text-xs px-2 py-1 rounded border border-dashed border-slate-300 text-slate-400 hover:text-slate-600 hover:border-slate-400">AI 设计模板 <span class="text-[10px] bg-amber-100 text-amber-600 px-1 rounded">Beta</span></button>
                            <button @click="showToast('该功能正在开发中，敬请期待', 'info')"
                                class="flex-1 text-xs px-2 py-1 rounded border border-dashed border-slate-300 text-slate-400 hover:text-slate-600 hover:border-slate-400">AI 改造模板 <span class="text-[10px] bg-amber-100 text-amber-600 px-1 rounded">Beta</span></button>
                        </div>
                    </div>
                    <!-- Categories - Scrollable -->
                    <div class="card p-4 flex-1 flex flex-col min-h-0 overflow-hidden custom-scrollbar">
                        <h2 class="text-sm font-bold text-slate-700 mb-3 flex-shrink-0 flex items-center gap-2">
                            <span
                                class="w-6 h-6 rounded-md bg-gradient-to-br from-amber-500 to-orange-500 flex items-center justify-center text-white text-xs">📁</span>
                            分类
                        </h2>

                        <!-- Category Search -->
                        <input type="text" x-model="categorySearch" placeholder="🔍 搜索分类..."
                            class="w-full rounded-lg border px-3 py-2 text-xs mb-3 flex-shrink-0">

                        <!-- Category List - Scrollable -->
                        <div class="flex-1 overflow-y-auto min-h-0 custom-scrollbar">
                            <!-- All Bookmarks -->
                            <div @click="loadCategory(null)"
                                class="flex items-center justify-between px-3 py-2 rounded-lg cursor-pointer transition-all hover:bg-slate-50"
                                :class="currentCategory === null ? 'bg-gradient-to-r from-blue-50 to-purple-50 text-blue-700 shadow-sm' : ''">
                                <span class="text-sm font-medium">📚 全部</span>
                                <span class="text-xs px-2 py-0.5 rounded-full bg-slate-100" x-text="totalCount"></span>
                            </div>

                            <!-- Uncategorized -->
                            <div @click="loadCategory('uncategorized')"
                                class="flex items-center justify-between px-3 py-2 rounded-lg cursor-pointer transition-all hover:bg-slate-50 mt-1"
                                :class="currentCategory === 'uncategorized' ? 'bg-gradient-to-r from-blue-50 to-purple-50 text-blue-700 shadow-sm' : ''">
                                <span class="text-sm font-medium">📂 未分类</span>
                                <span class="text-xs px-2 py-0.5 rounded-full bg-slate-100"
                                    x-text="uncategorizedCount"></span>
                            </div>

                            <!-- Select All Categories -->
                            <div class="flex items-center gap-2 mt-3 mb-1 px-1 py-1 border-b border-slate-100">
                                <input type="checkbox" id="select-all-categories"
                                    @change="toggleSelectAllCategories($event.target.checked)"
                                    :checked="selectedCategories.length > 0 && selectedCategories.length === getAllCategoryIds().length"
                                    class="rounded">
                                <label for="select-all-categories"
                                    class="text-xs text-slate-500 cursor-pointer">全选分类</label>
                            </div>

                            <!-- Category Tree - 移除 max-h-80 限制 -->
                            <div class="space-y-0.5 custom-scrollbar">
                                <template x-for="cat in categoryTree" :key="cat.id">
                                    <div>
                                        <!-- Parent Category -->
                                        <div class="flex items-center group">
                                            <input type="checkbox" :value="String(cat.id)" x-model="selectedCategories"
                                                class="mr-1 flex-shrink-0" @click.stop>
                                            <button x-show="cat.children && cat.children.length > 0"
                                                @click.stop="toggleCategoryExpand(cat.id)"
                                                class="w-4 h-4 flex items-center justify-center text-xs text-slate-400 hover:text-slate-600">
                                                <span x-text="isCategoryExpanded(cat.id) ? '▼' : '▶'"></span>
                                            </button>
                                            <span x-show="!cat.children || cat.children.length === 0"
                                                class="w-4"></span>
                                            <div @click="loadCategory(cat.id)"
                                                class="flex-1 flex items-center justify-between px-2 py-1 rounded cursor-pointer hover:bg-slate-50"
                                                :class="currentCategory == cat.id ? 'bg-blue-50 text-blue-700' : ''">
                                                <span class="text-sm flex items-center gap-1">
                                                    <span x-text="cat.icon || '📁'"
                                                        :style="cat.color ? 'color:' + cat.color : ''"></span>
                                                    <span x-text="cat.name"></span>
                                                </span>
                                                <span class="text-xs text-slate-500" x-text="cat.count"></span>
                                            </div>
                                            <div class="hidden group-hover:flex gap-0.5">
                                                <button @click.stop="openCreateCategoryModal(cat.id)"
                                                    class="text-xs text-slate-400 hover:text-blue-500"
                                                    title="添加子分类">+</button>
                                                <button @click.stop="openCategoryStyleModal(cat)"
                                                    class="text-xs text-slate-400 hover:text-blue-500"
                                                    title="设置样式">🎨</button>
                                                <button @click.stop="deleteCategory(cat.id)"
                                                    class="text-xs text-slate-400 hover:text-rose-500"
                                                    title="删除">🗑️</button>
                                            </div>
                                        </div>
                                        <!-- Child Categories -->
                                        <template
                                            x-if="cat.children && cat.children.length > 0 && isCategoryExpanded(cat.id)">
                                            <div class="ml-4 pl-2 border-l-2 border-slate-200">
                                                <template x-for="child in cat.children" :key="child.id">
                                                    <div class="flex items-center group">
                                                        <input type="checkbox" :value="String(child.id)"
                                                            x-model="selectedCategories" class="mr-1 flex-shrink-0"
                                                            @click.stop>
                                                        <div @click="loadCategory(child.id)"
                                                            class="flex-1 flex items-center justify-between px-2 py-1 rounded cursor-pointer hover:bg-slate-50"
                                                            :class="currentCategory == child.id ? 'bg-blue-50 text-blue-700' : ''">
                                                            <span class="text-sm flex items-center gap-1">
                                                                <span x-text="child.icon || '📄'"
                                                                    :style="child.color ? 'color:' + child.color : ''"></span>
                                                                <span x-text="child.displayName || child.name"></span>
                                                            </span>
                                                            <span class="text-xs text-slate-500"
                                                                x-text="child.count"></span>
                                                        </div>
                                                        <div class="hidden group-hover:flex gap-0.5">
                                                            <button @click.stop="openCategoryStyleModal(child)"
                                                                class="text-xs text-slate-400 hover:text-blue-500"
                                                                title="设置样式">🎨</button>
                                                            <button @click.stop="deleteCategory(child.id)"
                                                                class="text-xs text-slate-400 hover:text-rose-500"
                                                                title="删除">🗑️</button>
                                                        </div>
                                                    </div>
                                                </template>
                                            </div>
                                        </template>
                                    </div>
                                </template>
                            </div>

                        </div>

                        <!-- New Category - Fixed at bottom -->
                        <div class="mt-3 pt-3 border-t flex-shrink-0">
                            <!-- 批量操作 -->
                            <template x-if="selectedCategories.length > 0">
                                <div class="flex gap-2 mb-2">
                                    <button @click="batchDeleteCategories()"
                                        class="flex-1 rounded border border-rose-200 px-2 py-1.5 text-xs text-rose-600 hover:bg-rose-50">
                                        🗑️ 删除选中 (<span x-text="selectedCategories.length"></span>)
                                    </button>
                                </div>
                            </template>
                            <button @click="openCreateCategoryModal(null)"
                                class="w-full rounded border border-dashed border-slate-300 px-3 py-1.5 text-xs text-slate-500 hover:border-slate-400 hover:text-slate-700">+ 添加分类</button>
                        </div>
                    </div>

                </aside>

                <!-- Main Content -->
                <main class="flex-1 min-w-0 flex flex-col overflow-hidden">
                    <!-- Add Bookmark (moved to top) -->
                    <div class="rounded-lg border bg-white p-4 shadow-sm mb-4">
                        <h3 class="text-sm font-semibold text-slate-700 mb-3">➕ 添加书签</h3>
                        <div class="flex flex-wrap items-end gap-3">
                            <div class="flex-1 min-w-[200px]">
                                <input type="text" x-model="newBookmark.url" placeholder="URL"
                                    class="w-full rounded border px-3 py-2 text-sm">
                            </div>
                            <div class="flex-1 min-w-[150px]">
                                <input type="text" x-model="newBookmark.title" placeholder="标题（可选）"
                                    class="w-full rounded border px-3 py-2 text-sm">
                            </div>
                            <div class="w-32">
                                <select x-model="newBookmark.category_id"
                                    class="w-full rounded border px-3 py-2 text-sm">
                                    <option value="">未分类</option>
                                    <template x-for="cat in categories" :key="cat.id">
                                        <option :value="cat.id" x-text="cat.name"></option>
                                    </template>
                                </select>
                            </div>
                            <button @click="addBookmark()"
                                class="rounded bg-slate-900 text-white px-4 py-2 text-sm hover:bg-slate-800">添加</button>
                        </div>
                    </div>

                    <!-- Search & Filters -->
                    <div class="rounded-lg border bg-white p-3 shadow-sm mb-4">
                        <div class="flex flex-wrap items-center gap-2">
                            <input type="text" x-model="searchKeyword" @input="debouncedSearch()"
                                @keyup.enter="searchBookmarks()" placeholder="搜索书签..."
                                class="flex-1 min-w-[200px] rounded border px-3 py-2 text-sm">
                            <button @click="searchBookmarks()"
                                class="rounded bg-slate-900 text-white px-4 py-2 text-sm hover:bg-slate-800">搜索</button>
                            <button @click="showAdvancedSearch = !showAdvancedSearch"
                                class="rounded border px-3 py-2 text-sm hover:bg-slate-50">
                                <span x-text="showAdvancedSearch ? '收起 ▲' : '筛选 ▼'"></span>
                            </button>
                            <button @click="toggleViewMode()" class="rounded border px-3 py-2 text-sm hover:bg-slate-50"
                                x-text="viewMode === 'table' ? '🗂️ 卡片' : '📋 表格'"></button>
                        </div>

                        <!-- Advanced Search -->
                        <div x-show="showAdvancedSearch"
                            class="mt-3 pt-3 border-t grid grid-cols-2 md:grid-cols-4 gap-3">
                            <div>
                                <label class="text-xs text-slate-600">状态</label>
                                <select x-model="advancedSearch.status"
                                    class="w-full rounded border px-2 py-1.5 text-sm mt-1">
                                    <option value="all">全部</option>
                                    <option value="not_checked">未检查</option>
                                    <option value="ok">正常</option>
                                    <option value="fail">失败</option>
                                </select>
                            </div>
                            <div>
                                <label class="text-xs text-slate-600">排序</label>
                                <select x-model="advancedSearch.sort"
                                    class="w-full rounded border px-2 py-1.5 text-sm mt-1">
                                    <option value="id">ID</option>
                                    <option value="title">标题</option>
                                    <option value="created_at">创建时间</option>
                                    <option value="check_status">检查状态</option>
                                </select>
                            </div>
                            <div>
                                <label class="text-xs text-slate-600">排序方向</label>
                                <select x-model="advancedSearch.order"
                                    class="w-full rounded border px-2 py-1.5 text-sm mt-1">
                                    <option value="desc">降序</option>
                                    <option value="asc">升序</option>
                                </select>
                            </div>
                            <div class="flex items-end gap-2">
                                <button @click="applyAdvancedSearch()"
                                    class="rounded bg-slate-900 text-white px-4 py-1.5 text-sm hover:bg-slate-800">应用</button>
                                <button @click="resetAdvancedSearch()"
                                    class="rounded border px-4 py-1.5 text-sm hover:bg-slate-50">重置</button>
                            </div>
                        </div>
                    </div>

                    <!-- Batch Actions & Pagination -->
                    <div class="flex flex-wrap items-center justify-between gap-2 mb-4">
                        <div class="flex items-center gap-2 flex-wrap">
                            <span class="text-sm text-slate-500">
                                共 <span x-text="total"></span> 条，已选 <span x-text="selectedBookmarks.length"></span> 条
                            </span>
                            <template x-if="selectedBookmarks.length > 0">
                                <div class="flex gap-1">
                                    <button @click="openMoveSelectedModal()"
                                        class="rounded border px-2 py-1 text-xs hover:bg-slate-50">📁
                                        移动</button>
                                    <button @click="openCheckModalForSelected()"
                                        class="rounded border px-2 py-1 text-xs hover:bg-slate-50">🔍 检查</button>
                                    <button @click="promptClassifyBatch([...selectedBookmarks])"
                                        class="rounded border px-2 py-1 text-xs hover:bg-slate-50">🤖 AI 分类</button>
                                    <button @click="batchDelete()"
                                        class="rounded border border-rose-300 px-2 py-1 text-xs text-rose-600 hover:bg-rose-50">🗑️
                                        删除选中</button>
                                </div>
                            </template>
                            <!-- More dropdown -->
                            <div class="relative ml-2" x-data="{ showMoreMenu: false }">
                                <button @click="showMoreMenu = !showMoreMenu"
                                    class="rounded border px-2 py-1 text-xs hover:bg-slate-50">更多 ▼</button>
                                <div x-show="showMoreMenu" @click.away="showMoreMenu = false"
                                    class="absolute left-0 top-full mt-1 z-50 w-28 rounded-lg border bg-white shadow-lg py-1 text-left">
                                    <button @click="deleteCurrentPage(); showMoreMenu = false"
                                        class="block w-full px-3 py-1.5 text-xs text-rose-600 hover:bg-rose-50 text-left">删除本页</button>
                                    <button @click="deleteAllBookmarks(); showMoreMenu = false"
                                        class="block w-full px-3 py-1.5 text-xs text-rose-600 hover:bg-rose-50 text-left">删除全部</button>
                                </div>
                            </div>
                        </div>
                        <div class="flex items-center gap-2">
                            <span class="text-xs text-slate-500">第 <span x-text="page"></span>/<span
                                    x-text="totalPages"></span>
                                页</span>
                            <button @click="prevPage()" :disabled="page <= 1"
                                class="rounded border px-2 py-1 text-xs hover:bg-slate-50 disabled:opacity-50">上一页</button>
                            <button @click="nextPage()" :disabled="page >= totalPages"
                                class="rounded border px-2 py-1 text-xs hover:bg-slate-50 disabled:opacity-50">下一页</button>
                        </div>
                    </div>

                    <!-- Bookmark List Area -->
                    <div class="flex-1 overflow-y-auto min-h-0">
                        <!-- Table View -->
                        <div x-show="viewMode === 'table'" class="rounded-lg border bg-white shadow-sm overflow-hidden">
                            <table class="w-full">
                                <thead class="bg-slate-50">
                                    <tr>
                                        <th class="w-10 px-3 py-2"><input type="checkbox" @change="toggleAll($event)"
                                                :checked="allSelected">
                                        </th>
                                        <th class="px-3 py-2 text-left text-xs font-semibold text-slate-600">标题</th>
                                        <th class="w-24 px-3 py-2 text-left text-xs font-semibold text-slate-600">分类
                                        </th>
                                        <th class="w-20 px-3 py-2 text-center text-xs font-semibold text-slate-600">状态
                                        </th>
                                        <th class="w-24 px-3 py-2 text-center text-xs font-semibold text-slate-600">操作
                                        </th>
                                    </tr>
                                </thead>
                                <tbody class="divide-y">
                                    <template x-for="bookmark in displayBookmarks" :key="bookmark.id">
                                        <tr class="hover:bg-slate-50">
                                            <td class="px-3 py-2">
                                                <input type="checkbox" :value="String(bookmark.id)"
                                                    x-model="selectedBookmarks">
                                            </td>
                                            <td class="px-3 py-2 max-w-xs">
                                                <a :href="bookmark.url" target="_blank"
                                                    class="text-sm text-blue-600 hover:underline line-clamp-1"
                                                    x-text="bookmark.title"></a>
                                                <div class="text-xs text-slate-400 truncate max-w-xs"
                                                    x-text="bookmark.url">
                                                </div>
                                            </td>
                                            <td class="px-3 py-2"><span class="text-xs text-slate-500"
                                                    x-text="bookmark.category_name || '未分类'"></span></td>
                                            <td class="px-3 py-2 text-center">
                                                <span class="inline-flex items-center gap-1">
                                                    <span class="w-2 h-2 rounded-full"
                                                        :class="bookmark.check_status === 'ok' ? 'bg-emerald-500' : bookmark.check_status === 'fail' ? 'bg-rose-500' : 'bg-slate-300'"></span>
                                                    <span
                                                        x-show="bookmark.skip_check == 1 || bookmark.skip_check === true"
                                                        class="text-xs text-slate-400" title="忽略检查">🚫</span>
                                                </span>
                                            </td>
                                            <td class="px-3 py-2 text-center relative">
                                                <!-- Dropdown Menu Button -->
                                                <button
                                                    @click.stop="openDropdownId === bookmark.id ? closeAllDropdowns() : openDropdown(bookmark.id)"
                                                    class="rounded border px-2 py-1 text-xs hover:bg-slate-100 dark:hover:bg-slate-700 dark:border-slate-600">操作
                                                    ▼</button>
                                                <!-- Dropdown Menu -->
                                                <div x-show="openDropdownId === bookmark.id"
                                                    @click.away="closeAllDropdowns()" x-effect="if (openDropdownId === bookmark.id) { 
                                                        $nextTick(() => { 
                                                            const rect = $el.parentElement.getBoundingClientRect();
                                                            const spaceBelow = window.innerHeight - rect.bottom;
                                                            if (spaceBelow < 250) {
                                                                $el.style.top = 'auto';
                                                                $el.style.bottom = '100%';
                                                                $el.style.marginBottom = '0.25rem';
                                                                $el.style.marginTop = '0';
                                                            } else {
                                                                $el.style.bottom = 'auto';
                                                                $el.style.top = '100%';
                                                                $el.style.marginTop = '0.25rem';
                                                                $el.style.marginBottom = '0';
                                                            }
                                                        });
                                                    }"
                                                    class="absolute right-0 z-50 w-32 rounded-lg border bg-white dark:bg-slate-800 dark:border-slate-600 shadow-lg py-1 text-left max-h-80 overflow-y-auto">
                                                    <button @click="openEditBookmark(bookmark); closeAllDropdowns()"
                                                        class="block w-full px-3 py-1.5 text-xs hover:bg-slate-50 text-left">✏️
                                                        编辑</button>
                                                    <button @click="openMoveBookmark(bookmark); closeAllDropdowns()"
                                                        class="block w-full px-3 py-1.5 text-xs hover:bg-slate-50 text-left">📁
                                                        移动</button>
                                                    <button @click="startCheckOne(bookmark.id); closeAllDropdowns()"
                                                        class="block w-full px-3 py-1.5 text-xs hover:bg-slate-50 text-left">🔍
                                                        检查</button>
                                                    <button @click="promptClassifyBatch([bookmark.id]); closeAllDropdowns()"
                                                        class="block w-full px-3 py-1.5 text-xs hover:bg-slate-50 text-left">🤖
                                                        AI 分类</button>
                                                    <hr class="my-1">
                                                    <button
                                                        @click="updateBookmarkStatus(bookmark.id, 'ok'); closeAllDropdowns()"
                                                        class="block w-full px-3 py-1.5 text-xs hover:bg-slate-50 text-left">✅
                                                        标记正常</button>
                                                    <button
                                                        @click="updateBookmarkStatus(bookmark.id, 'fail'); closeAllDropdowns()"
                                                        class="block w-full px-3 py-1.5 text-xs hover:bg-slate-50 text-left">❌
                                                        标记失败</button>
                                                    <button @click="toggleSkipCheck(bookmark); closeAllDropdowns()"
                                                        class="block w-full px-3 py-1.5 text-xs hover:bg-slate-50 text-left"
                                                        x-text="bookmark.skip_check ? '🔄 取消忽略' : '🚫 忽略检查'"></button>
                                                    <hr class="my-1">
                                                    <button @click="deleteBookmark(bookmark.id); closeAllDropdowns()"
                                                        class="block w-full px-3 py-1.5 text-xs hover:bg-rose-50 text-rose-600 text-left">🗑️
                                                        删除</button>
                                                </div>
                                            </td>
                                        </tr>
                                    </template>
                                </tbody>
                            </table>
                            <div x-show="displayBookmarks.length === 0" class="text-center py-10 text-slate-400">暂无书签
                            </div>
                        </div>

                        <!-- Card View -->
                        <div x-show="viewMode === 'card'" class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4">
                            <template x-for="bookmark in displayBookmarks" :key="bookmark.id">
                                <div class="rounded-lg border bg-white p-4 shadow-sm hover:shadow-md transition-shadow">
                                    <div class="flex items-start gap-2">
                                        <input type="checkbox" :value="String(bookmark.id)" x-model="selectedBookmarks"
                                            class="mt-1">
                                        <div class="flex-1 min-w-0">
                                            <div class="flex items-start justify-between gap-2">
                                                <a :href="bookmark.url" target="_blank"
                                                    class="text-sm font-medium text-blue-600 hover:underline line-clamp-2 flex-1"
                                                    x-text="bookmark.title"></a>
                                                <span class="inline-flex items-center gap-1 flex-shrink-0 mt-1">
                                                    <span class="w-2 h-2 rounded-full"
                                                        :class="bookmark.check_status === 'ok' ? 'bg-emerald-500' : bookmark.check_status === 'fail' ? 'bg-rose-500' : 'bg-slate-300'"></span>
                                                    <span
                                                        x-show="bookmark.skip_check == 1 || bookmark.skip_check === true"
                                                        class="text-xs text-slate-400" title="忽略检查">🚫</span>
                                                </span>
                                            </div>
                                            <div class="text-xs text-slate-400 truncate max-w-xs mt-1"
                                                x-text="bookmark.url">
                                            </div>
                                            <div class="flex items-center justify-between mt-3">
                                                <span class="text-xs bg-slate-100 rounded px-2 py-0.5"
                                                    x-text="bookmark.category_name || '未分类'"></span>
                                                <div class="relative">
                                                    <button
                                                        @click.stop="openDropdownId === ('card-' + bookmark.id) ? closeAllDropdowns() : openDropdown('card-' + bookmark.id)"
                                                        class="rounded border px-2 py-1 text-xs hover:bg-slate-100">操作
                                                        ▼</button>
                                                    <div x-show="openDropdownId === ('card-' + bookmark.id)"
                                                        @click.away="closeAllDropdowns()"
                                                        class="absolute right-0 top-full mt-1 z-50 w-32 rounded-lg border bg-white shadow-lg py-1 text-left">
                                                        <button @click="openEditBookmark(bookmark); closeAllDropdowns()"
                                                            class="block w-full px-3 py-1.5 text-xs hover:bg-slate-50 text-left">✏️
                                                            编辑</button>
                                                        <button @click="openMoveBookmark(bookmark); closeAllDropdowns()"
                                                            class="block w-full px-3 py-1.5 text-xs hover:bg-slate-50 text-left">📁
                                                            移动</button>
                                                        <button @click="startCheckOne(bookmark.id); closeAllDropdowns()"
                                                            class="block w-full px-3 py-1.5 text-xs hover:bg-slate-50 text-left">�
                                                            检查</button>
                                                        <hr class="my-1">
                                                        <button
                                                            @click="updateBookmarkStatus(bookmark.id, 'ok'); closeAllDropdowns()"
                                                            class="block w-full px-3 py-1.5 text-xs hover:bg-slate-50 text-left">✅
                                                            标记正常</button>
                                                        <button
                                                            @click="updateBookmarkStatus(bookmark.id, 'fail'); closeAllDropdowns()"
                                                            class="block w-full px-3 py-1.5 text-xs hover:bg-slate-50 text-left">❌
                                                            标记失败</button>
                                                        <button @click="toggleSkipCheck(bookmark); closeAllDropdowns()"
                                                            class="block w-full px-3 py-1.5 text-xs hover:bg-slate-50 text-left"
                                                            x-text="bookmark.skip_check ? '🔄 取消忽略' : '🚫 忽略检查'"></button>
                                                        <hr class="my-1">
                                                        <button
                                                            @click="deleteBookmark(bookmark.id); closeAllDropdowns()"
                                                            class="block w-full px-3 py-1.5 text-xs hover:bg-rose-50 text-rose-600 text-left">🗑️
                                                            删除</button>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </template>
                        </div>
                    </div>
                </main>
            </div>
        </div>

        <!-- Edit Bookmark Modal -->
        <div x-cloak x-show="showEditModal" class="fixed inset-0 z-50 flex items-center justify-center bg-black/50"
            @click.self="closeEditModal()">
            <div class="w-full max-w-md rounded-lg bg-white p-4 shadow-xl">
                <div class="flex items-center justify-between mb-3">
                    <h3 class="text-lg font-semibold">编辑书签</h3>
                    <button @click="closeEditModal()"
                        class="text-slate-400 hover:text-slate-600 text-xl">&times;</button>
                </div>
                <div class="space-y-3">
                    <input type="text" x-model="editBookmark.url" placeholder="URL"
                        class="w-full rounded border px-3 py-2 text-sm">
                    <input type="text" x-model="editBookmark.title" placeholder="标题"
                        class="w-full rounded border px-3 py-2 text-sm">
                </div>
                <div class="flex justify-end gap-2 mt-4">
                    <button @click="closeEditModal()"
                        class="rounded border px-4 py-2 text-sm hover:bg-slate-50">取消</button>
                    <button @click="saveEditBookmark()"
                        class="rounded bg-slate-900 text-white px-4 py-2 text-sm hover:bg-slate-800">保存</button>
                </div>
            </div>
        </div>

        <!-- Move One Bookmark Modal -->
        <div x-cloak x-show="showMoveOneModal" class="fixed inset-0 z-50 flex items-center justify-center bg-black/50"
            @click.self="closeMoveOneModal()">
            <div class="w-full max-w-md rounded-lg bg-white p-4 shadow-xl">
                <div class="flex items-center justify-between mb-3">
                    <h3 class="text-lg font-semibold">移动书签</h3>
                    <button @click="closeMoveOneModal()"
                        class="text-slate-400 hover:text-slate-600 text-xl">&times;</button>
                </div>
                <select x-model="moveOneTargetCategory" class="w-full rounded border px-3 py-2 text-sm">
                    <option value="">未分类</option>
                    <template x-for="cat in categories" :key="cat.id">
                        <option :value="cat.id" x-text="cat.name"></option>
                    </template>
                </select>
                <div class="flex justify-end gap-2 mt-4">
                    <button @click="closeMoveOneModal()"
                        class="rounded border px-4 py-2 text-sm hover:bg-slate-50">取消</button>
                    <button @click="confirmMoveOneBookmark()"
                        class="rounded bg-slate-900 text-white px-4 py-2 text-sm hover:bg-slate-800">确认移动</button>
                </div>
            </div>
        </div>

        <!-- Move Selected Modal -->
        <div x-cloak x-show="showMoveSelectedModal"
            class="fixed inset-0 z-50 flex items-center justify-center bg-black/50"
            @click.self="closeMoveSelectedModal()">
            <div class="w-full max-w-md rounded-lg bg-white p-4 shadow-xl">
                <h3 class="text-lg font-semibold mb-3">批量移动书签</h3>
                <p class="text-sm text-slate-500 mb-3">将 <span x-text="selectedBookmarks.length"></span> 个书签移动到：</p>
                <select x-model="moveSelectedTargetCategory" class="w-full rounded border px-3 py-2 text-sm">
                    <option value="">未分类</option>
                    <template x-for="cat in categories" :key="cat.id">
                        <option :value="cat.id" x-text="cat.name"></option>
                    </template>
                </select>
                <div class="flex justify-end gap-2 mt-4">
                    <button @click="closeMoveSelectedModal()"
                        class="rounded border px-4 py-2 text-sm hover:bg-slate-50">取消</button>
                    <button @click="confirmMoveSelectedBookmarks()"
                        class="rounded bg-slate-900 text-white px-4 py-2 text-sm hover:bg-slate-800">确认移动</button>
                </div>
            </div>
        </div>

        <!-- Category Style Modal -->
        <div x-cloak x-show="showCategoryStyleModal"
            class="fixed inset-0 z-50 flex items-center justify-center bg-black/50"
            @click.self="closeCategoryStyleModal()">
            <div class="w-full max-w-md rounded-lg bg-white p-4 shadow-xl">
                <h3 class="text-lg font-semibold mb-3">分类样式</h3>
                <div class="space-y-3">
                    <div>
                        <label class="text-xs text-slate-600">图标</label>
                        <div class="flex flex-wrap gap-2 mt-1">
                            <template
                                x-for="icon in ['📁', '📂', '📄', '📝', '📚', '🔖', '⭐', '❤️', '🎮', '🎵', '🎬', '📷', '💻', '🌐', '🛠️', '📱']">
                                <button @click="categoryIcon = icon"
                                    class="w-8 h-8 rounded border hover:bg-slate-50 flex items-center justify-center"
                                    :class="categoryIcon === icon ? 'border-blue-500 bg-blue-50' : ''"
                                    x-text="icon"></button>
                            </template>
                        </div>
                    </div>
                    <div>
                        <label class="text-xs text-slate-600">颜色</label>
                        <div class="flex flex-wrap gap-2 mt-1">
                            <template
                                x-for="color in ['', '#ef4444', '#f97316', '#eab308', '#22c55e', '#14b8a6', '#3b82f6', '#8b5cf6', '#ec4899']">
                                <button @click="categoryColor = color" class="w-8 h-8 rounded border hover:opacity-80"
                                    :class="categoryColor === color ? 'ring-2 ring-blue-500' : ''"
                                    :style="color ? 'background-color:' + color : ''"
                                    x-text="color ? '' : '✕'"></button>
                            </template>
                        </div>
                    </div>
                </div>
                <div class="flex justify-end gap-2 mt-4">
                    <button @click="closeCategoryStyleModal()"
                        class="rounded border px-4 py-2 text-sm hover:bg-slate-50">取消</button>
                    <button @click="saveCategoryStyle()"
                        class="rounded bg-slate-900 text-white px-4 py-2 text-sm hover:bg-slate-800">保存</button>
                </div>
            </div>
        </div>

        <!-- Create Category Modal -->
        <div x-cloak x-show="showCreateCategoryModal"
            class="fixed inset-0 z-50 flex items-center justify-center bg-black/50"
            @click.self="closeCreateCategoryModal()">
            <div class="w-full max-w-md rounded-lg bg-white p-4 shadow-xl">
                <h3 class="text-lg font-semibold mb-3" x-text="createCategoryParentId ? '添加子分类' : '添加分类'"></h3>
                <div class="space-y-3">
                    <div>
                        <label class="text-xs text-slate-600">名称</label>
                        <input type="text" x-model="createCategoryName" placeholder="分类名称"
                            class="w-full rounded border px-3 py-2 text-sm mt-1" @keyup.enter="confirmCreateCategory()">
                    </div>
                    <div>
                        <label class="text-xs text-slate-600">图标</label>
                        <div class="flex flex-wrap gap-2 mt-1">
                            <template
                                x-for="icon in ['📁', '📂', '📄', '📝', '📚', '🔖', '⭐', '❤️', '🎮', '🎵', '🎬', '📷', '💻', '🌐', '🛠️', '📱']">
                                <button @click="createCategoryIcon = createCategoryIcon === icon ? '' : icon"
                                    class="w-8 h-8 rounded border hover:bg-slate-50 flex items-center justify-center"
                                    :class="createCategoryIcon === icon ? 'border-blue-500 bg-blue-50' : ''"
                                    x-text="icon"></button>
                            </template>
                        </div>
                    </div>
                    <div>
                        <label class="text-xs text-slate-600">颜色</label>
                        <div class="flex flex-wrap gap-2 mt-1">
                            <template
                                x-for="color in ['', '#ef4444', '#f97316', '#eab308', '#22c55e', '#14b8a6', '#3b82f6', '#8b5cf6', '#ec4899']">
                                <button @click="createCategoryColor = color" class="w-8 h-8 rounded border hover:opacity-80"
                                    :class="createCategoryColor === color ? 'ring-2 ring-blue-500' : ''"
                                    :style="color ? 'background-color:' + color : ''"
                                    x-text="color ? '' : '✕'"></button>
                            </template>
                        </div>
                    </div>
                </div>
                <div class="flex justify-end gap-2 mt-4">
                    <button @click="closeCreateCategoryModal()"
                        class="rounded border px-4 py-2 text-sm hover:bg-slate-50">取消</button>
                    <button @click="confirmCreateCategory()"
                        :disabled="!createCategoryName.trim()"
                        class="rounded bg-slate-900 text-white px-4 py-2 text-sm hover:bg-slate-800 disabled:opacity-40 disabled:cursor-not-allowed">确认</button>
                </div>
            </div>
        </div>

        <!-- Check Modal -->
        <div x-cloak x-show="showCheckModal" class="fixed inset-0 z-50 flex items-center justify-center bg-black/50"
            @click.self="closeCheckModal()">
            <div class="w-full max-w-lg rounded-lg bg-white p-4 shadow-xl">
                <div class="flex items-center justify-between mb-3">
                    <h3 class="text-lg font-semibold">🔍 批量检查</h3>
                    <button @click="closeCheckModal()"
                        class="text-slate-400 hover:text-slate-600 text-xl">&times;</button>
                </div>
                <template x-if="!checkJobId">
                    <div class="space-y-3">
                        <div>
                            <label class="text-xs text-slate-600">检查范围</label>
                            <select x-model="checkOptions.scope" class="w-full rounded border px-3 py-2 text-sm mt-1">
                                <option value="all">全部书签</option>
                                <option value="not_checked">仅未检查</option>
                                <option value="failed">仅失败书签</option>
                                <option value="category">当前分类</option>
                                <option value="selected">选中书签</option>
                            </select>
                        </div>
                        <div class="grid grid-cols-2 gap-3">
                            <div>
                                <label class="text-xs text-slate-600">重试次数</label>
                                <select x-model="checkOptions.retries"
                                    class="w-full rounded border px-3 py-2 text-sm mt-1">
                                    <option value="0">0</option>
                                    <option value="1">1</option>
                                    <option value="2">2</option>
                                    <option value="3">3</option>
                                </select>
                            </div>
                            <div>
                                <label class="text-xs text-slate-600">重试间隔(ms)</label>
                                <input type="number" x-model="checkOptions.retry_delay_ms"
                                    class="w-full rounded border px-3 py-2 text-sm mt-1">
                            </div>
                        </div>
                        <div class="flex justify-end gap-2">
                            <button @click="closeCheckModal()"
                                class="rounded border px-4 py-2 text-sm hover:bg-slate-50">取消</button>
                            <button @click="startCheck()"
                                class="rounded bg-slate-900 text-white px-4 py-2 text-sm hover:bg-slate-800">开始检查</button>
                        </div>
                    </div>
                </template>
                <template x-if="checkJobId && !checkJobDone">
                    <div class="space-y-4">
                        <!-- Circular Progress Ring -->
                        <div class="flex flex-col items-center gap-3">
                            <div class="relative w-24 h-24">
                                <svg class="w-24 h-24 transform -rotate-90">
                                    <circle cx="48" cy="48" r="40" stroke="#e2e8f0" stroke-width="8" fill="none" />
                                    <circle cx="48" cy="48" r="40" stroke="#3b82f6" stroke-width="8" fill="none"
                                        stroke-linecap="round" :stroke-dasharray="251.2"
                                        :stroke-dashoffset="251.2 - (251.2 * checkProgress / 100)" />
                                </svg>
                                <div class="absolute inset-0 flex items-center justify-center">
                                    <span class="text-xl font-bold text-blue-600" x-text="checkProgress + '%'"></span>
                                </div>
                            </div>
                            <div class="text-center">
                                <div class="text-sm font-medium text-slate-700"
                                    x-text="'处理中 ' + checkStats.processed + ' / ' + checkStats.total"></div>
                                <div class="text-xs text-slate-400 mt-1">正在检查书签可用性...</div>
                            </div>
                        </div>
                        <!-- Action Buttons -->
                        <div class="flex justify-center gap-3 pt-2 border-t">
                            <button @click="cancelCheckJob()"
                                class="flex items-center gap-1 rounded-lg border border-rose-200 text-rose-600 px-4 py-2 text-sm hover:bg-rose-50 transition">
                                <span>✕</span> 取消任务
                            </button>
                            <a :href="'/jobs/' + checkJobId"
                                class="flex items-center gap-1 rounded-lg border px-4 py-2 text-sm hover:bg-slate-50 transition">
                                <span>📋</span> 查看详情
                            </a>
                        </div>
                    </div>
                </template>
                <template x-if="checkJobDone">
                    <div class="space-y-4">
                        <!-- 100% Completion Ring -->
                        <div class="flex flex-col items-center gap-3">
                            <div class="relative w-24 h-24">
                                <svg class="w-24 h-24 transform -rotate-90">
                                    <circle cx="48" cy="48" r="40" stroke="#e2e8f0" stroke-width="8" fill="none" />
                                    <circle cx="48" cy="48" r="40" stroke="#10b981" stroke-width="8" fill="none"
                                        stroke-linecap="round" stroke-dasharray="251.2" stroke-dashoffset="0" />
                                </svg>
                                <div class="absolute inset-0 flex items-center justify-center">
                                    <span class="text-xl font-bold text-emerald-600">100%</span>
                                </div>
                            </div>
                            <div class="text-emerald-600 font-medium">✅ 检查完成</div>
                            <div class="text-sm text-slate-500"
                                x-text="'成功: ' + checkStats.inserted + '  失败: ' + checkStats.failed"></div>
                        </div>
                        <!-- Action Buttons -->
                        <div class="flex justify-center gap-3 pt-2 border-t">
                            <a :href="'/jobs/' + checkJobId"
                                class="flex items-center gap-1 rounded-lg border px-4 py-2 text-sm hover:bg-slate-50 transition">
                                <span>📋</span> 查看详情
                            </a>
                            <button @click="closeCheckModal()"
                                class="rounded-lg border px-4 py-2 text-sm hover:bg-slate-50 transition">关闭</button>
                        </div>
                    </div>
                </template>
            </div>
        </div>

        <!-- Template Select Modal -->
        <div x-cloak x-show="showTemplateSelectModal"
            class="fixed inset-0 z-50 flex items-center justify-center bg-black/50"
            @click.self="showTemplateSelectModal = false">
            <div class="w-full max-w-3xl rounded-lg bg-white p-4 shadow-xl max-h-[80vh] flex flex-col">
                <div class="flex items-center justify-between mb-3 flex-shrink-0">
                    <h3 class="text-lg font-semibold">🗂️ 选择分类模板</h3>
                    <button @click="showTemplateSelectModal = false"
                        class="text-slate-400 hover:text-slate-600 text-xl">&times;</button>
                </div>
                <div class="flex-1 overflow-y-auto space-y-4 min-h-0">
                    <!-- 预置模板 -->
                    <template x-if="presetTemplates.length > 0">
                        <div>
                            <div class="text-xs font-medium text-slate-500 mb-1.5">预置模板</div>
                            <div class="space-y-2">
                                <template x-for="tpl in presetTemplates" :key="tpl.id">
                                    <div class="flex items-center justify-between border rounded-lg px-3 py-2 hover:bg-slate-50"
                                        :class="tpl.is_active === 1 ? 'border-blue-300 bg-blue-50' : ''">
                                        <div class="flex-1 min-w-0">
                                            <div class="flex items-center gap-2">
                                                <span class="text-sm font-medium truncate" x-text="tpl.name"></span>
                                                <span class="text-xs px-1.5 py-0.5 rounded bg-violet-100 text-violet-600">预置</span>
                                                <template x-if="tpl.is_active === 1">
                                                    <span class="text-xs px-1.5 py-0.5 rounded bg-blue-100 text-blue-600">当前</span>
                                                </template>
                                            </div>
                                            <div class="text-xs text-slate-400 mt-0.5" x-text="tpl.top_level_count + ' 个一级分类'"></div>
                                        </div>
                                        <div class="flex items-center gap-1 ml-2 flex-shrink-0">
                                            <button @click="resetPresetTemplate(tpl.id)"
                                                class="text-xs px-2 py-1 rounded border border-amber-300 text-amber-600 hover:bg-amber-50">重置</button>
                                            <template x-if="tpl.is_active !== 1">
                                                <button @click="if(await AppDialog.confirm('应用模板将替换当前所有分类，所有书签将变为未分类。如果该模板曾使用过，书签分布将自动恢复。\n\n确定应用此模板？')) { applyTemplate(tpl.id); showTemplateSelectModal = false; }"
                                                    class="text-xs px-2 py-1 rounded bg-blue-500 text-white hover:bg-blue-600"
                                                    :disabled="templateApplying">应用</button>
                                            </template>
                                        </div>
                                    </div>
                                </template>
                            </div>
                        </div>
                    </template>
                    <!-- 自定义模板 -->
                    <div>
                        <div class="text-xs font-medium text-slate-500 mb-1.5">自定义模板</div>
                        <div class="space-y-2">
                            <template x-for="tpl in customTemplates" :key="tpl.id">
                                <div class="flex items-center justify-between border rounded-lg px-3 py-2 hover:bg-slate-50"
                                    :class="tpl.is_active === 1 ? 'border-blue-300 bg-blue-50' : ''">
                                    <div class="flex-1 min-w-0">
                                        <div class="flex items-center gap-2">
                                            <span class="text-sm font-medium truncate" x-text="tpl.name"></span>
                                            <span class="text-xs px-1.5 py-0.5 rounded bg-slate-100 text-slate-600">自定义</span>
                                            <template x-if="tpl.is_active === 1">
                                                <span class="text-xs px-1.5 py-0.5 rounded bg-blue-100 text-blue-600">当前</span>
                                            </template>
                                        </div>
                                        <div class="text-xs text-slate-400 mt-0.5" x-text="tpl.top_level_count + ' 个一级分类'"></div>
                                    </div>
                                    <div class="flex items-center gap-1 ml-2 flex-shrink-0">
                                        <button @click="openTemplateEditor(tpl.id)"
                                            class="text-xs px-2 py-1 rounded border hover:bg-slate-100">编辑</button>
                                        <template x-if="tpl.is_active !== 1">
                                            <button @click="if(await AppDialog.confirm('确定删除此模板？')) deleteTemplate(tpl.id)"
                                                class="text-xs px-2 py-1 rounded border border-rose-200 text-rose-500 hover:bg-rose-50">删除</button>
                                        </template>
                                        <template x-if="tpl.is_active !== 1">
                                            <button @click="if(await AppDialog.confirm('应用模板将替换当前所有分类，所有书签将变为未分类。如果该模板曾使用过，书签分布将自动恢复。\n\n确定应用此模板？')) { applyTemplate(tpl.id); showTemplateSelectModal = false; }"
                                                class="text-xs px-2 py-1 rounded bg-blue-500 text-white hover:bg-blue-600"
                                                :disabled="templateApplying">应用</button>
                                        </template>
                                    </div>
                                </div>
                            </template>
                            <template x-if="customTemplates.length === 0">
                                <div class="text-xs text-slate-400 text-center py-3">暂无自定义模板</div>
                            </template>
                        </div>
                    </div>
                </div>
                <!-- New Template Button -->
                <button @click="openNewTemplateEditor()"
                    class="w-full mt-2 rounded border border-dashed border-slate-300 px-3 py-1.5 text-xs text-slate-500 hover:border-slate-400 hover:text-slate-700 flex-shrink-0">+ 新建自定义模板</button>
            </div>
        </div>

        <!-- Batch Size Selector Modal -->
        <div x-cloak x-show="showBatchSizeModal"
            class="fixed inset-0 z-50 flex items-center justify-center bg-black/50"
            @click.self="showBatchSizeModal = false">
            <div class="w-full max-w-xs rounded-lg bg-white p-4 shadow-xl">
                <div class="flex items-center justify-between mb-3">
                    <h3 class="text-lg font-semibold">🤖 AI 分类</h3>
                    <button @click="showBatchSizeModal = false"
                        class="text-slate-400 hover:text-slate-600 text-xl">&times;</button>
                </div>
                <p class="text-sm text-slate-500 mb-3">将对 <span class="font-medium text-slate-700" x-text="classifyBatchIds.length"></span> 个书签进行 AI 分类</p>
                <template x-if="!activeTemplate">
                    <div class="mb-3 text-xs text-amber-600 bg-amber-50 border border-amber-200 rounded px-3 py-2">请先在左侧「分类模板」中选择并应用一个模板，AI 分类依赖模板中的分类结构。</div>
                </template>
                <div class="mb-4">
                    <label class="text-xs text-slate-600">每批处理数量</label>
                    <select x-model.number="classifyBatchSize" class="w-full rounded border px-3 py-2 text-sm mt-1">
                        <option value="10">10</option>
                        <option value="20">20（推荐）</option>
                        <option value="30">30</option>
                    </select>
                </div>
                <div class="flex justify-end gap-2">
                    <button @click="showBatchSizeModal = false"
                        class="rounded border px-4 py-2 text-sm hover:bg-slate-50">取消</button>
                    <button @click="startClassifyBatch(classifyBatchIds, classifyBatchSize)"
                        class="rounded bg-slate-900 text-white px-4 py-2 text-sm hover:bg-slate-800">开始分类</button>
                </div>
            </div>
        </div>

        <!-- Template Edit Modal -->
        <div x-cloak x-show="showTemplateEditModal"
            class="fixed inset-0 z-50 flex items-center justify-center bg-black/50"
            @keydown.escape.window="if(showTemplateEditModal) { if(hasUnsavedTemplateChanges()) { if(await AppDialog.confirm('有未保存的修改，确定要关闭吗？')) showTemplateEditModal = false; } else { showTemplateEditModal = false; } }">
            <div class="w-full max-w-3xl rounded-lg bg-white p-4 shadow-xl max-h-[85vh] flex flex-col">
                <div class="flex items-center justify-between mb-3 flex-shrink-0">
                    <h3 class="text-lg font-semibold" x-text="templateEditTarget ? '编辑模板' : '新建自定义模板'"></h3>
                    <button @click="if(hasUnsavedTemplateChanges()) { if(await AppDialog.confirm('有未保存的修改，确定要关闭吗？')) showTemplateEditModal = false; } else { showTemplateEditModal = false; }"
                        class="text-slate-400 hover:text-slate-600 text-xl">&times;</button>
                </div>
                <template x-if="!templateEditTarget">
                    <div class="mb-3 flex-shrink-0">
                        <label class="text-xs text-slate-600">基于</label>
                        <select x-model="templateEditSourceId"
                            @change="loadPresetTreeForEdit(templateEditSourceId)"
                            class="w-full rounded border px-3 py-2 text-sm mt-1">
                            <option :value="null">空白模板</option>
                            <template x-for="tpl in presetTemplates" :key="tpl.id">
                                <option :value="tpl.id" x-text="tpl.name"></option>
                            </template>
                        </select>
                    </div>
                </template>
                <div class="mb-3 flex-shrink-0">
                    <label class="text-xs text-slate-600">模板名称</label>
                    <input type="text" x-model="templateEditName"
                        class="w-full rounded border px-3 py-2 text-sm mt-1" placeholder="输入模板名称">
                </div>
                <div class="flex items-center justify-between mb-2 flex-shrink-0">
                    <span class="text-xs text-slate-600">分类树</span>
                    <button @click="addTemplateTreeNode()"
                        class="text-xs text-blue-500 hover:underline">+ 添加一级分类</button>
                </div>
                <div class="flex-1 overflow-y-auto border rounded p-2 space-y-2 min-h-0">
                    <template x-for="(node, pi) in templateEditTree" :key="pi">
                        <div class="space-y-1">
                            <div class="flex items-center gap-2">
                                <input type="text" x-model="templateEditTree[pi].name"
                                    class="flex-1 rounded border px-2 py-1 text-sm">
                                <button @click="addTemplateTreeNode(pi)"
                                    class="text-xs text-blue-500 hover:underline">+ 子分类</button>
                                <button @click="removeTemplateTreeNode(pi)"
                                    class="text-xs text-rose-500 hover:underline">删除</button>
                            </div>
                            <template x-if="node.children && node.children.length > 0">
                                <div class="ml-6 space-y-1">
                                    <template x-for="(child, ci) in node.children" :key="ci">
                                        <div class="flex items-center gap-2">
                                            <input type="text"
                                                x-model="templateEditTree[pi].children[ci].name"
                                                class="flex-1 rounded border px-2 py-1 text-sm">
                                            <button @click="removeTemplateTreeNode(pi, ci)"
                                                class="text-xs text-rose-500 hover:underline">删除</button>
                                        </div>
                                    </template>
                                </div>
                            </template>
                        </div>
                    </template>
                    <template x-if="templateEditTree.length === 0">
                        <div class="text-xs text-slate-400 text-center py-4">暂无分类，点击上方按钮添加</div>
                    </template>
                </div>
                <div class="flex justify-end gap-2 mt-3 pt-3 border-t flex-shrink-0">
                    <button @click="if(hasUnsavedTemplateChanges()) { if(await AppDialog.confirm('有未保存的修改，确定要关闭吗？')) showTemplateEditModal = false; } else { showTemplateEditModal = false; }"
                        class="rounded border px-4 py-2 text-sm hover:bg-slate-50">取消</button>
                    <button @click="saveTemplateEdit()"
                        class="rounded bg-slate-900 text-white px-4 py-2 text-sm hover:bg-slate-800">保存</button>
                </div>
            </div>
        </div>

        <!-- AI Organize Modal -->
        <div x-cloak x-show="showAIOrganizeModal"
            class="fixed inset-0 z-50 flex items-center justify-center bg-black/50"
            @click.self="closeOrganizeModal()">
            <div class="w-full max-w-2xl rounded-lg bg-white p-4 shadow-xl max-h-[90vh] overflow-y-auto">
                <div class="flex items-center justify-between mb-3">
                    <h3 class="text-lg font-semibold">🤖 AI 整理</h3>
                    <button @click="closeOrganizeModal()"
                        class="text-slate-400 hover:text-slate-600 text-xl">&times;</button>
                </div>

                <!-- Phase: idle - Scope selection -->
                <template x-if="organizePhase === 'idle'">
                    <div class="space-y-3">
                        <p class="text-sm text-slate-500">AI 将基于当前分类模板，批量匹配书签到最合适的分类。</p>
                        <template x-if="!activeTemplate">
                            <div class="text-xs text-amber-600 bg-amber-50 border border-amber-200 rounded px-3 py-2">请先在左侧「分类模板」中选择并应用一个模板，AI 整理依赖模板中的分类结构。</div>
                        </template>
                        <div>
                            <label class="text-xs text-slate-600">整理范围</label>
                            <select x-model="organizeScope" class="w-full rounded border px-3 py-2 text-sm mt-1">
                                <option value="all">全部书签</option>
                                <option value="uncategorized">未分类书签</option>
                                <option value="category">指定分类</option>
                            </select>
                        </div>
                        <template x-if="organizeScope === 'category'">
                            <div>
                                <label class="text-xs text-slate-600">选择分类</label>
                                <select x-model="organizeScopeCategoryId" class="w-full rounded border px-3 py-2 text-sm mt-1">
                                    <template x-for="cat in categories" :key="cat.id">
                                        <option :value="cat.id" x-text="cat.name"></option>
                                    </template>
                                </select>
                            </div>
                        </template>
                        <div class="flex justify-end gap-2">
                            <button @click="closeOrganizeModal()"
                                class="rounded border px-4 py-2 text-sm hover:bg-slate-50">取消</button>
                            <button @click="startOrganize()"
                                class="rounded bg-slate-900 text-white px-4 py-2 text-sm hover:bg-slate-800">开始整理</button>
                        </div>
                    </div>
                </template>

                <!-- Phase: assigning - Progress -->
                <template x-if="organizePhase === 'assigning'">
                    <div class="space-y-4">
                        <div class="flex flex-col items-center gap-3">
                            <div class="text-xs text-slate-400">批量归类中</div>
                            <div class="relative w-24 h-24">
                                <svg class="w-24 h-24 transform -rotate-90">
                                    <circle cx="48" cy="48" r="40" stroke="#e2e8f0" stroke-width="8" fill="none" />
                                    <circle cx="48" cy="48" r="40" stroke="#8b5cf6" stroke-width="8" fill="none"
                                        stroke-linecap="round" :stroke-dasharray="251.2"
                                        :stroke-dashoffset="251.2 - (organizeProgress.batches_total > 0 ? 251.2 * organizeProgress.batches_done / organizeProgress.batches_total : 0)" />
                                </svg>
                                <div class="absolute inset-0 flex items-center justify-center">
                                    <span class="text-xl font-bold text-purple-600"
                                        x-text="organizeProgress.batches_total > 0 ? Math.floor(organizeProgress.batches_done / organizeProgress.batches_total * 100) + '%' : '准备中...'"></span>
                                </div>
                            </div>
                            <div class="text-center">
                                <div class="text-sm font-medium text-slate-700"
                                    x-text="'批次 ' + organizeProgress.batches_done + ' / ' + organizeProgress.batches_total"></div>
                                <div class="text-xs text-slate-400 mt-1">AI 正在批量归类书签...</div>
                            </div>
                        </div>
                        <div class="flex justify-center gap-2 pt-2 border-t">
                            <button @click="cancelOrganize()"
                                class="flex items-center gap-1 rounded-lg border border-rose-200 text-rose-600 px-4 py-2 text-sm hover:bg-rose-50 transition">
                                <span>✕</span> 取消
                            </button>
                            <a x-show="organizePlan?.job_id" :href="'/jobs/' + organizePlan?.job_id"
                                class="flex items-center gap-1 rounded-lg border border-slate-200 text-slate-600 px-4 py-2 text-sm hover:bg-slate-50 transition">
                                查看任务详情
                            </a>
                        </div>
                    </div>
                </template>

                <!-- Phase: failed -->
                <template x-if="organizePhase === 'failed'">
                    <div class="space-y-3">
                        <div class="flex flex-col items-center gap-2 py-4">
                            <div class="w-12 h-12 rounded-full bg-rose-100 flex items-center justify-center text-2xl">✕</div>
                            <div class="text-sm font-medium text-rose-700">归类失败</div>
                            <div class="text-xs text-slate-500 text-center" x-text="organizePlan?.message || '连续多个批次失败，请检查 AI 配置后重试'"></div>
                        </div>
                        <template x-if="organizeProgress.failed_batch_ids && organizeProgress.failed_batch_ids.length > 0">
                            <div class="text-xs text-slate-400 text-center">
                                失败批次: <span x-text="organizeProgress.failed_batch_ids.join(', ')"></span>
                            </div>
                        </template>
                        <div class="flex justify-center gap-2 pt-2 border-t">
                            <button @click="cancelOrganize()"
                                class="rounded border px-4 py-2 text-sm hover:bg-slate-50">放弃</button>
                            <button @click="retryOrganize()"
                                class="rounded bg-slate-900 text-white px-4 py-2 text-sm hover:bg-slate-800">重试</button>
                        </div>
                    </div>
                </template>

            </div>
        </div>
        <div x-cloak x-show="showImportProgressModal"
            class="fixed inset-0 z-50 flex items-center justify-center bg-black/50">
            <div class="w-full max-w-md rounded-lg bg-white p-4 shadow-xl">
                <div class="flex items-center justify-between mb-3">
                    <h3 class="text-lg font-semibold">📥 导入进度</h3>
                    <button @click="closeImportProgressModal()"
                        class="text-slate-400 hover:text-slate-600 text-xl">&times;</button>
                </div>
                <div class="space-y-3 text-center">
                    <div class="text-2xl" x-text="importProgress + '%'"></div>
                    <div class="w-full h-2 bg-slate-200 rounded overflow-hidden">
                        <div class="h-full bg-blue-500 transition-all" :style="'width:' + importProgress + '%'"></div>
                    </div>
                    <div class="text-sm text-slate-500"
                        x-text="importStats.processed + '/' + importStats.total + ' (成功:' + importStats.inserted + ' 失败:' + importStats.failed + ')'">
                    </div>
                    <button @click="cancelImportJob()"
                        class="rounded border border-rose-300 text-rose-600 px-4 py-2 text-sm hover:bg-rose-50">取消导入</button>
                </div>
            </div>
        </div>

        <!-- Backup Modal -->
        <div x-cloak x-show="showBackupModal" class="fixed inset-0 z-50 flex items-center justify-center bg-black/50"
            @click.self="closeBackupModal()">
            <div class="w-full max-w-2xl rounded-lg bg-white p-4 shadow-xl max-h-[90vh] overflow-y-auto">
                <div class="flex items-center justify-between mb-3">
                    <h3 class="text-lg font-semibold">💾 备份管理</h3>
                    <button @click="closeBackupModal()"
                        class="text-slate-400 hover:text-slate-600 text-xl">&times;</button>
                </div>
                <div class="flex justify-between items-center mb-4">
                    <button @click="runBackupNow()"
                        class="rounded bg-slate-900 text-white px-4 py-2 text-sm hover:bg-slate-800">立即备份</button>
                    <a href="/settings" class="text-sm text-blue-500 hover:underline">备份设置</a>
                </div>
                <div class="space-y-4">
                    <!-- Manual Backups -->
                    <div>
                        <h4 class="text-sm font-medium text-slate-700 mb-2">手动备份</h4>
                        <template x-if="manualBackups.length === 0">
                            <div class="text-xs text-slate-400">暂无手动备份</div>
                        </template>
                        <div class="space-y-1">
                            <template x-for="b in manualBackups" :key="b.name">
                                <div class="flex items-center justify-between p-2 bg-slate-50 rounded text-sm">
                                    <span x-text="b.name"></span>
                                    <div class="flex items-center gap-2 text-xs">
                                        <span class="text-slate-400" x-text="formatBytes(b.size)"></span>
                                        <button @click="restoreBackup(b.name)"
                                            class="text-blue-500 hover:underline">还原</button>
                                        <button @click="deleteBackup(b.name)"
                                            class="text-rose-500 hover:underline">删除</button>
                                    </div>
                                </div>
                            </template>
                        </div>
                    </div>
                    <!-- Auto Backups -->
                    <div>
                        <h4 class="text-sm font-medium text-slate-700 mb-2">自动备份</h4>
                        <template x-if="autoBackups.length === 0">
                            <div class="text-xs text-slate-400">暂无自动备份</div>
                        </template>
                        <div class="space-y-1">
                            <template x-for="b in autoBackups" :key="b.name">
                                <div class="flex items-center justify-between p-2 bg-slate-50 rounded text-sm">
                                    <span x-text="b.name"></span>
                                    <div class="flex items-center gap-2 text-xs">
                                        <span class="text-slate-400" x-text="formatBytes(b.size)"></span>
                                        <button @click="restoreBackup(b.name)"
                                            class="text-blue-500 hover:underline">还原</button>
                                        <button @click="deleteBackup(b.name)"
                                            class="text-rose-500 hover:underline">删除</button>
                                    </div>
                                </div>
                            </template>
                        </div>
                    </div>
                    <!-- Upload Restore -->
                    <div class="pt-4 border-t">
                        <h4 class="text-sm font-medium text-slate-700 mb-2">上传还原</h4>
                        <form @submit.prevent="uploadAndRestore($event)">
                            <input type="file" name="file" accept=".db" class="text-xs mb-2">
                            <button type="submit"
                                class="rounded border px-3 py-1.5 text-sm hover:bg-slate-50">上传并还原</button>
                        </form>
                    </div>
                </div>
                <div class="flex justify-end mt-4">
                    <button @click="closeBackupModal()"
                        class="rounded border px-4 py-2 text-sm hover:bg-slate-50">关闭</button>
                </div>
            </div>
        </div>

        <!-- Export Modal -->
        <div x-cloak x-show="showExportModal" class="fixed inset-0 z-50 flex items-center justify-center bg-black/50"
            @click.self="closeExportModal()">
            <div class="w-full max-w-md rounded-lg bg-white p-4 shadow-xl">
                <div class="flex items-center justify-between mb-3">
                    <h3 class="text-lg font-semibold">📤 导出书签</h3>
                    <button @click="closeExportModal()"
                        class="text-slate-400 hover:text-slate-600 text-xl">&times;</button>
                </div>
                <div class="space-y-3">
                    <div>
                        <label class="text-xs text-slate-600">导出范围</label>
                        <select x-model="exportScope" class="w-full rounded border px-3 py-2 text-sm mt-1">
                            <option value="all">全部书签</option>
                            <option value="uncategorized">仅未分类</option>
                            <option value="selected" x-show="selectedCategories.length > 0">选中分类</option>
                        </select>
                    </div>
                    <div>
                        <label class="text-xs text-slate-600">导出格式</label>
                        <select x-model="exportFormat" class="w-full rounded border px-3 py-2 text-sm mt-1">
                            <option value="html">浏览器书签 (HTML)</option>
                            <option value="json">JSON</option>
                        </select>
                    </div>
                </div>
                <div class="flex justify-end gap-2 mt-4">
                    <button @click="closeExportModal()"
                        class="rounded border px-4 py-2 text-sm hover:bg-slate-50">取消</button>
                    <a :href="getExportUrl()" @click="closeExportModal()"
                        class="rounded bg-slate-900 text-white px-4 py-2 text-sm hover:bg-slate-800 inline-block">下载</a>
                </div>
            </div>
        </div>
    </div>
    <script src="/public/lib/alpine.min.js"></script>
</body>

</html>
